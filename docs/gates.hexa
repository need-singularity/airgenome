//  EFFECT SYSTEM — sources and sinks
// ═══════════════════════════════════════════════════════════════════════

effect FileIO {
    fn read_file(path: str) -> str
    fn write_file(path: str, data: str) -> ()
}

effect ProcessSensor {
    fn list_processes() -> str          // ps -axm output
    fn read_sysctl(key: str) -> str     // sysctl read-only
}

