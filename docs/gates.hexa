// ═══════════════════════════════════════════════════════════════════════
//  CLASSIFICATION + RULE FIRING
// ═══════════════════════════════════════════════════════════════════════

// Classify ALL processes — no process left behind.
// 0=macos 1=finder 2=telegram 3=chrome 4=safari 5=claude 6=terminal 7=devtools
fn classify_path(comm: str) -> int {
    // Named gates (exact match priority)
    if comm.contains("WebKit") { return 4 }
    if comm.contains("Safari") { return 4 }
    if comm.contains("Google Chrome") { return 3 }
    if comm.contains("Telegram") { return 2 }
    if comm.contains("Finder") { return 1 }
    if comm.contains("com.apple.Finder") { return 1 }
    // Claude gate
    if comm.contains("claude") { return 5 }
    // Terminal gate
    if comm.contains("iTerm") { return 6 }
    if comm.contains("Terminal.app") { return 6 }
    if comm.contains("Alacritty") { return 6 }
    if comm.contains("Warp") { return 6 }
    // Devtools gate
    if comm.contains("rustc") { return 7 }
    if comm.contains("cargo") { return 7 }
    if comm.contains("Python") { return 7 }
    if comm.contains("python") { return 7 }
    if comm.contains("node") { return 7 }
    if comm.contains("npm") { return 7 }
    if comm.contains("Xcode") { return 7 }
    if comm.contains("Code Helper") { return 7 }
    if comm.contains("gopls") { return 7 }
    if comm.contains("rust-analyzer") { return 7 }
    if comm.contains("mcp") { return 7 }
    // macOS system (broad catch-all for system paths)
    if comm.contains("/usr/") { return 0 }
    if comm.contains("/System/") { return 0 }
    if comm.contains("/sbin/") { return 0 }
    if comm.contains("kernel_task") { return 0 }
    if comm.contains("launchd") { return 0 }
    if comm.contains("WindowServer") { return 0 }
    // Everything else → macos (gate 0) as catch-all
    return 0
}

// Legacy named classify (for self-tests)
pure fn classify(proc_name: str) -> int {
    match proc_name {
        "launchd" -> 0
        "WindowServer" -> 0
        "kernel_task" -> 0
        "Finder" -> 1
        "Telegram" -> 2
        "Google Chrome" -> 3
        "Safari" -> 4
        _ -> -1
    }
}

// Array mutation helpers (hexa-lang disallows arr[k]=v inside while)
fn aset(arr: auto, idx: int, val: float) -> auto {
    arr[idx] = val
    return arr
}
fn aadd(arr: auto, idx: int, val: float) -> auto {
    arr[idx] = arr[idx] + val
    return arr
}
fn nadd(arr: auto, idx: int, val: int) -> auto {
    arr[idx] = arr[idx] + val
    return arr
}

// ═══════════════════════════════════════════════════════════════════════
//  BREAKTHROUGH FORMULA (canonical)
// ═══════════════════════════════════════════════════════════════════════

let RAW = 0.6360                                   // rule-only baseline
let CURRENT_MESH = 0.0044                          // nexus original mesh coupling
let GHOST_PENALTY = -0.0026                        // ghost RSS correction
let SCALE = 0.0151 / 1.500                         // nexus implicit scaling ratio
let MARGIN_MIN_L1 = 0.005                          // L1-ship threshold
let MARGIN_MIN_L2 = 0.100                          // L2-ship
let MARGIN_MIN_L3 = 0.130                          // L3-ship
let MARGIN_MIN_L4 = 0.140                          // L4-ship
let MARGIN_MIN_L5A = 0.240                         // L5a-ship
let MARGIN_MIN_L6 = 0.310                          // L6-ship target
let PAIR_THRESHOLD = 0.5                           // default per-pair firing threshold

// Pure math — no effects, deterministic, referentially transparent.

pure fn abs_float(x: float) -> float {
    if x < 0.0 { return -x }
    return x
}

pure fn mutual_info_stub(sample_count: int) -> float {
    // MI estimator placeholder — real impl uses histogram binning
    if sample_count < 2 { return 0.0 }
    return 0.0
}

pure fn lagged_mi_stub(sample_count: int, lag: int) -> float {
    if sample_count <= lag { return 0.0 }
    return 0.0
}

pure fn triadic_stub(sample_count: int) -> float {
    if sample_count < 15 { return 0.0 }
    return 0.0
}

pure fn transfer_entropy_stub(sample_count: int) -> float {
    if sample_count < 2 { return 0.0 }
    return 0.0
}

// Verdict classifier.
pure fn grade_margin(margin: float) -> str {
    if margin <= 0.0   { return "under-singularity" }
    if margin <= 0.005 { return "boundary" }
    if margin <= 0.05  { return "weak-breakthrough" }
    if margin <= 0.15  { return "strong-breakthrough" }
    if margin <= 0.30  { return "deep-breakthrough" }
    return "transcendent"
}

pure fn compute_adjusted(per_gate_mi: float, cross_gate_mi: float) -> float {
    let new_mi_recovery = per_gate_mi * SCALE * 1.5
    let new_cross_coupling = cross_gate_mi * SCALE
    return RAW + CURRENT_MESH + new_cross_coupling + new_mi_recovery + GHOST_PENALTY
}

pure fn is_crossed(adjusted: float) -> bool {
    return adjusted > SINGULARITY
}

