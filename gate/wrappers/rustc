#!/bin/bash
# cargo 자식 프로세스로 호출 시 게이트 skip (CARGO env = cargo가 설정)
[ -n "$CARGO" ] && exec "$HOME/.cargo/bin/rustc" "$@"

UBU_HOST="192.168.50.119"; UBU_PORT="9900"; UBU_SSH="ubu"; UBU_DIR="/tmp/airgenome"; TS_HOST=""
CFG="$HOME/Dev/airgenome/nexus/shared/gate_config.jsonl"
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SELF_DIR/_cache.sh"
ag_load_config "$CFG"
ag_budget_check && GATE_LOCAL=1
ag_budget_enter
ag_resolve_host
if [ "$GATE_LOCAL" = "1" ]; then
  ag_gate_msg "local" "rustc $*"
  exec "$HOME/.cargo/bin/rustc" "$@"
elif [ -z "$GH" ]; then
  ag_gate_msg "unreachable" "rustc $*"
  exec "$HOME/.cargo/bin/rustc" "$@"
fi

# remote dispatch
ag_gate_msg "remote" "rustc $*" "$GH:$UBU_PORT" "$UBU_DIR"
rsync -aq --update "$HOME/Dev/nexus/shared/" "$UBU_SSH:$UBU_DIR/nexus/shared/" 2>/dev/null &

HAS_FILE=false
RARGS=()
BASENAME=""
for a in "$@"; do
  if [[ -f "$a" && "$a" == *.rs ]]; then
    HAS_FILE=true
    BASENAME="$(basename "$a" .rs)"
    ssh "$UBU_SSH" "mkdir -p $UBU_DIR/gate_files" 2>/dev/null
    scp -q "$a" "$UBU_SSH:$UBU_DIR/gate_files/" 2>/dev/null
    RARGS+=("$UBU_DIR/gate_files/$(basename "$a")")
  else
    RARGS+=("$a")
  fi
done

wait  # rsync 완료 대기
if [ "$HAS_FILE" = "true" ]; then
  # 컴파일 + 실행
  echo "cd $UBU_DIR/gate_files && source ~/.cargo/env && rustc ${RARGS[*]} -o $UBU_DIR/gate_files/$BASENAME && $UBU_DIR/gate_files/$BASENAME" | nc -w 600 "$GH" "$UBU_PORT" 2>/dev/null | sed '/^---END---$/d'
else
  echo "source ~/.cargo/env && rustc ${RARGS[*]}" | nc -w 600 "$GH" "$UBU_PORT" 2>/dev/null | sed '/^---END---$/d'
fi
