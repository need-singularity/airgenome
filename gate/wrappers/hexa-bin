#!/bin/bash
# hexa-bin gate wrapper — 모든 hexa-bin 호출을 Ubuntu로 오프로드
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
LOCAL_BIN="$SELF_DIR/hexa-bin-real"

UBU_HOST="192.168.50.119"; UBU_PORT="9900"; UBU_SSH="ubu"; UBU_DIR="/tmp/airgenome"; TS_HOST=""
CFG="$HOME/Dev/airgenome/nexus/shared/gate_config.jsonl"
# budget + reachability + config cache (GATE_G1 optimization)
. "$SELF_DIR/_cache.sh"
ag_load_config "$CFG"
ag_budget_enter
ag_filter_decide hexa-bin "$@"
_t0=$(date +%s)

if [ "$FILTER_BUDGET_BYPASS" != "1" ]; then
  ag_budget_check && FILTER_TARGET="local"
fi

ag_resolve_host
if [ "$FILTER_TARGET" = "ubu" ] && [ -z "$GH" ]; then FILTER_TARGET="local"; fi

if [ "$FILTER_TARGET" = "local" ]; then
  ag_gate_msg "local" "hexa-bin $* [filter:$FILTER_REASON]"
  "$LOCAL_BIN" "$@"
  _rc=$?
  ag_filter_record hexa-bin local "$_rc" $(( $(date +%s) - _t0 ))
  exit $_rc
fi

# pre-sync (백그라운드)
rsync -aq --update "$HOME/Dev/nexus/shared/" "$UBU_SSH:$UBU_DIR/nexus/shared/" 2>/dev/null &

# 파일 인자 → scp
RARGS=()
for a in "$@"; do
  if [[ -f "$a" ]]; then
    ssh "$UBU_SSH" "mkdir -p $UBU_DIR/gate_files" 2>/dev/null
    scp -q "$a" "$UBU_SSH:$UBU_DIR/gate_files/" 2>/dev/null
    RARGS+=("$UBU_DIR/gate_files/$(basename "$a")")
  else
    RARGS+=("$a")
  fi
done

wait
REMOTE_HEXA="/tmp/hexa-build/hexa-lang/target/release/hexa"
echo "cd $UBU_DIR && $REMOTE_HEXA ${RARGS[*]}" | nc -w 600 "$GH" "$UBU_PORT" 2>/dev/null | sed '/^---END---$/d'
_rc=$?
ag_filter_record hexa-bin "${FILTER_TARGET:-ubu}" "$_rc" $(( $(date +%s) - _t0 ))
exit $_rc
