#!/bin/bash
UBU_HOST="192.168.50.119"; UBU_PORT="9900"; UBU_SSH="ubu"; UBU_DIR="/tmp/airgenome"; TS_HOST=""
CFG="$HOME/Dev/airgenome/nexus/shared/gate_config.jsonl"
# budget + reachability + config cache (GATE_G1 optimization)
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SELF_DIR/_cache.sh"
ag_load_config "$CFG"
ag_budget_check && GATE_LOCAL=1
ag_budget_enter
ag_resolve_host
if [ "$GATE_LOCAL" = "1" ]; then
  ag_gate_msg "local" "cargo $*"
  exec "$HOME/.cargo/bin/cargo" "$@"
elif [ -z "$GH" ]; then
  ag_gate_msg "unreachable" "cargo $*"
  exec "$HOME/.cargo/bin/cargo" "$@"
fi

# remote dispatch
ag_gate_msg "remote" "cargo $*" "$GH:$UBU_PORT" "$UBU_DIR"
rsync -aq --update "$HOME/Dev/nexus/shared/" "$UBU_SSH:$UBU_DIR/nexus/shared/" 2>/dev/null
echo "cd $UBU_DIR && source ~/.cargo/env && cargo $*" | nc -w 600 "$GH" "$UBU_PORT" 2>/dev/null | sed '/^---END---$/d'
