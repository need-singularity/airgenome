msg1(hint_label, sel(cstring("setTextColor:")), sec_color)

msg1(cv, sel(cstring("addSubview:")), hint_label)

// ═══════════════════════════════════════════════════════════════════════
//  Show window + run
// ═══════════════════════════════════════════════════════════════════════

msg1(win, sel(cstring("makeKeyAndOrderFront:")), ptr_null())
msg_int(app, sel(cstring("activateIgnoringOtherApps:")), 1)

// Auto-refresh timer (10s interval) — G3 (float) + G4 (callback trampoline)
// Use scheduledTimerWithTimeInterval:target:selector:userInfo:repeats:
// which sends the action selector to a target object (avoids ObjC blocks).
let timer_cls_name = cls(cstring("NSObject"))
let timer_target_cls = alloc_class(timer_cls_name, cstring("TimerTarget"), 0)

fn timer_fire(self_arg, cmd_arg, timer_arg, unused_arg) {
    refresh_account_data()
    do_reload_table()
}
let timer_fire_imp = callback_create(timer_fire)
add_method(timer_target_cls, sel(cstring("onTimer:")),
           timer_fire_imp, cstring("v@:@"))

register_class(timer_target_cls)
let timer_target = msg0(msg0(timer_target_cls, sel(cstring("alloc"))), sel(cstring("init")))

// Float-typed msgSend for scheduledTimerWithTimeInterval:target:selector:userInfo:repeats:
// Args: (cls, sel, interval: Float, target, selector, userInfo, repeats: Int)
@symbol("objc_msgSend")
extern fn msg_timer(obj: *Void, sel: *Void, interval: Float, target: *Void, action: *Void, info: *Void, repeats: Int) -> *Void

let timer_cls = cls(cstring("NSTimer"))
msg_timer(
    timer_cls,
    sel(cstring("scheduledTimerWithTimeInterval:target:selector:userInfo:repeats:")),
    10.0,                         // 10 second interval
    timer_target,                 // target
    sel(cstring("onTimer:")),     // selector
    ptr_null(),                   // userInfo: nil
    1                             // repeats: YES
)

// Run the application event loop
msg0(app, sel(cstring("run")))

// ═══════════════════════════════════════════════════════════════════════
//  Cleanup — free callback trampolines
// ═══════════════════════════════════════════════════════════════════════
// Note: app.run() blocks until quit, so cleanup runs after window closes
callback_free(row_count_imp)
callback_free(cell_value_imp)
callback_free(remove_imp)
callback_free(restore_imp)
callback_free(refresh_imp)
callback_free(timer_fire_imp)
