// sampler.hexa — airgenome 백그라운드 리소스 샘플러 (run.sh 내장 루프 분리)
// 사용: hexa sampler.hexa <state_path> <config_path> <total_ram_mb> <ncpu> <dir>
// 5초 간격으로 CPU/RAM/Swap/Load/Gate 측정 → state JSON 기록

let a = args()
if a.len() < 7 {
    println("Usage: hexa sampler.hexa <state> <config> <ram_mb> <ncpu> <dir>")
    exit(1)
}

let STATE = a[2]
let CONFIG = a[3]
let TOTAL_RAM_MB = to_int(to_float(a[4]))
let NCPU = to_int(to_float(a[5]))
let DIR = a[6]
let THROTTLE_FILE = exec("echo ${TMPDIR:-/tmp}").trim() + "/airgenome-throttled.pids"

fn read_config_val(path: str, key: str, default_val: int) -> int {
    if file_exists(path) == false { return default_val }
    let raw = read_file(path)
    if raw.contains("\"" + key + "\"") == false { return default_val }
    let p = raw.split("\"" + key + "\"")[1]
    let v = p.split(":")[1].split(",")[0].split("}")[0].trim()
    try { return to_int(to_float(v)) } catch e { return default_val }
}

let mut prev_level = "ok"
let mut prev_net_bytes = 0
let mut prev_net_ts = 0
let mut prev_disk_kb = 0
let mut prev_disk_ts = 0

while true {
    // ── MEASURE ── (정밀도 <1%: 단일 top 호출 + vm_stat 페이지 단위)

    // CPU — top -l2 평균(첫 샘플은 부팅 이래 누적이라 부정확), 소수 1자리 유지
    let cpu_str = exec("top -l2 -n0 2>/dev/null | awk '/CPU usage/{u=$3; s=$5; gsub(/%/,\"\",u); gsub(/%/,\"\",s); a=u+s} END{printf \"%.1f\",a}'").trim()
    let mut cpu = 0
    let mut cpu_f = 0.0
    try { cpu_f = to_float(cpu_str) } catch e {}
    if cpu_f <= 0.0 {
        let cpu_total = exec("ps -A -o %cpu= | awk '{s+=$1}END{printf \"%.2f\",s}'").trim()
        try { cpu_f = to_float(cpu_total) / to_float(to_string(NCPU)) } catch e {}
    }
    cpu = to_int(cpu_f)

    // RAM — vm_stat 페이지 단위 (active+wired+compressor). top "23G"는 해상도 1GB(~4% 오차).
    let ram_str = exec("vm_stat 2>/dev/null | awk 'BEGIN{ps=16384} /page size of/{ps=$8} /Pages active/{a=$3} /Pages wired down/{w=$4} /Pages occupied by compressor/{c=$5} END{gsub(/\\./,\"\",a); gsub(/\\./,\"\",w); gsub(/\\./,\"\",c); printf \"%.1f\",(a+w+c)*ps/1048576}'").trim()
    let mut ram_used_f = 0.0
    try { ram_used_f = to_float(ram_str) } catch e {}
    let ram_used_mb = to_int(ram_used_f)
    let free_mb = if TOTAL_RAM_MB > ram_used_mb { TOTAL_RAM_MB - ram_used_mb } else { 0 }
    let ram = if TOTAL_RAM_MB > 0 { ram_used_mb * 100 / TOTAL_RAM_MB } else { 0 }

    // Swap — vm.swapusage used 필드, 소수 정밀도 유지
    let swap_str = exec("sysctl -n vm.swapusage 2>/dev/null | awk '{gsub(/M/,\"\",$3); printf \"%.1f\",$3}'").trim()
    let mut swap_f = 0.0
    try { swap_f = to_float(swap_str) } catch e {}
    let swap_mb = to_int(swap_f)
    let swap = if TOTAL_RAM_MB > 0 { swap_mb * 100 / TOTAL_RAM_MB } else { 0 }

    // Load
    let load_str = exec("sysctl -n vm.loadavg 2>/dev/null | awk '{gsub(/[{}]/,\"\"); printf \"%.0f\",$1}'").trim()
    let mut load = 0
    try { load = to_int(to_float(load_str)) } catch e {}

    // Net — netstat -ibn 델타, MB/s (1% 미만 정밀도 유지 위해 bytes 단위)
    let net_now_str = exec("netstat -ibn 2>/dev/null | awk 'NR>1 && $1!~/^lo/ && $1!~/^utun/ && $4!~/:/{ib+=$7; ob+=$10} END{printf \"%.0f\",ib+ob}'").trim()
    let ts_str = exec("date +%s").trim()
    let mut net_now = 0
    let mut ts_now = 0
    try { net_now = to_int(to_float(net_now_str)) } catch e {}
    try { ts_now = to_int(to_float(ts_str)) } catch e {}
    let mut net_mbps = 0
    let mut net_kbps_f = 0.0
    if prev_net_bytes > 0 && ts_now > prev_net_ts {
        let dt = ts_now - prev_net_ts
        let db = if net_now > prev_net_bytes { net_now - prev_net_bytes } else { 0 }
        if dt > 0 {
            net_mbps = (db / dt) / 1048576
            try { net_kbps_f = to_float(to_string(db)) / to_float(to_string(dt)) / 1024.0 } catch e {}
        }
    }
    prev_net_bytes = net_now
    prev_net_ts = ts_now

    // Disk — iostat 1초 샘플, MB/s (nonblocking 단발)
    let disk_now_str = exec("iostat -d -c 2 disk0 2>/dev/null | awk 'END{printf \"%.1f\",$3}'").trim()
    let mut disk_mbps_f = 0.0
    try { disk_mbps_f = to_float(disk_now_str) } catch e {}
    let disk_mbps = to_int(disk_mbps_f)

    // GPU (로컬 Apple Silicon) — ioreg 기반 IOGPU 사용률 (powermetrics sudo 필요없이)
    let gpu_local_str = exec("ioreg -r -d 1 -w 0 -c IOAccelerator 2>/dev/null | grep -o '\"Device Utilization %\"=[0-9]*' | head -1 | awk -F= '{print $2}'").trim()
    let mut gpu_local = 0
    try { gpu_local = to_int(to_float(gpu_local_str)) } catch e {}

    // ── CONFIG ──
    let cpu_ceil = read_config_val(CONFIG, "cpu_ceil", 90)
    let ram_ceil = read_config_val(CONFIG, "ram_ceil", 80)
    let swap_ceil = read_config_val(CONFIG, "swap_ceil", 50)
    let mut bridge_max = read_config_val(CONFIG, "bridge_max", 4)

    // ── DYNAMIC BRIDGE_MAX (vitals L5c NMI 기반 자동조절) ──
    let vitals_path = DIR + "/forge/state.json"
    if file_exists(vitals_path) {
        let vraw = read_file(vitals_path)
        if vraw.contains("\"l5c_nmi\"") {
            let nmi_s = vraw.split("\"l5c_nmi\"")[1].split(":")[1].split(",")[0].split("}")[0].trim()
            let mut l5c_nmi = 0.0
            try { l5c_nmi = to_float(nmi_s) } catch e {}
            if l5c_nmi > 0.3 && ram > 60 {
                // 높은 temporal persistence + RAM 부하 → 브릿지 반감
                bridge_max = bridge_max / 2
                if bridge_max < 1 { bridge_max = 1 }
            } else if prev_level == "ok" && l5c_nmi < 0.15 {
                // 안정 상태 → 브릿지 여유 +2
                bridge_max = bridge_max + 2
            }
        }
    }

    // ── BRIDGE LIMITER ──
    let bridge_pids = exec("ps -eo pid=,command= | grep 'gap_finder.hexa bridge' | grep -v grep | awk '{print $1}'").trim()
    let bridge_count_str = exec("echo '" + bridge_pids.replace("'", "") + "' | grep -c . 2>/dev/null || echo 0").trim()
    let mut bridge_count = 0
    try { bridge_count = to_int(to_float(bridge_count_str)) } catch e {}

    if bridge_max > 0 && bridge_count > bridge_max {
        let kill_n = bridge_count - bridge_max
        exec("echo '" + bridge_pids + "' | head -" + to_string(kill_n) + " | while read BPID; do kill $BPID 2>/dev/null; done")
    }

    // ── LEVEL ──
    let mut level = "ok"
    let mut throttled = "false"

    let swap_thrash = swap_mb > 10240
    let load_saturated = load > (NCPU * 5)

    if free_mb < 200 || swap_thrash {
        level = "critical"
        throttled = "true"
        exec("purge 2>/dev/null")
        if bridge_count > 0 {
            exec("echo '" + bridge_pids + "' | while read BPID; do kill $BPID 2>/dev/null; done")
        }
        exec("ps -eo pid=,rss=,comm= | sort -rnk2 | head -5 | while read TPID TRSS TNAME; do [ \"$TPID\" -lt 200 ] 2>/dev/null && continue; case \"$TNAME\" in kernel_task|WindowServer|launchd|loginwindow|opendirectoryd) continue ;; esac; taskpolicy -b -p $TPID 2>/dev/null; echo $TPID >> " + THROTTLE_FILE + "; done")
    } else if free_mb < 512 || load_saturated {
        level = "danger"
        throttled = "true"
        exec("purge 2>/dev/null")
        if bridge_count > 1 {
            exec("echo '" + bridge_pids + "' | head -" + to_string(bridge_count - 1) + " | while read BPID; do kill $BPID 2>/dev/null; done")
        }
    } else if ram > ram_ceil || cpu > cpu_ceil || swap > swap_ceil {
        level = "warn"
        // ── PREDICTIVE PURGE (RAM→Swap 캐스케이드 예방) ──
        if ram > 70 {
            let mut pred_nmi = 0.0
            if file_exists(vitals_path) {
                let vr2 = read_file(vitals_path)
                if vr2.contains("\"l5c_nmi\"") {
                    let ns2 = vr2.split("\"l5c_nmi\"")[1].split(":")[1].split(",")[0].split("}")[0].trim()
                    try { pred_nmi = to_float(ns2) } catch e {}
                }
            }
            if pred_nmi > 0.4 {
                // L5c NMI 높음 = RAM 압박 지속적 → 조기 purge
                exec("purge 2>/dev/null")
            }
        }
    } else {
        if file_exists(THROTTLE_FILE) {
            exec("sort -u " + THROTTLE_FILE + " | while read RPID; do taskpolicy -d default -p $RPID 2>/dev/null; done")
            exec("rm -f " + THROTTLE_FILE)
        }
    }

    // ── SAVINGS ──
    let sys_cpu_total_s = exec("ps -A -o %cpu= | awk '{s+=$1}END{printf \"%.0f\",s}'").trim()
    let sys_ram_total_s = exec("ps -A -o rss= | awk '{s+=$1}END{printf \"%.0f\",s/1024}'").trim()
    let mut sys_cpu_total = 1
    let mut sys_ram_total = 1
    try { sys_cpu_total = to_int(to_float(sys_cpu_total_s)) } catch e {}
    try { sys_ram_total = to_int(to_float(sys_ram_total_s)) } catch e {}
    if sys_cpu_total < 1 { sys_cpu_total = 1 }
    if sys_ram_total < 1 { sys_ram_total = 1 }

    let hog_cpu_s = exec("ps -eo pid=,%cpu=,comm= | awk '$1>100 && $2>30.0 {c=$3; if(c~/kernel_task|WindowServer|launchd|loginwindow|Finder|Dock/) next; s+=$2*0.30} END{printf \"%.0f\",s}'").trim()
    let hog_ram_s = exec("ps -eo pid=,rss=,comm= | awk '$1>100 && $2>1048576 {c=$3; if(c~/kernel_task|WindowServer|launchd|loginwindow|Finder|Dock/) next; s+=($2/1024)*0.20} END{printf \"%.0f\",s}'").trim()
    let claude_s = exec("ps -eo pid=,rss=,%cpu=,comm= | grep '[c]laude' | awk '$3<1.0 {s+=($2/1024)*0.20} END{printf \"%.0f\",s}'").trim()
    let webkit_s = exec("ps -eo pid=,rss=,%cpu=,comm= | grep 'WebKit.WebContent' | awk '$3<0.5 && $2>204800 {s+=($2/1024)*0.20} END{printf \"%.0f\",s}'").trim()

    let mut hog_cpu = 0
    let mut hog_ram = 0
    try { hog_cpu = to_int(to_float(hog_cpu_s)) } catch e {}
    try { hog_ram = to_int(to_float(hog_ram_s)) } catch e {}
    let mut claude_save = 0
    let mut webkit_save = 0
    try { claude_save = to_int(to_float(claude_s)) } catch e {}
    try { webkit_save = to_int(to_float(webkit_s)) } catch e {}
    hog_ram = hog_ram + claude_save + webkit_save

    let mut save_cpu = hog_cpu * 100 / sys_cpu_total
    let mut save_ram = hog_ram * 100 / sys_ram_total
    if save_cpu > 99 { save_cpu = 99 }
    if save_ram > 99 { save_ram = 99 }

    // ── GATE STATUS ──
    let gate_cfg = DIR + "/nexus/shared/gate_config.jsonl"
    let mut ubu_host = "192.168.50.119"
    let mut ubu_port = "9900"
    if file_exists(gate_cfg) {
        let gh = exec("awk -F'\"' '/\"remote_host\"/{print $8}' " + gate_cfg + " 2>/dev/null").trim()
        let gp = exec("awk -F'\"' '/\"remote_port\"/{print $8}' " + gate_cfg + " 2>/dev/null").trim()
        if len(gh) > 0 { ubu_host = gh }
        if len(gp) > 0 { ubu_port = gp }
    }

    let mut gate = "offline"
    let mut ubu_load = "0"
    let mut ubu_ram_pct = 0
    let mut ubu_ram_used = 0
    let mut ubu_ram_total = 0
    let mut ubu_ram_avail = 0
    let mut ubu_jobs = 0
    let mut ubu_cpu = 0
    let mut ubu_gpu_util = 0
    let mut ubu_gpu_mem = 0
    let mut ubu_gpu_name = ""

    let gate_check = exec("nc -z -w 1 " + ubu_host + " " + ubu_port + " 2>/dev/null && echo y || echo n").trim()
    if gate_check == "y" {
        gate = "online"
        let ubu_status = exec("echo STATUS | nc -w 2 " + ubu_host + " " + ubu_port + " 2>/dev/null").trim()
        if len(ubu_status) > 0 {
            let ul = exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'load=[^ ]*' | cut -d= -f2 | awk '{print $1}'").trim()
            if len(ul) > 0 { ubu_load = ul }
            let uru = exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'ram=[^ ]*' | cut -d= -f2 | cut -d/ -f1").trim()
            let urt = exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'ram=[^ ]*' | cut -d/ -f2 | sed 's/MB.*//'").trim()
            let ura = exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'avail=[^ ]*' | cut -d= -f2 | sed 's/MB.*//'").trim()
            try { ubu_ram_used = to_int(to_float(uru)) } catch e {}
            try { ubu_ram_total = to_int(to_float(urt)) } catch e {}
            try { ubu_ram_avail = to_int(to_float(ura)) } catch e {}
            if ubu_ram_total > 0 { ubu_ram_pct = ubu_ram_used * 100 / ubu_ram_total }
            // jobs/cpu/gpu 모두 STATUS 응답에서 파싱 (SSH 제거 — 렉 방지)
            let uj = exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'jobs=[^ ]*' | cut -d= -f2").trim()
            try { ubu_jobs = to_int(to_float(uj)) } catch e {}
            let uc = exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'cpu=[^ ]*' | cut -d= -f2").trim()
            try { ubu_cpu = to_int(to_float(uc)) } catch e {}
            // GPU: "gpu=<util>, <mem>, <name>" — 첫 gpu= 이후 전부
            if ubu_status.contains("gpu=") {
                let gpu_csv = ubu_status.split("gpu=")[1].trim()
                if len(gpu_csv) > 0 {
                    if gpu_csv.contains("No devices") == false {
                        if gpu_csv.contains("error") == false {
                            let gparts = gpu_csv.split(",")
                            if len(gparts) >= 3 {
                                try { ubu_gpu_util = to_int(to_float(gparts[0].trim())) } catch e {}
                                try { ubu_gpu_mem = to_int(to_float(gparts[1].trim())) } catch e {}
                                ubu_gpu_name = gparts[2].trim()
                            }
                        }
                    }
                }
            }
        }
    }

    // ── WRITE STATE ──
    let mut disk_kbps_f = 0.0
    try { disk_kbps_f = to_float(disk_now_str) * 1024.0 } catch e {}
    let gpu_local_f_str = if len(gpu_local_str) > 0 { gpu_local_str } else { "0" }
    let state_json = "{\"active\":true,\"cpu\":" + to_string(cpu) + ",\"cpu_f\":" + cpu_str + ",\"ram\":" + to_string(ram) + ",\"ram_f\":" + ram_str + ",\"ram_used_mb\":" + to_string(ram_used_mb) + ",\"swap\":" + to_string(swap) + ",\"swap_f\":" + swap_str + ",\"swap_mb\":" + to_string(swap_mb) + ",\"net_mbps\":" + to_string(net_mbps) + ",\"net_mbps_f\":" + to_string(net_kbps_f) + ",\"disk_mbps\":" + to_string(disk_mbps) + ",\"disk_mbps_f\":" + to_string(disk_kbps_f) + ",\"gpu_local\":" + to_string(gpu_local) + ",\"gpu_local_f\":" + gpu_local_f_str + ",\"free_mb\":" + to_string(free_mb) + ",\"load\":" + to_string(load) + ",\"level\":\"" + level + "\",\"throttled\":" + throttled + ",\"cpu_ceil\":" + to_string(cpu_ceil) + ",\"ram_ceil\":" + to_string(ram_ceil) + ",\"swap_ceil\":" + to_string(swap_ceil) + ",\"save_cpu\":" + to_string(save_cpu) + ",\"save_ram\":" + to_string(save_ram) + ",\"gate\":\"" + gate + "\",\"ubu_load\":\"" + ubu_load + "\",\"ubu_ram_pct\":" + to_string(ubu_ram_pct) + ",\"ubu_ram_used\":" + to_string(ubu_ram_used) + ",\"ubu_ram_total\":" + to_string(ubu_ram_total) + ",\"ubu_ram_avail\":" + to_string(ubu_ram_avail) + ",\"ubu_jobs\":" + to_string(ubu_jobs) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"ubu_gpu_util\":" + to_string(ubu_gpu_util) + ",\"ubu_gpu_mem\":" + to_string(ubu_gpu_mem) + ",\"ubu_gpu_name\":\"" + ubu_gpu_name + "\"}"
    try { write_file(STATE, state_json + "\n") } catch e {}

    // vitals_ring tick — 6축 push
    exec("$HOME/Dev/hexa-lang/target/release/hexa $HOME/Dev/airgenome/modules/vitals_ring.hexa tick " + to_string(cpu) + " " + to_string(ram) + " " + to_string(swap) + " " + to_string(net_mbps) + " " + to_string(disk_mbps) + " " + to_string(gpu_local))

    prev_level = level
    exec("sleep 5")
}
