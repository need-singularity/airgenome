// sampler.hexa — airgenome 백그라운드 리소스 샘플러 (run.sh 내장 루프 분리)
// 사용: hexa sampler.hexa <state_path> <config_path> <total_ram_mb> <ncpu> <dir>
// adaptive 간격(ok=15s/warn=5s/critical=3s)으로 CPU/RAM/Swap/Load/Gate 측정 → state JSON 기록

let a = args()
if a.len() < 7 {
    println("Usage: hexa sampler.hexa <state> <config> <ram_mb> <ncpu> <dir>")
    exit(1)
}

let STATE = a[2]
let CONFIG = a[3]
let TOTAL_RAM_MB = to_int(to_float(a[4]))
let NCPU = to_int(to_float(a[5]))
let DIR = a[6]
let THROTTLE_FILE = try { exec("echo ${TMPDIR:-/tmp}").trim() } catch e { "/tmp" } + "/airgenome-throttled.pids"

fn read_config_val(path: str, key: str, default_val: int) -> int {
    if file_exists(path) == false { return default_val }
    let raw = read_file(path)
    if raw.contains("\"" + key + "\"") == false { return default_val }
    let p = raw.split("\"" + key + "\"")[1]
    let v = p.split(":")[1].split(",")[0].split("}")[0].trim()
    try { return to_int(to_float(v)) } catch e { return default_val }
}

fn read_jsonl_val(path: str, key: str, default_val: int) -> int {
    if file_exists(path) == false { return default_val }
    let v = try { exec("awk -F'\"' '/\"" + key + "\"/{print $8}' " + path + " 2>/dev/null").trim() } catch e { "" }
    if len(v) == 0 { return default_val }
    try { return to_int(to_float(v)) } catch e { return default_val }
}

let mut prev_level = "ok"
let mut prev_net_bytes = 0
let mut prev_net_ts = 0
let mut prev_disk_kb = 0
let mut prev_disk_ts = 0
let mut prev_save_cpu = 0
let mut prev_save_ram = 0
let mut prev_ghost_sh = 0
let mut prev_ghost_grep = 0
let mut cycle = 0

// EMA (지수이동평균) — 측정 노이즈 감쇠, 정밀도 향상
let EMA_ALPHA = 0.3   // α=0.3: 최신 30% + 이력 70%
let mut ema_cpu = -1.0
let mut ema_ram = -1.0
let mut ema_swap = -1.0
let mut ema_gpu = -1.0

fn ema(prev: float, cur: float, alpha: float) -> float {
    if prev < 0.0 { return cur }  // 초기값
    return alpha * cur + (1.0 - alpha) * prev
}

// Alert cooldown — growth_bus 스팸 방지 (최소 300초 간격)
let mut last_l5c_alert_ts = 0
let mut last_l6e_alert_ts = 0
let ALERT_COOLDOWN = 300

// --once 모드: 1회 실행 후 exit (LaunchAgent StartInterval 호환)
let ONCE_MODE = env("AIRGENOME_SAMPLER_ONCE") == "1"

while true {
    // ── ADAPTIVE SCAN ── (lite_scan: ok 레벨 시 heavy exec 스킵, 첫 사이클은 항상 full)
    let lite_scan = (prev_level == "ok" && cycle > 0)
    cycle = cycle + 1

    // ── MEASURE ── (정밀도 <1%: 단일 top 호출 + vm_stat 페이지 단위)

    // CPU — top -l1 (첫 샘플은 부팅 이래 누적이라 부정확), 소수 1자리 유지
    let mut cpu_str = ""
    let mut cpu = 0
    let mut cpu_f = 0.0
    if lite_scan == false {
        cpu_str = try { exec("top -l1 -n0 -s0 2>/dev/null | awk '/CPU usage/{u=$3; s=$5; gsub(/%/,\"\",u); gsub(/%/,\"\",s); printf \"%.1f\",u+s}'").trim() } catch e { "0" }
        try { cpu_f = to_float(cpu_str) } catch e {}
    }
    // ps -A -o %cpu= 캐시 (savings + fallback 공용, 중복 호출 제거)
    let ps_cpu_cache = if lite_scan && ema_cpu >= 0.0 { "" } else { try { exec("ps -A -o %cpu= | awk '{s+=$1}END{printf \"%.2f\",s}'").trim() } catch e { "0" } }

    if cpu_f <= 0.0 {
        if lite_scan && ema_cpu >= 0.0 {
            // lite_scan: EMA 값 직접 사용 (top -l2 + ps 둘 다 스킵)
            cpu_f = ema_cpu
        } else {
            try { cpu_f = to_float(ps_cpu_cache) / to_float(to_string(NCPU)) } catch e {}
        }
        cpu_str = to_string(cpu_f)
    }
    // EMA 평활
    ema_cpu = ema(ema_cpu, cpu_f, EMA_ALPHA)
    cpu_f = ema_cpu
    cpu_str = to_string(cpu_f)
    cpu = to_int(cpu_f)

    // RAM — vm_stat 페이지 단위 (active+wired+compressor). top "23G"는 해상도 1GB(~4% 오차).
    let ram_str = try { exec("vm_stat 2>/dev/null | awk 'BEGIN{ps=16384} /page size of/{ps=$8} /Pages active/{a=$3} /Pages wired down/{w=$4} /Pages occupied by compressor/{c=$5} END{gsub(/\\./,\"\",a); gsub(/\\./,\"\",w); gsub(/\\./,\"\",c); printf \"%.1f\",(a+w+c)*ps/1048576}'").trim() } catch e { "0" }
    let mut ram_used_f = 0.0
    try { ram_used_f = to_float(ram_str) } catch e {}
    ema_ram = ema(ema_ram, ram_used_f, EMA_ALPHA)
    ram_used_f = ema_ram
    let ram_used_mb = to_int(ram_used_f)
    let free_mb = if TOTAL_RAM_MB > ram_used_mb { TOTAL_RAM_MB - ram_used_mb } else { 0 }
    let ram = if TOTAL_RAM_MB > 0 { ram_used_mb * 100 / TOTAL_RAM_MB } else { 0 }

    // Swap — vm.swapusage used 필드, 소수 정밀도 유지
    let swap_str = try { exec("sysctl -n vm.swapusage 2>/dev/null | awk '{gsub(/M/,\"\",$3); printf \"%.1f\",$3}'").trim() } catch e { "0" }
    let mut swap_f = 0.0
    try { swap_f = to_float(swap_str) } catch e {}
    ema_swap = ema(ema_swap, swap_f, EMA_ALPHA)
    swap_f = ema_swap
    let swap_mb = to_int(swap_f)
    let swap = if TOTAL_RAM_MB > 0 { swap_mb * 100 / TOTAL_RAM_MB } else { 0 }

    // Load
    let load_str = try { exec("sysctl -n vm.loadavg 2>/dev/null | awk '{gsub(/[{}]/,\"\"); printf \"%.0f\",$1}'").trim() } catch e { "0" }
    let mut load = 0
    try { load = to_int(to_float(load_str)) } catch e {}

    // Net — netstat -ibn 델타, MB/s (1% 미만 정밀도 유지 위해 bytes 단위)
    let net_now_str = try { exec("netstat -ibn 2>/dev/null | awk 'NR>1 && $1!~/^lo/ && $1!~/^utun/ && $4!~/:/{ib+=$7; ob+=$10} END{printf \"%.0f\",ib+ob}'").trim() } catch e { "0" }
    let ts_str = try { exec("date +%s").trim() } catch e { "0" }
    let mut net_now = 0
    let mut ts_now = 0
    try { net_now = to_int(to_float(net_now_str)) } catch e {}
    try { ts_now = to_int(to_float(ts_str)) } catch e {}
    let mut net_mbps = 0
    let mut net_kbps_f = 0.0
    if prev_net_bytes > 0 && ts_now > prev_net_ts {
        let dt = ts_now - prev_net_ts
        let db = if net_now > prev_net_bytes { net_now - prev_net_bytes } else { 0 }
        if dt > 0 {
            net_mbps = (db / dt) / 1048576
            try { net_kbps_f = to_float(to_string(db)) / to_float(to_string(dt)) / 1024.0 } catch e {}
        }
    }
    prev_net_bytes = net_now
    prev_net_ts = ts_now

    // Disk — iostat -Id cumulative KB (delta 방식, 정밀도 향상)
    let mut disk_cum = prev_disk_kb
    let mut disk_mbps = 0
    let mut disk_mbps_f = 0.0
    if lite_scan == false {
        let disk_cum_str = try { exec("iostat -Id disk0 2>/dev/null | awk 'NR==3{printf \"%.0f\",$3}'").trim() } catch e { "0" }
        try { disk_cum = to_int(to_float(disk_cum_str)) } catch e {}
    }
    if prev_disk_kb > 0 && ts_now > prev_disk_ts {
        let dt = ts_now - prev_disk_ts
        let dk = if disk_cum > prev_disk_kb { disk_cum - prev_disk_kb } else { 0 }
        if dt > 0 {
            disk_mbps = dk / dt / 1024
            try { disk_mbps_f = to_float(to_string(dk)) / to_float(to_string(dt)) / 1024.0 } catch e {}
        }
    }
    if lite_scan == false {
        prev_disk_kb = disk_cum
        prev_disk_ts = ts_now
    }

    // GPU (로컬 Apple Silicon) — ioreg 기반 IOGPU 사용률 (powermetrics sudo 필요없이)
    let mut gpu_local_str = ""
    let mut gpu_local = 0
    if lite_scan == false {
        gpu_local_str = try { exec("ioreg -r -d 1 -w 0 -c IOAccelerator 2>/dev/null | grep -o '\"Device Utilization %\"=[0-9]*' | head -1 | awk -F= '{print $2}'").trim() } catch e { "" }
        let mut gpu_raw = 0.0
        try { gpu_raw = to_float(gpu_local_str) } catch e {}
        ema_gpu = ema(ema_gpu, gpu_raw, EMA_ALPHA)
    }
    // lite_scan에서도 EMA 값 사용
    if ema_gpu >= 0.0 {
        gpu_local = to_int(ema_gpu)
        gpu_local_str = to_string(ema_gpu)
    }

    // ── CONFIG ──
    let cpu_ceil = read_config_val(CONFIG, "cpu_ceil", 90)
    let ram_ceil = read_config_val(CONFIG, "ram_ceil", 80)
    let swap_ceil = read_config_val(CONFIG, "swap_ceil", 50)
    let mut bridge_max = read_config_val(CONFIG, "bridge_max", 4)

    // ── DYNAMIC BRIDGE_MAX (vitals L5c NMI 기반 자동조절) ──
    let vitals_path = DIR + "/forge/state.json"
    if file_exists(vitals_path) {
        let vraw = read_file(vitals_path)
        if vraw.contains("\"l5c_nmi\"") {
            let nmi_s = vraw.split("\"l5c_nmi\"")[1].split(":")[1].split(",")[0].split("}")[0].trim()
            let mut l5c_nmi = 0.0
            try { l5c_nmi = to_float(nmi_s) } catch e {}
            if l5c_nmi > 0.3 && ram > 60 {
                // 높은 temporal persistence + RAM 부하 → 브릿지 반감
                bridge_max = bridge_max / 2
                if bridge_max < 1 { bridge_max = 1 }
            } else if prev_level == "ok" && l5c_nmi < 0.15 {
                // 안정 상태 → 브릿지 여유 +2
                bridge_max = bridge_max + 2
            }
        }
    }

    // ── BRIDGE LIMITER ── (lite_scan: 매 2사이클마다만 실행)
    let mut bridge_pids = ""
    let mut bridge_count = 0
    if lite_scan == false || cycle % 2 == 0 {
        bridge_pids = try { exec("ps -eo pid=,command= | grep 'gap_finder.hexa bridge' | grep -v grep | awk '{print $1}'").trim() } catch e { "" }
        let bridge_count_str = try { exec("echo '" + bridge_pids.replace("'", "") + "' | grep -c . 2>/dev/null || echo 0").trim() } catch e { "0" }
        try { bridge_count = to_int(to_float(bridge_count_str)) } catch e {}

        if bridge_max > 0 && bridge_count > bridge_max {
            let kill_n = bridge_count - bridge_max
            try { exec("echo '" + bridge_pids + "' | head -" + to_string(kill_n) + " | while read BPID; do kill $BPID 2>/dev/null; done") } catch e { println("[warn] sampler: bridge kill failed — " + e) }
        }
    }

    // ── LEVEL ──
    let mut level = "ok"
    let mut throttled = "false"

    let swap_thrash = swap_mb > 10240
    let load_saturated = load > (NCPU * 5)

    if free_mb < 200 || swap_thrash {
        level = "critical"
        throttled = "true"
        try { exec("purge 2>/dev/null") } catch e { println("[warn] sampler: purge failed — " + e) }
        if bridge_count > 0 {
            try { exec("echo '" + bridge_pids + "' | while read BPID; do kill $BPID 2>/dev/null; done") } catch e { println("[warn] sampler: bridge kill failed — " + e) }
        }
        try { exec("ps -eo pid=,rss=,comm= | sort -rnk2 | head -5 | while read TPID TRSS TNAME; do [ \"$TPID\" -lt 200 ] 2>/dev/null && continue; case \"$TNAME\" in kernel_task|WindowServer|launchd|loginwindow|opendirectoryd) continue ;; esac; taskpolicy -b -p $TPID 2>/dev/null; echo $TPID >> " + THROTTLE_FILE + "; done") } catch e { println("[warn] sampler: taskpolicy throttle failed — " + e) }
    } else if free_mb < 512 || load_saturated {
        level = "danger"
        throttled = "true"
        try { exec("purge 2>/dev/null") } catch e { println("[warn] sampler: purge failed — " + e) }
        if bridge_count > 1 {
            try { exec("echo '" + bridge_pids + "' | head -" + to_string(bridge_count - 1) + " | while read BPID; do kill $BPID 2>/dev/null; done") } catch e { println("[warn] sampler: bridge kill failed — " + e) }
        }
    } else if ram > ram_ceil || cpu > cpu_ceil || swap > swap_ceil {
        level = "warn"
        // ── PREDICTIVE PURGE (RAM→Swap 캐스케이드 예방) ──
        if ram > 70 {
            let mut pred_nmi = 0.0
            if file_exists(vitals_path) {
                let vr2 = read_file(vitals_path)
                if vr2.contains("\"l5c_nmi\"") {
                    let ns2 = vr2.split("\"l5c_nmi\"")[1].split(":")[1].split(",")[0].split("}")[0].trim()
                    try { pred_nmi = to_float(ns2) } catch e {}
                }
            }
            if pred_nmi > 0.4 {
                // L5c NMI 높음 = RAM 압박 지속적 → 조기 purge
                try { exec("purge 2>/dev/null") } catch e { println("[warn] sampler: predictive purge failed — " + e) }
            }
        }
    } else {
        if file_exists(THROTTLE_FILE) {
            try {
                exec("sort -u " + THROTTLE_FILE + " | while read RPID; do taskpolicy -d default -p $RPID 2>/dev/null; done")
                exec("rm -f " + THROTTLE_FILE)
            } catch e { println("[warn] sampler: taskpolicy restore failed — " + e) }
        }
    }

    // ── SAVINGS ── (lite_scan: 매 3사이클마다만 재계산, 캐시 ps 재사용)
    let mut save_cpu = prev_save_cpu
    let mut save_ram = prev_save_ram
    if lite_scan == false || cycle % 3 == 0 {
        // sys_cpu: 캐시된 ps_cpu_cache 재사용 (중복 ps -A -o %cpu= 제거)
        let sys_cpu_total_s = if len(ps_cpu_cache) > 0 { ps_cpu_cache } else { try { exec("ps -A -o %cpu= | awk '{s+=$1}END{printf \"%.0f\",s}'").trim() } catch e { "1" } }
        let sys_ram_total_s = try { exec("ps -A -o rss= | awk '{s+=$1}END{printf \"%.0f\",s/1024}'").trim() } catch e { "1" }
        let mut sys_cpu_total = 1
        let mut sys_ram_total = 1
        try { sys_cpu_total = to_int(to_float(sys_cpu_total_s)) } catch e {}
        try { sys_ram_total = to_int(to_float(sys_ram_total_s)) } catch e {}
        if sys_cpu_total < 1 { sys_cpu_total = 1 }
        if sys_ram_total < 1 { sys_ram_total = 1 }

        let hog_cpu_s = try { exec("ps -eo pid=,%cpu=,comm= | awk '$1>100 && $2>30.0 {c=$3; if(c~/kernel_task|WindowServer|launchd|loginwindow|Finder|Dock/) next; s+=$2*0.30} END{printf \"%.0f\",s}'").trim() } catch e { "0" }
        let hog_ram_s = try { exec("ps -eo pid=,rss=,comm= | awk '$1>100 && $2>1048576 {c=$3; if(c~/kernel_task|WindowServer|launchd|loginwindow|Finder|Dock/) next; s+=($2/1024)*0.20} END{printf \"%.0f\",s}'").trim() } catch e { "0" }
        let claude_s = try { exec("ps -eo pid=,rss=,%cpu=,comm= | grep '[c]laude' | awk '$3<1.0 {s+=($2/1024)*0.20} END{printf \"%.0f\",s}'").trim() } catch e { "0" }
        let webkit_s = try { exec("ps -eo pid=,rss=,%cpu=,comm= | grep 'WebKit.WebContent' | awk '$3<0.5 && $2>204800 {s+=($2/1024)*0.20} END{printf \"%.0f\",s}'").trim() } catch e { "0" }

        let mut hog_cpu = 0
        let mut hog_ram = 0
        try { hog_cpu = to_int(to_float(hog_cpu_s)) } catch e {}
        try { hog_ram = to_int(to_float(hog_ram_s)) } catch e {}
        let mut claude_save = 0
        let mut webkit_save = 0
        try { claude_save = to_int(to_float(claude_s)) } catch e {}
        try { webkit_save = to_int(to_float(webkit_s)) } catch e {}
        hog_ram = hog_ram + claude_save + webkit_save

        save_cpu = hog_cpu * 100 / sys_cpu_total
        save_ram = hog_ram * 100 / sys_ram_total
        if save_cpu > 99 { save_cpu = 99 }
        if save_ram > 99 { save_ram = 99 }
        prev_save_cpu = save_cpu
        prev_save_ram = save_ram
    }

    // ── GHOST PROCESS DETECTION (detect-only, Prime Directive safe) ──
    // lite_scan: 매 5사이클마다만 실행, 나머지는 이전 값 유지
    let mut ghost_sh = prev_ghost_sh
    let mut ghost_grep = prev_ghost_grep
    if lite_scan == false || cycle % 5 == 0 {
        let ghost_sh_s = try { exec("ps -eo ppid,etime,pcpu,pid,comm | awk '$1==1 && $5==\"sh\" {split($2,t,/[-:]/); if(length(t)>=3){h=t[1]}else{h=0}; if(h>=1 && $3>1.0) c++} END{print c+0}'").trim() } catch e { "0" }
        let ghost_grep_s = try { exec("ps -eo ppid,etime,pcpu,pid,comm | awk '$1==1 && $5==\"grep\" {split($2,t,/[-:]/); if(length(t)>=3){h=t[1]}else{h=0}; if(h>=1 && $3>1.0) c++} END{print c+0}'").trim() } catch e { "0" }
        try { ghost_sh = to_int(to_float(ghost_sh_s)) } catch e {}
        try { ghost_grep = to_int(to_float(ghost_grep_s)) } catch e {}
        prev_ghost_sh = ghost_sh
        prev_ghost_grep = ghost_grep
    }
    let ghost_total = ghost_sh + ghost_grep
    if ghost_total >= 3 && level == "ok" {
        level = "warn"
    }

    // ── GHOST AUTO-KILL — orphan 프로세스 정리 (Prime Directive 예외: PPID=1 orphan은 죽은 프로세스) ──
    if ghost_sh + ghost_grep > 0 {
        try { exec("ps -eo ppid,etime,pcpu,pid,comm | awk '$1==1 && $5==\"sh\" {split($2,t,/[-:]/); if(length(t)>=3){h=t[1]}else{h=0}; if(h>=1 && $3>1.0) print $4}' | xargs kill 2>/dev/null") } catch e {}
        try { exec("ps -eo ppid,etime,pcpu,pid,comm | awk '$1==1 && $5==\"grep\" {split($2,t,/[-:]/); if(length(t)>=3){h=t[1]}else{h=0}; if(h>=1 && $3>1.0) print $4}' | xargs kill 2>/dev/null") } catch e {}
    }

    // ── GATE STATUS ──
    let gate_cfg = DIR + "/nexus/shared/gate_config.jsonl"
    let mut ubu_host = ""
    let mut ubu_port = "9900"
    if file_exists(gate_cfg) {
        let gh = try { exec("awk -F'\"' '/\"remote_host\"/{print $8}' " + gate_cfg + " 2>/dev/null").trim() } catch e { "" }
        let gp = try { exec("awk -F'\"' '/\"remote_port\"/{print $8}' " + gate_cfg + " 2>/dev/null").trim() } catch e { "" }
        if len(gh) > 0 { ubu_host = gh }
        if len(gp) > 0 { ubu_port = gp }
    }
    if len(ubu_host) == 0 { ubu_host = try { exec("printenv AG3_UBU_HOST 2>/dev/null || true").trim() } catch e { "" } }

    let mut gate = "offline"
    let mut ubu_load = "0"
    let mut ubu_ram_pct = 0
    let mut ubu_ram_used = 0
    let mut ubu_ram_total = 0
    let mut ubu_ram_avail = 0
    let mut ubu_jobs = 0
    let mut ubu_cpu = 0
    let mut ubu_gpu_util = 0
    let mut ubu_gpu_mem = 0
    let mut ubu_gpu_name = ""

    let gate_check = try { exec("nc -z -w 1 " + ubu_host + " " + ubu_port + " 2>/dev/null && echo y || echo n").trim() } catch e { "n" }
    if gate_check == "y" {
        gate = "online"
        let ubu_status = try { exec("echo STATUS | nc -w 2 " + ubu_host + " " + ubu_port + " 2>/dev/null").trim() } catch e { "" }
        if len(ubu_status) > 0 {
            let ul = try { exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'load=[^ ]*' | cut -d= -f2 | awk '{print $1}'").trim() } catch e { "" }
            if len(ul) > 0 { ubu_load = ul }
            let uru = try { exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'ram=[^ ]*' | cut -d= -f2 | cut -d/ -f1").trim() } catch e { "" }
            let urt = try { exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'ram=[^ ]*' | cut -d/ -f2 | sed 's/MB.*//'").trim() } catch e { "" }
            let ura = try { exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'avail=[^ ]*' | cut -d= -f2 | sed 's/MB.*//'").trim() } catch e { "" }
            try { ubu_ram_used = to_int(to_float(uru)) } catch e {}
            try { ubu_ram_total = to_int(to_float(urt)) } catch e {}
            try { ubu_ram_avail = to_int(to_float(ura)) } catch e {}
            if ubu_ram_total > 0 { ubu_ram_pct = ubu_ram_used * 100 / ubu_ram_total }
            // jobs/cpu/gpu 모두 STATUS 응답에서 파싱 (SSH 제거 — 렉 방지)
            let uj = try { exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'jobs=[^ ]*' | cut -d= -f2").trim() } catch e { "" }
            try { ubu_jobs = to_int(to_float(uj)) } catch e {}
            let uc = try { exec("echo '" + ubu_status.replace("'", "") + "' | grep -o 'cpu=[^ ]*' | cut -d= -f2").trim() } catch e { "" }
            try { ubu_cpu = to_int(to_float(uc)) } catch e {}
            // GPU: "gpu=<util>, <mem>, <name>" — 첫 gpu= 이후 전부
            if ubu_status.contains("gpu=") {
                let gpu_csv = ubu_status.split("gpu=")[1].trim()
                if len(gpu_csv) > 0 {
                    if gpu_csv.contains("No devices") == false {
                        if gpu_csv.contains("error") == false {
                            let gparts = gpu_csv.split(",")
                            if len(gparts) >= 3 {
                                try { ubu_gpu_util = to_int(to_float(gparts[0].trim())) } catch e {}
                                try { ubu_gpu_mem = to_int(to_float(gparts[1].trim())) } catch e {}
                                ubu_gpu_name = gparts[2].trim()
                            }
                        }
                    }
                }
            }
        }
    }

    // ── WRITE STATE ──
    let disk_kbps_f = disk_mbps_f * 1024.0
    let gpu_local_f_str = if len(gpu_local_str) > 0 { gpu_local_str } else { "0" }
    let state_json = "{\"active\":true,\"cpu\":" + to_string(cpu) + ",\"cpu_f\":" + cpu_str + ",\"ram\":" + to_string(ram) + ",\"ram_f\":" + ram_str + ",\"ram_used_mb\":" + to_string(ram_used_mb) + ",\"swap\":" + to_string(swap) + ",\"swap_f\":" + swap_str + ",\"swap_mb\":" + to_string(swap_mb) + ",\"net_mbps\":" + to_string(net_mbps) + ",\"net_mbps_f\":" + to_string(net_kbps_f) + ",\"disk_mbps\":" + to_string(disk_mbps) + ",\"disk_mbps_f\":" + to_string(disk_kbps_f) + ",\"gpu_local\":" + to_string(gpu_local) + ",\"gpu_local_f\":" + gpu_local_f_str + ",\"free_mb\":" + to_string(free_mb) + ",\"load\":" + to_string(load) + ",\"level\":\"" + level + "\",\"throttled\":" + throttled + ",\"cpu_ceil\":" + to_string(cpu_ceil) + ",\"ram_ceil\":" + to_string(ram_ceil) + ",\"swap_ceil\":" + to_string(swap_ceil) + ",\"save_cpu\":" + to_string(save_cpu) + ",\"save_ram\":" + to_string(save_ram) + ",\"gate\":\"" + gate + "\",\"ubu_load\":\"" + ubu_load + "\",\"ubu_ram_pct\":" + to_string(ubu_ram_pct) + ",\"ubu_ram_used\":" + to_string(ubu_ram_used) + ",\"ubu_ram_total\":" + to_string(ubu_ram_total) + ",\"ubu_ram_avail\":" + to_string(ubu_ram_avail) + ",\"ubu_jobs\":" + to_string(ubu_jobs) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"ubu_gpu_util\":" + to_string(ubu_gpu_util) + ",\"ubu_gpu_mem\":" + to_string(ubu_gpu_mem) + ",\"ubu_gpu_name\":\"" + ubu_gpu_name + "\",\"ghost_sh\":" + to_string(ghost_sh) + ",\"ghost_grep\":" + to_string(ghost_grep) + "}"
    // 원자적 쓰기: tmp → rename (menubar read 레이스 방지, 골화)
    let tmp_state = STATE + ".tmp"
    try {
        write_file(tmp_state, state_json + "\n")
        exec("mv -f '" + tmp_state + "' '" + STATE + "'")
    } catch e {}

    // vitals_ring tick — 6축 push (float 정밀도 유지: int 절삭 → <1% 오차)
    let vr_cpu = cpu_str
    // ram_str = MB 단위 → 퍼센트 float 변환 필요
    let vr_ram = to_string(ram_used_f * 100.0 / to_float(to_string(TOTAL_RAM_MB)))
    // swap_str = MB 단위 → 퍼센트 float 변환 필요
    let vr_swap = to_string(swap_f * 100.0 / to_float(to_string(TOTAL_RAM_MB)))
    let vr_net = to_string(net_kbps_f / 1024.0)
    let vr_disk = to_string(disk_mbps_f)
    let vr_gpu = gpu_local_f_str
    let HEXA_BIN = env("HOME") + "/.hx/bin/hexa"
    let VR_MOD = env("HOME") + "/Dev/airgenome/modules/vitals_ring.hexa"
    let vr_cmd = HEXA_BIN + " " + VR_MOD + " tick " + vr_cpu + " " + vr_ram + " " + vr_swap + " " + vr_net + " " + vr_disk + " " + vr_gpu
    try { exec(vr_cmd + " >> /tmp/airgenome-vr-tick.log 2>&1") } catch e {
        try { exec("echo '[ERR] " + e + "' >> /tmp/airgenome-vr-tick.log") } catch e2 {}
    }

    // ── L5c/L6e ALERT → growth_bus ──
    // vitals_ring tick이 forge/state.json에 병합 → 읽어서 임계값 확인
    if file_exists(vitals_path) {
        let vr3 = read_file(vitals_path)
        let mut alert_nmi = 0.0
        let mut alert_l6e = 0.0
        if vr3.contains("\"l5c_nmi\"") {
            let ns3 = vr3.split("\"l5c_nmi\"")[1].split(":")[1].split(",")[0].split("}")[0].trim()
            try { alert_nmi = to_float(ns3) } catch e {}
        }
        if vr3.contains("\"l6e_score\"") {
            let ls3 = vr3.split("\"l6e_score\"")[1].split(":")[1].split(",")[0].split("}")[0].trim()
            try { alert_l6e = to_float(ls3) } catch e {}
        }
        let gb_path = DIR + "/nexus/shared/growth_bus.jsonl"
        let alert_ts = try { exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() } catch e { "" }
        if alert_nmi > 0.7 && (ts_now - last_l5c_alert_ts) > ALERT_COOLDOWN {
            let ev = "{\"ts\":\"" + alert_ts + "\",\"source\":\"sampler\",\"type\":\"vitals_alert\",\"metric\":\"l5c_nmi\",\"value\":" + to_string(alert_nmi) + ",\"severity\":\"high\",\"note\":\"momentum persistence > 0.7\"}"
            try { exec("echo '" + ev + "' >> " + gb_path) } catch e {}
            last_l5c_alert_ts = ts_now
        }
        if alert_l6e < 0.3 && alert_l6e > 0.001 && (ts_now - last_l6e_alert_ts) > ALERT_COOLDOWN {
            let ev2 = "{\"ts\":\"" + alert_ts + "\",\"source\":\"sampler\",\"type\":\"vitals_alert\",\"metric\":\"l6e_score\",\"value\":" + to_string(alert_l6e) + ",\"severity\":\"high\",\"note\":\"acceleration turbulence < 0.3\"}"
            try { exec("echo '" + ev2 + "' >> " + gb_path) } catch e {}
            last_l6e_alert_ts = ts_now
        }
    }

    prev_level = level

    // ── LOG ROTATION (100 사이클마다 = ~25분 간격) ──
    if cycle % 100 == 0 {
        let log_max = read_jsonl_val(gate_cfg, "log_rotate_max_bytes", 10485760)
        let gb_path = DIR + "/nexus/shared/growth_bus.jsonl"
        if file_exists(gb_path) {
            let gb_size_s = try { exec("wc -c < '" + gb_path + "' 2>/dev/null").trim() } catch e { "0" }
            let mut gb_size = 0
            try { gb_size = to_int(to_float(gb_size_s)) } catch e {}
            if gb_size > log_max {
                // 최근 50%만 유지
                let total_lines_s = try { exec("wc -l < '" + gb_path + "' 2>/dev/null").trim() } catch e { "0" }
                let mut total_lines = 0
                try { total_lines = to_int(to_float(total_lines_s)) } catch e {}
                let keep = total_lines / 2
                if keep > 1000 {
                    try { exec("cp '" + gb_path + "' '" + gb_path + ".bak' && tail -" + to_string(keep) + " '" + gb_path + ".bak' > '" + gb_path + "' && rm '" + gb_path + ".bak'") } catch e {}
                }
            }
        }

        // dispatch.log rotation
        let dl_path = DIR + "/forge/dispatch.log"
        if file_exists(dl_path) {
            let dl_size_s = try { exec("wc -c < '" + dl_path + "' 2>/dev/null").trim() } catch e { "0" }
            let mut dl_size = 0
            try { dl_size = to_int(to_float(dl_size_s)) } catch e {}
            if dl_size > log_max {
                let dl_lines_s = try { exec("wc -l < '" + dl_path + "' 2>/dev/null").trim() } catch e { "0" }
                let mut dl_lines = 0
                try { dl_lines = to_int(to_float(dl_lines_s)) } catch e {}
                let dl_keep = dl_lines / 2
                if dl_keep > 100 {
                    try { exec("cp '" + dl_path + "' '" + dl_path + ".bak' && tail -" + to_string(dl_keep) + " '" + dl_path + ".bak' > '" + dl_path + "' && rm '" + dl_path + ".bak'") } catch e {}
                }
            }
        }

        // forge/harvest.log rotation
        let hl_path = DIR + "/forge/harvest.log"
        if file_exists(hl_path) {
            let hl_size_s = try { exec("wc -c < '" + hl_path + "' 2>/dev/null").trim() } catch e { "0" }
            let mut hl_size = 0
            try { hl_size = to_int(to_float(hl_size_s)) } catch e {}
            if hl_size > log_max {
                let hl_lines_s = try { exec("wc -l < '" + hl_path + "' 2>/dev/null").trim() } catch e { "0" }
                let mut hl_lines = 0
                try { hl_lines = to_int(to_float(hl_lines_s)) } catch e {}
                let hl_keep = hl_lines / 2
                if hl_keep > 100 {
                    try { exec("cp '" + hl_path + "' '" + hl_path + ".bak' && tail -" + to_string(hl_keep) + " '" + hl_path + ".bak' > '" + hl_path + "' && rm '" + hl_path + ".bak'") } catch e {}
                }
            }
        }
    }

    // ── ADAPTIVE SLEEP ── (level 기반 스캔 주기 조절)
    let scan_ok_sec = read_jsonl_val(gate_cfg, "scan_ok_sec", 15)
    let scan_warn_sec = read_jsonl_val(gate_cfg, "scan_warn_sec", 5)
    let scan_critical_sec = read_jsonl_val(gate_cfg, "scan_critical_sec", 3)
    let mut sleep_sec = 5
    if level == "ok" { sleep_sec = scan_ok_sec }
    if level == "warn" { sleep_sec = scan_warn_sec }
    if level == "critical" || level == "danger" { sleep_sec = scan_critical_sec }
    if ONCE_MODE { return }
    try { exec("sleep " + to_string(sleep_sec)) } catch e {}
}
