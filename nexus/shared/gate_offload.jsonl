{"type":"pattern","match":"*.hexa","cpu_threshold":30,"desc":"hexa 프로세스 CPU 30%+ → Ubuntu 오프로드"}
{"type":"pattern","match":"cargo *|rustc *|cc *|gcc *|g++ *|clang *|clang++ *|ld *|ar *","cpu_threshold":30,"desc":"Rust/C/C++ 빌드 전체 CPU 30%+ → Ubuntu 오프로드"}
{"type":"pattern","match":"make *|cmake *|ninja *|meson *","cpu_threshold":30,"desc":"빌드 시스템 CPU 30%+ → Ubuntu 오프로드"}
{"type":"pattern","match":"python3 *|python *|pip *","cpu_threshold":30,"desc":"Python 프로세스 CPU 30%+ → Ubuntu 오프로드"}
{"type":"pattern","match":"bash *|sh *|zsh *","cpu_threshold":30,"desc":"Shell 스크립트 CPU 30%+ → Ubuntu 오프로드"}
{"type":"pattern","match":"node *|npm *|npx *|tsc *|esbuild *|vite *|webpack *","cpu_threshold":30,"desc":"Node/JS 빌드 CPU 30%+ → Ubuntu 오프로드"}
{"type":"pattern","match":"swift *|swiftc *|xcodebuild *","cpu_threshold":30,"desc":"Swift 빌드 CPU 30%+ → Ubuntu 오프로드"}
{"type":"pattern","match":"go build *|go test *|go run *","cpu_threshold":30,"desc":"Go 빌드 CPU 30%+ → Ubuntu 오프로드"}
{"type":"exclude","match":"cl.hexa","reason":"cl 런처 Mac 전용 (Prime Directive 보호)"}
{"type":"exclude","match":"sampler.hexa","reason":"로컬 모니터링 전용"}
{"type":"exclude","match":"menubar.js","reason":"Mac UI 전용"}
{"type":"exclude","match":"gate_daemon.hexa","reason":"Ubuntu 측 데몬"}
{"type":"exclude","match":"iTerm2","reason":"Mac 터미널 앱"}
{"type":"exclude","match":"Safari","reason":"Mac 브라우저"}
{"type":"exclude","match":"Finder","reason":"Mac Finder"}
{"type":"exclude","match":"claude","reason":"Claude Code Mac 전용"}
{"type":"exclude","match":"WindowServer","reason":"macOS 시스템 프로세스"}
{"type":"exclude","match":"kernel_task","reason":"macOS 커널"}
{"type":"exclude","match":"ubu_monitor","reason":"모니터링 자체는 Mac 실행"}
{"type":"exclude","match":"hook.hexa","reason":"Claude Code hook — Mac 전용 즉시 실행"}
{"type":"config","key":"detect_cmd","value":"ps axo pid,pcpu,comm | awk '$2>=30'","desc":"Mac CPU 30%+ 프로세스 전체 탐지"}
{"type":"config","key":"max_concurrent_ubu","value":"10","desc":"Ubuntu 동시 오프로드 상한"}
