#!/bin/bash
# nexus/shared/bin/hexa — 중앙 자원 가드 래퍼
# 골화 2026-04-10: Mac 자원 사용 금지 중앙 집행
# 외부 폴더 의존 제거: 모든 경로는 프로젝트 내부 또는 gate_config.jsonl 참조

AG_HOME="${AIRGENOME_HOME:-$HOME/Dev/airgenome}"
CFG="$AG_HOME/nexus/shared/gate_config.jsonl"
LOCAL_HEXA="$AG_HOME/nexus/shared/bin/hexa.real"
[ ! -x "$LOCAL_HEXA" ] && LOCAL_HEXA="$HOME/Dev/hexa-lang/hexa"

# ── 외부 프로젝트 pass-through ──
# 첫 .hexa 인자가 $AG_HOME 외부에 있으면 게이트 전체 우회 (직접 LOCAL_HEXA exec).
# 이유: 이 wrapper 는 ~/.hx/bin/hexa 로 단일화돼서 글로벌 hexa 호출을 받음 →
#       nexus 같은 타프로젝트 .hexa 까지 airgenome gate 가 잘못 적용되는 것 방지.
# 메시지는 stderr 로 명시 출력하여 silent 변화 방지.
for _ag_arg in "$@"; do
    case "$_ag_arg" in
        *.hexa)
            _ag_dir=$(cd "$(dirname "$_ag_arg")" 2>/dev/null && pwd)
            if [ -n "$_ag_dir" ]; then
                _ag_abs="$_ag_dir/$(basename "$_ag_arg")"
                case "$_ag_abs" in
                    "$AG_HOME"/*) ;;  # 내부 → 게이트 진입
                    *)
                        echo "[GATE PASS-THROUGH] 외부 프로젝트: $_ag_abs — airgenome gate 미적용" >&2
                        exec "$LOCAL_HEXA" "$@"
                        ;;
                esac
            fi
            break  # 첫 .hexa 만 판정
            ;;
    esac
done

# ── L0 Guard — airgenome L0 파일 존재 검증 ──
_l0_skip=0
for _la in "$@"; do
    case "$_la" in *l0_guard.hexa*|*sync_codeowners.hexa*) _l0_skip=1; break;; esac
done
if [ "$_l0_skip" -eq 0 ] && [ -f "$HOME/Dev/nexus/shared/lockdown/lockdown.json" ]; then
    _l0_fail=$(/usr/bin/python3 -c "
import json,os
D=json.load(open(os.environ['HOME']+'/Dev/nexus/shared/lockdown/lockdown.json'))
ag=os.environ.get('AIRGENOME_HOME', os.environ['HOME']+'/Dev/airgenome')
for e in D.get('projects',{}).get('airgenome',{}).get('L0',[]):
    if not os.path.exists(ag+'/'+e['path']): print(e['path'])
" 2>/dev/null)
    if [ -n "$_l0_fail" ]; then
        echo "[L0 GUARD] L0 파일 누락:" >&2
        echo "$_l0_fail" | while read -r _p; do echo "  FAIL  $_p" >&2; done
        echo "[L0 GUARD] hexa l0_guard.hexa sync 실행 필요" >&2
        exit 1
    fi
fi

# gate_config에서 원격 설정 읽기 (외부 경로 하드코딩 제거)
_cfg() { grep "\"$1\"" "$CFG" 2>/dev/null | sed 's/.*"value": "//;s/".*//'; }
UBU_SSH=$(_cfg ssh_alias); [ -z "$UBU_SSH" ] && UBU_SSH="ubu"
UBU_DIR=$(_cfg remote_dir); [ -z "$UBU_DIR" ] && UBU_DIR="/home/aiden/airgenome"
UBU_HEXA=$(_cfg ubu_hexa_bin); [ -z "$UBU_HEXA" ] && UBU_HEXA="/home/aiden/Dev/hexa-lang/target/release/hexa"
HTZ_SSH=$(_cfg htz_ssh_alias); [ -z "$HTZ_SSH" ] && HTZ_SSH="hetzner"
HTZ_HEXA=$(_cfg htz_hexa_bin); [ -z "$HTZ_HEXA" ] && HTZ_HEXA="/root/Dev/hexa-lang/target/release/hexa"
HTZ_DIR=$(_cfg htz_nexus_dir);  [ -z "$HTZ_DIR" ]  && HTZ_DIR="/root/Dev/nexus"

# 타겟 강제 — HEXA_TARGET=ubu|hetzner|auto (기본 auto)
HEXA_TARGET="${HEXA_TARGET:-auto}"

# ── Mac 전용 스크립트 (절대 원격 라우팅 금지) ──
MAC_ONLY="cl.hexa|sampler.hexa|menubar.hexa|menubar.js|ag3_loop.hexa|ag3_guard.hexa|ag3_menubar_feed.hexa|auto_dispatch.hexa|session_snapshot.hexa|session_resume.hexa|genome_harvest.hexa|growth_bus_sync.hexa|usage.hexa|resource_coordinator.hexa|hook.hexa|launcher_cap.hexa|infra_probe.hexa|sync_remote.hexa|claude_profile_dedup.hexa|mac_compute_zero.hexa|load_balancer.hexa|per_source_genome.hexa|per_source_sigdiff.hexa|resource_ceiling.hexa|monitor_test.hexa|run_all.hexa|detector_loop.hexa|task_dispatcher.hexa|blast_htz.hexa|blast_ubu.hexa|blast_common.hexa"

# 인자에서 Mac 전용 스크립트 감지
for a in "$@"; do
    _bn=$(basename "$a" 2>/dev/null)
    if echo "$_bn" | grep -qE "$MAC_ONLY"; then
        exec "$LOCAL_HEXA" "$@"
    fi
done

# mac_compute_allowed 플래그
mac_allowed=$(_cfg mac_compute_allowed)
[ -z "$mac_allowed" ] && mac_allowed="false"

if [ "$mac_allowed" = "true" ]; then
    exec "$LOCAL_HEXA" "$@"
fi

# ── Mac 연산 금지 → 원격 라우팅 ──

# sentinel 250 = SSH 도달 불가 (remote command의 실제 rc 와 구분)
_route_ubu() {
    "$(dirname "$0")/ssh_gate" ubu "true" 2>/dev/null || return 250
    RARGS=()
    ssh "$UBU_SSH" "mkdir -p $UBU_DIR/gate_files" 2>/dev/null
    for a in "$@"; do
        if [ -f "$a" ]; then
            scp -q "$a" "$UBU_SSH:$UBU_DIR/gate_files/" 2>/dev/null
            RARGS+=("$UBU_DIR/gate_files/$(basename "$a")")
        else
            RARGS+=("$a")
        fi
    done
    local _esc; _esc=$(printf '%q ' "${RARGS[@]}")
    "$(dirname "$0")/ssh_gate" ubu "cd $UBU_DIR && $UBU_HEXA $_esc" 2>&1
    return $?
}

_route_htz() {
    "$(dirname "$0")/ssh_gate" htz "true" 2>/dev/null || return 250
    RARGS=()
    ssh "$HTZ_SSH" "mkdir -p $HTZ_DIR/gate_files" 2>/dev/null
    local NEXUS_LOCAL="$HOME/Dev/nexus"
    for a in "$@"; do
        if [ -f "$a" ]; then
            # nexus-repo 파일이면 hetzner 의 nexus 사본을 그대로 사용 (scp 생략 → import 깨짐 방지)
            local rp; rp=$(cd "$(dirname "$a")" 2>/dev/null && pwd)/$(basename "$a")
            if [[ "$rp" == "$NEXUS_LOCAL"/* ]]; then
                RARGS+=("$HTZ_DIR/${rp#$NEXUS_LOCAL/}")
            else
                scp -q "$a" "$HTZ_SSH:$HTZ_DIR/gate_files/" 2>/dev/null
                RARGS+=("$HTZ_DIR/gate_files/$(basename "$a")")
            fi
        else
            RARGS+=("$a")
        fi
    done
    local _esc; _esc=$(printf '%q ' "${RARGS[@]}")
    "$(dirname "$0")/ssh_gate" htz "cd $HTZ_DIR && $HTZ_HEXA $_esc" 2>&1
    return $?
}

# 타겟 강제
case "$HEXA_TARGET" in
    ubu)
        _route_ubu "$@"; rc=$?
        [ $rc -eq 250 ] && { echo "[GUARD] HEXA_TARGET=ubu but ubu unreachable" >&2; exit 1; }
        exit $rc
        ;;
    hetzner|htz)
        _route_htz "$@"; rc=$?
        [ $rc -eq 250 ] && { echo "[GUARD] HEXA_TARGET=hetzner but hetzner unreachable" >&2; exit 1; }
        exit $rc
        ;;
    auto|*)
        _route_ubu "$@"; rc=$?
        [ $rc -ne 250 ] && exit $rc   # ubu 실행됨 (성공이든 실패든 결과 그대로)
        _route_htz "$@"; rc=$?
        [ $rc -ne 250 ] && exit $rc   # hetzner 폴백 실행
        echo "[GUARD] Mac 연산 금지 + ubu/hetzner 모두 unreachable — 실행 거부" >&2
        exit 1
        ;;
esac
