// airgenome/modules/auto_dispatch.hexa — OFFLOAD_O1 자동 디스패치 집행기
//
// Mac CPU 과부하 + Ubuntu 여유 시 오프로드 후보를 탐지하고 강제 throttle.
// 골화 2026-04-10: 권장→집행 승격. 오프로드 대상은 taskpolicy -b 즉시 적용.
//
// 설정 (nexus/shared/gate_config.jsonl):
//   offload_cpu_threshold  — Mac CPU% 임계치 (default 80)
//   offload_ubu_max_cpu    — Ubuntu CPU% 상한 (default 70)
//   offload_htz_max_cpu    — Hetzner CPU% 상한 (default 70)
//   offload_patterns       — 오프로드 대상 패턴 (comma-sep, default "hexa,python3,node,cargo,gcc,clang")
//   offload_scan_interval  — watch 모드 폴링 초 (default 10)
//   offload_top_n          — CPU hog 상위 N개 (default 3)
//
// Usage:
//   hexa modules/auto_dispatch.hexa check              — 1회 분석
//   hexa modules/auto_dispatch.hexa watch              — 폴링 루프
//   hexa modules/auto_dispatch.hexa check <state_path> — 커스텀 상태 경로
//
// 출력: JSON (stdout) + forge/dispatch.log (JSONL append)
//
// ── 환경변수 & 인자 ──────────────────────────────────────────────────
// HOME                : 사용자 홈 디렉토리 (설정/로그 기본 경로)
// TMPDIR              : 임시 디렉토리 (default /tmp)
//                     state_path 기본값: ${TMPDIR}/airgenome-state.json
// argv[2] (command)   : "check" (1회) | "watch" (수동 디버그 전용)
// argv[3] (state_path): 커스텀 상태 JSON 경로 (선택)
// ─────────────────────────────────────────────────────────────────────

let VERSION = "0.2.0"
let HOME = env("HOME")
let DIR = HOME + "/Dev/airgenome"
let CONFIG_PATH = DIR + "/nexus/shared/gate_config.jsonl"
let DISPATCH_LOG = DIR + "/forge/dispatch.log"
let GROWTH_BUS = HOME + "/Dev/nexus/shared/growth_bus.jsonl"
let INFRA_STATE_PATH = HOME + "/Dev/nexus/shared/infra_state.json"

// ── SYSTEM EXCLUDE (PID < 200 또는 시스템 데몬) ──────────────────────────
// Prime Directive: 시스템 프로세스는 관찰 대상에서 제외
let SYS_EXCLUDE = "kernel_task|WindowServer|launchd|loginwindow|Finder|Dock|opendirectoryd|mds_stores|hidd|coreservicesd"
// 본질적으로 mac 로컬 전용 (GUI/CLI 본체) — 오프로드 불가능 카테고리
// hog 가 이 패턴에 매칭되면 "patterns 에 추가하면 해결" 이라는 잘못된 인상을 안 주도록 별도 분류
// 2026-04-11: rsync/git 추가 — 파일 동기화/로컬 repo 작업은 원격 이관 불가 (unknown → non_off 로 강등)
let NON_OFFLOADABLE = "claude|iTerm2|Cursor|Code Helper|Electron|Chrome|Safari|Firefox|Slack|Discord|Notion|Spotify|zoom|Music|Photos|rsync|git|Terminal|LoginItems"

// ═══════════════════════════════════════════════════════════════════════
//  Config loader (ag3_loop.hexa 동일 패턴)
// ═══════════════════════════════════════════════════════════════════════

fn load_cfg(key: str, fallback: str) -> str {
    if file_exists(CONFIG_PATH) == false { return fallback }
    let content = read_file(CONFIG_PATH)
    let lines = content.split("\n")
    let i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if len(line) > 2 {
            let parsed = json_parse(line)
            if parsed["key"] == key { return parsed["value"] }
        }
        i = i + 1
    }
    return fallback
}

fn load_cfg_int(key: str, fallback: int) -> int {
    let v = load_cfg(key, to_string(fallback))
    try { return to_int(to_float(v)) } catch e { return fallback }
}

// ═══════════════════════════════════════════════════════════════════════
//  Read sampler state JSON (Mac vitals + Ubuntu status)
// ═══════════════════════════════════════════════════════════════════════

fn read_json_int(raw: str, key: str, fallback: int) -> int {
    if raw.contains("\"" + key + "\"") == false { return fallback }
    let after = raw.split("\"" + key + "\"")[1]
    let val_s = after.split(":")[1].split(",")[0].split("}")[0].trim().replace("\"", "")
    try { return to_int(to_float(val_s)) } catch e { return fallback }
}

fn read_json_str(raw: str, key: str, fallback: str) -> str {
    if raw.contains("\"" + key + "\"") == false { return fallback }
    let after = raw.split("\"" + key + "\"")[1]
    // "key":"value" — after = :"value",... → split(":") → ["", "\"value\",..."]
    // 두번째 조각에서 따옴표 사이 값 추출
    let colon_parts = after.split(":")
    if colon_parts.len() < 2 { return fallback }
    let val_raw = colon_parts[1].split(",")[0].split("}")[0].trim()
    // 따옴표 제거
    return val_raw.replace("\"", "")
}

// ═══════════════════════════════════════════════════════════════════════
//  Top CPU hog 목록 (시스템 프로세스 제외)
// ═══════════════════════════════════════════════════════════════════════

fn get_top_hogs(top_n: int) -> str {
    // ps 결과: pid cpu comm — PID>100, 시스템 제외, CPU 내림차순 상위 N
    let cmd = "ps -eo pid=,%cpu=,comm= | awk '$1>100 && $2>0.5 {c=$3; if(c~/" + SYS_EXCLUDE + "/) next; printf \"%s %.1f %s\\n\",$1,$2,$3}' | sort -rnk2 | head -" + to_string(top_n)
    return exec(cmd).trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  Pattern matcher: comm 이 offload_patterns 중 하나를 포함하는지
// ═══════════════════════════════════════════════════════════════════════

fn matches_pattern(comm: str, patterns: str) -> bool {
    let pats = patterns.split(",")
    let i = 0
    while i < pats.len() {
        let p = pats[i].trim()
        if len(p) > 0 && comm.contains(p) { return true }
        i = i + 1
    }
    return false
}

// NON_OFFLOADABLE 는 pipe-separated regex alternation → split("|") 로 처리
fn is_non_offloadable(comm: str) -> bool {
    let pats = NON_OFFLOADABLE.split("|")
    let i = 0
    while i < pats.len() {
        let p = pats[i].trim()
        if len(p) > 0 && comm.contains(p) { return true }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════════
//  Timestamp
// ═══════════════════════════════════════════════════════════════════════

fn ts_iso() -> str {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  htz blowup 자동 발화 (cooldown throttle — 2026-04-11)
//
//  기존: offload_htz 조건 충족 시 JSON status 만 반환 (실제 집행 없음)
//  추가: htz_dispatch.hexa blowup airgenome 을 nohup 으로 detach 실행,
//        /tmp/ag_htz_fire.lock 에 epoch 기록하여 cooldown_s 내 재발화 방지.
//  반환: "fired(pid=N)" | "throttled(Ns)" | "fire_err:..."
// ═══════════════════════════════════════════════════════════════════════

fn fire_htz_blowup(now_s: str) -> str {
    let lock_file = "/tmp/ag_htz_fire.lock"
    let cooldown_s = load_cfg_int("offload_htz_cooldown_s", 300)
    let mut cooldown_left = 0
    if file_exists(lock_file) {
        let mut lock_ts = "0"
        try { lock_ts = read_file(lock_file).trim() } catch e {}
        try {
            let diff = to_int(to_float(now_s)) - to_int(to_float(lock_ts))
            if diff < cooldown_s { cooldown_left = cooldown_s - diff }
        } catch e {}
    }
    if cooldown_left > 0 {
        return "throttled(" + to_string(cooldown_left) + "s)"
    }
    // 2026-04-11: RAM 스택킹 방지 가드 — 원격에 이미 blowup 돌고 있으면 skip.
    // 측정: blowup 1 instance = ~19GB RSS. cooldown<runtime 면 중복 누적 → OOM.
    let probe = try { exec("ssh -o ConnectTimeout=3 -o BatchMode=yes hetzner 'pgrep -c -f blowup\\.hexa' 2>/dev/null").trim() } catch e { "0" }
    let mut running_n = 0
    try { running_n = to_int(to_float(probe)) } catch e {}
    if running_n > 0 {
        return "already_running(" + to_string(running_n) + ")"
    }
    try { write_file(lock_file, now_s) } catch e {}
    let hexa_bin = DIR + "/nexus/shared/bin/hexa"
    let dispatch_path = DIR + "/modules/htz_dispatch.hexa"
    let blowup_domain = load_cfg("offload_htz_blowup_domain", "airgenome")
    let blowup_depth = load_cfg("offload_htz_blowup_depth", "3")
    let fire_cmd = hexa_bin + " " + dispatch_path + " blowup " + blowup_domain + " " + blowup_depth + " >/tmp/ag_htz_fire.out 2>&1 & echo $!"
    let mut pid = "0"
    try { pid = exec(fire_cmd).trim() } catch e { return "fire_err" }
    return "fired(pid=" + pid + ")"
}

// ═══════════════════════════════════════════════════════════════════════
//  Proactive ubu idle check + fire (B2 — 2026-04-11)
//
//  ubu GPU util < threshold 시 blowup 을 ubu 로 직접 SSH fire.
//  ubu CPU baseline 이 64% 정도 (ag3-loop/gate-mesh/harvest/gate daemon) 라
//  CPU 로는 유휴 판정 불가 → GPU util 기준 (RTX 5070 이 진짜 놀 때만 fire).
//  blowup 은 CPU 작업이라 GPU util 을 늘리진 못하지만, ubu 전체 busy 는 확보.
// ═══════════════════════════════════════════════════════════════════════

fn fire_ubu_blowup(now_s: str) -> str {
    let lock_file = "/tmp/ag_ubu_fire.lock"
    let cooldown_s = load_cfg_int("offload_ubu_cooldown_s", 300)
    let mut cooldown_left = 0
    if file_exists(lock_file) {
        let mut lock_ts = "0"
        try { lock_ts = read_file(lock_file).trim() } catch e {}
        try {
            let diff = to_int(to_float(now_s)) - to_int(to_float(lock_ts))
            if diff < cooldown_s { cooldown_left = cooldown_s - diff }
        } catch e {}
    }
    if cooldown_left > 0 {
        return "throttled(" + to_string(cooldown_left) + "s)"
    }
    // 2026-04-11: RAM 스택킹 방지 가드 — 이미 돌고 있으면 skip
    let ubu_alias_probe = load_cfg("ssh_alias", "ubu")
    let probe = try { exec("ssh -o ConnectTimeout=3 -o BatchMode=yes " + ubu_alias_probe + " 'pgrep -c -f blowup\\.hexa' 2>/dev/null").trim() } catch e { "0" }
    let mut running_n = 0
    try { running_n = to_int(to_float(probe)) } catch e {}
    if running_n > 0 {
        return "already_running(" + to_string(running_n) + ")"
    }
    try { write_file(lock_file, now_s) } catch e {}
    let ubu_alias = load_cfg("ssh_alias", "ubu")
    let ubu_hexa = load_cfg("ubu_hexa_bin", "~/Dev/hexa-lang/target/release/hexa")
    let ubu_blowup = load_cfg("ubu_blowup_script", "~/Dev/nexus/mk2_hexa/native/blowup.hexa")
    let blowup_domain = load_cfg("offload_ubu_blowup_domain", "airgenome")
    let blowup_depth = load_cfg("offload_ubu_blowup_depth", "3")
    // 2026-04-11: prlimit + timeout 로 리소스 격리. ubu 30GB RAM 엄격.
    let ubu_mem_bytes = load_cfg("ubu_blowup_mem_bytes", "16106127360")  // 15GB
    let ubu_timeout_s = load_cfg("ubu_blowup_timeout_s", "90")
    // SSH 원격 nohup detach — 로컬은 즉시 리턴, ubu 에서 백그라운드 실행
    let remote_cmd = "nohup timeout " + ubu_timeout_s + " prlimit --as=" + ubu_mem_bytes + " -- " + ubu_hexa + " " + ubu_blowup + " " + blowup_domain + " " + blowup_depth + " --no-graph >/tmp/ag_ubu_blowup.out 2>&1 & disown"
    let ssh_cmd = "ssh -o ConnectTimeout=5 -o BatchMode=yes " + ubu_alias + " '" + remote_cmd + "' >/tmp/ag_ubu_fire.out 2>&1 & echo $!"
    let mut pid = "0"
    try { pid = exec(ssh_cmd).trim() } catch e { return "fire_err" }
    return "fired(pid=" + pid + ")"
}

fn proactive_ubu_check(ts: str, epoch: str) -> str {
    // 0. Toggle check
    let enabled = load_cfg("offload_ubu_enabled", "true")
    if enabled != "true" { return "disabled" }
    // 1. Fast cooldown check
    let lock_file = "/tmp/ag_ubu_fire.lock"
    let cooldown_s = load_cfg_int("offload_ubu_cooldown_s", 300)
    if file_exists(lock_file) {
        let mut lock_ts = "0"
        try { lock_ts = read_file(lock_file).trim() } catch e {}
        let mut diff_i = 9999
        try { diff_i = to_int(to_float(epoch)) - to_int(to_float(lock_ts)) } catch e {}
        if diff_i < cooldown_s {
            return "cooldown(" + to_string(cooldown_s - diff_i) + "s)"
        }
    }
    // 2. Probe ubu GPU util via ag3_status.json (fresh, 5s 주기)
    let ag3_path = env("HOME") + "/.airgenome/ag3_status.json"
    let mut ubu_available = false
    let mut ubu_gpu_util = 100
    if file_exists(ag3_path) {
        let uup = try { exec("python3 -c \"import json; d=json.load(open('" + ag3_path + "')); print(1 if d.get('ubu_up') else 0)\" 2>/dev/null").trim() } catch e { "0" }
        if uup == "1" {
            ubu_available = true
            let gu = try { exec("python3 -c \"import json; d=json.load(open('" + ag3_path + "')); print(d.get('gpu_util', 100))\" 2>/dev/null").trim() } catch e { "100" }
            try { ubu_gpu_util = to_int(to_float(gu)) } catch e {}
        }
    }
    if ubu_available == false { return "ubu_unavailable" }
    let idle_gpu = load_cfg_int("offload_ubu_idle_gpu_threshold", 5)
    if ubu_gpu_util >= idle_gpu { return "not_idle(gpu=" + to_string(ubu_gpu_util) + "%)" }
    return fire_ubu_blowup(epoch)
}

// ═══════════════════════════════════════════════════════════════════════
//  Proactive htz idle check (B1 — 2026-04-11)
//
//  기존 slice A 는 "ubu busy → htz fallback" 만 발동. 둘 다 idle 이면 영원히 논다.
//  이 함수는 mac/ubu 상태와 무관하게 htz 자체 유휴도 체크 → 일감 투입.
//
//  동작: cooldown fast-path 먼저 → infra_state.json 읽어 htz_cpu_pct 환산 →
//        idle_threshold 이하 면 fire_htz_blowup 호출.
//  cooldown 체크는 fire_htz_blowup 내부에도 있어 이중 안전망.
// ═══════════════════════════════════════════════════════════════════════

fn proactive_htz_check(ts: str, epoch: str) -> str {
    // ── 0. Toggle check (사용자 수동 on/off) ──
    let enabled = load_cfg("offload_htz_enabled", "true")
    if enabled != "true" { return "disabled" }
    // ── 1. Fast cooldown check (Python3 호출 회피) ──
    let lock_file = "/tmp/ag_htz_fire.lock"
    let cooldown_s = load_cfg_int("offload_htz_cooldown_s", 300)
    if file_exists(lock_file) {
        let mut lock_ts = "0"
        try { lock_ts = read_file(lock_file).trim() } catch e {}
        let mut diff_i = 9999
        try { diff_i = to_int(to_float(epoch)) - to_int(to_float(lock_ts)) } catch e {}
        if diff_i < cooldown_s {
            return "cooldown(" + to_string(cooldown_s - diff_i) + "s)"
        }
    }

    // ── 2. Probe htz idle via infra_state.json (10min stale OK — rough threshold) ──
    let htz_idle_threshold = load_cfg_int("offload_htz_idle_threshold", 30)
    let mut htz_cpu_pct = 100
    let mut htz_status = "unknown"
    if file_exists(INFRA_STATE_PATH) {
        let hst = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['htz']['status'])\" 2>/dev/null").trim() } catch e { "" }
        if len(hst) > 0 { htz_status = hst }
        let hload = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['htz'].get('load','100'))\" 2>/dev/null").trim() } catch e { "100" }
        let hthr = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['htz'].get('cpu_threads',1))\" 2>/dev/null").trim() } catch e { "1" }
        try {
            let hload_f = to_float(hload)
            let hthr_f = to_float(hthr)
            if hthr_f > 0.0 { htz_cpu_pct = to_int(hload_f * 100.0 / hthr_f) }
        } catch e {}
    }
    if htz_status != "active" { return "unavailable(" + htz_status + ")" }
    if htz_cpu_pct >= htz_idle_threshold { return "not_idle(" + to_string(htz_cpu_pct) + "%)" }
    // htz 유휴 확인 + cooldown 통과 → fire (내부에서 한번 더 cooldown write)
    return fire_htz_blowup(epoch)
}

fn ts_epoch() -> str {
    return exec("date +%s").trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  Core: 1회 분석
// ═══════════════════════════════════════════════════════════════════════

fn check_once(state_path: str) -> str {
    let ts = ts_iso()
    let epoch = ts_epoch()

    // ── 설정 로드 ──
    let cpu_thresh = load_cfg_int("offload_cpu_threshold", 80)
    let ubu_max    = load_cfg_int("offload_ubu_max_cpu", 70)
    let patterns   = load_cfg("offload_patterns", "hexa,python3,node,cargo,gcc,clang")
    let top_n      = load_cfg_int("offload_top_n", 3)

    // ── B1: Proactive htz idle fire (모든 결과 로그 — return 응답 2026-04-11) ──
    let htz_proactive = proactive_htz_check(ts, epoch)
    let mut htz_type = "HTZ_PROACTIVE_SKIP"
    if htz_proactive.contains("fired") { htz_type = "HTZ_PROACTIVE_FIRE" }
    let htz_log = "{\"ts\":\"" + ts + "\",\"epoch\":" + epoch + ",\"type\":\"" + htz_type + "\",\"action\":\"" + htz_proactive + "\"}"
    try { append_file(DISPATCH_LOG, htz_log + "\n") } catch e {}

    // ── B2: Proactive ubu idle fire (모든 결과 로그) ──
    let ubu_proactive = proactive_ubu_check(ts, epoch)
    let mut ubu_type = "UBU_PROACTIVE_SKIP"
    if ubu_proactive.contains("fired") { ubu_type = "UBU_PROACTIVE_FIRE" }
    let ubu_log = "{\"ts\":\"" + ts + "\",\"epoch\":" + epoch + ",\"type\":\"" + ubu_type + "\",\"action\":\"" + ubu_proactive + "\"}"
    try { append_file(DISPATCH_LOG, ubu_log + "\n") } catch e {}

    // ── 상태 읽기 ──
    if file_exists(state_path) == false {
        return "{\"ts\":\"" + ts + "\",\"status\":\"no_state\",\"htz_proactive\":\"" + htz_proactive + "\",\"reason\":\"state file not found: " + state_path + "\"}"
    }
    let raw = read_file(state_path).trim()
    if len(raw) < 10 {
        return "{\"ts\":\"" + ts + "\",\"status\":\"no_state\",\"htz_proactive\":\"" + htz_proactive + "\",\"reason\":\"state file empty\"}"
    }

    let mac_cpu = read_json_int(raw, "cpu", 0)
    let gate    = read_json_str(raw, "gate", "offline")
    let ubu_cpu = read_json_int(raw, "ubu_cpu", 100)

    // ── 조건 평가 ──
    if mac_cpu < cpu_thresh {
        return "{\"ts\":\"" + ts + "\",\"status\":\"idle\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"threshold\":" + to_string(cpu_thresh) + ",\"htz_proactive\":\"" + htz_proactive + "\",\"reason\":\"mac cpu below threshold\"}"
    }
    if gate != "online" {
        return "{\"ts\":\"" + ts + "\",\"status\":\"gate_offline\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"gate\":\"" + gate + "\",\"reason\":\"ubuntu gate not online\"}"
    }
    if ubu_cpu > ubu_max {
        // ── htz fallback: ubu busy → Hetzner 확인 ──
        let htz_max = load_cfg_int("offload_htz_max_cpu", 70)
        let mut htz_cpu = 100
        let mut htz_status = "unknown"

        // infra_state.json 에서 htz 상태 읽기 (nested JSON → python3, vast 패턴 재사용)
        // 2026-04-11: 기존 read_json_str(raw,"htz_status") 는 top-level 키만 찾아 실패했고,
        // SSH probe awk 수식도 "$1*100/($1+$4)" 로 0 만 출력하던 이중 고장 수정.
        if file_exists(INFRA_STATE_PATH) {
            let hst = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['htz']['status'])\" 2>/dev/null").trim() } catch e { "" }
            if len(hst) > 0 { htz_status = hst }
            // load/threads → cpu_pct 환산 (htz.load 는 1분 load average, cpu_threads 로 정규화)
            let hload = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['htz'].get('load','100'))\" 2>/dev/null").trim() } catch e { "100" }
            let hthr = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['htz'].get('cpu_threads',1))\" 2>/dev/null").trim() } catch e { "1" }
            try {
                let hload_f = to_float(hload)
                let hthr_f = to_float(hthr)
                if hthr_f > 0.0 {
                    htz_cpu = to_int(hload_f * 100.0 / hthr_f)
                }
            } catch e {}
        }

        // infra_state 없거나 stale → SSH probe fallback (정정: /proc/stat NR==1 올바른 수식)
        if htz_status == "unknown" {
            let probe = exec("ssh -o ConnectTimeout=5 -o BatchMode=yes hetzner \"awk 'NR==1{idle=\\$5; total=\\$2+\\$3+\\$4+\\$5+\\$6+\\$7+\\$8+\\$9; if(total>0) printf \\\"%d\\\", (total-idle)*100/total; else print 100}' /proc/stat 2>/dev/null || echo 100\" 2>/dev/null").trim()
            try {
                htz_cpu = to_int(to_float(probe))
                if htz_cpu >= 0 && htz_cpu <= 100 { htz_status = "active" }
            } catch e {}
        }

        if htz_status == "active" && htz_cpu <= htz_max {
            // 2026-04-11: recommend → enforce 승격. 실제 htz blowup 자동 발화.
            let fire = fire_htz_blowup(epoch)
            let log_entry = "{\"ts\":\"" + ts + "\",\"epoch\":" + epoch + ",\"type\":\"OFFLOAD_HTZ_FIRE\",\"action\":\"" + fire + "\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"htz_cpu\":" + to_string(htz_cpu) + "}"
            try { append_file(DISPATCH_LOG, log_entry + "\n") } catch e {}
            return "{\"ts\":\"" + ts + "\",\"status\":\"offload_htz\",\"host\":\"htz\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"htz_cpu\":" + to_string(htz_cpu) + ",\"fire\":\"" + fire + "\",\"reason\":\"ubu busy, htz available → " + fire + "\"}"
        }

        // ── vast fallback: ubu+htz both busy → Vast.ai 확인 ──
        let mut vast_status = "unknown"
        let mut vast_gpu_util = 100
        let mut vast_cpu_pct = 100
        if file_exists(INFRA_STATE_PATH) {
            let infra_raw2 = read_file(INFRA_STATE_PATH).trim()
            if infra_raw2.contains("\"vast\"") {
                vast_status = read_json_str(infra_raw2, "vast_status", "unknown")
                // infra_state는 중첩 JSON이라 간단 파서로 한계 → awk fallback
                let vgu = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['vast']['gpu_util'])\" 2>/dev/null").trim() } catch e { "100" }
                let vcp = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['vast']['cpu_pct'])\" 2>/dev/null").trim() } catch e { "100" }
                let vst = try { exec("python3 -c \"import json; d=json.load(open('" + INFRA_STATE_PATH + "')); print(d['hosts']['vast']['status'])\" 2>/dev/null").trim() } catch e { "offline" }
                try { vast_gpu_util = to_int(to_float(vgu)) } catch e {}
                try { vast_cpu_pct = to_int(to_float(vcp)) } catch e {}
                vast_status = vst
            }
        }

        if vast_status == "active" && vast_cpu_pct < 70 {
            return "{\"ts\":\"" + ts + "\",\"status\":\"offload_vast\",\"host\":\"vast\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"htz_cpu\":" + to_string(htz_cpu) + ",\"vast_cpu\":" + to_string(vast_cpu_pct) + ",\"vast_gpu\":" + to_string(vast_gpu_util) + ",\"reason\":\"ubu+htz busy, vast available\"}"
        }

        // 전부 불가
        return "{\"ts\":\"" + ts + "\",\"status\":\"all_busy\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"ubu_max\":" + to_string(ubu_max) + ",\"htz_cpu\":" + to_string(htz_cpu) + ",\"htz_status\":\"" + htz_status + "\",\"vast_status\":\"" + vast_status + "\",\"reason\":\"all hosts busy\"}"
    }

    // ── 조건 충족: top N hog 탐색 ──
    let hog_raw = get_top_hogs(top_n)
    if len(hog_raw) == 0 {
        return "{\"ts\":\"" + ts + "\",\"status\":\"no_hogs\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"reason\":\"no significant cpu hogs found\"}"
    }

    let hog_lines = hog_raw.split("\n")
    let mut recs = ""
    let mut rec_count = 0
    let mut non_off = ""        // 본질적으로 오프로드 불가 (GUI/CLI)
    let mut non_off_count = 0
    let mut unknown = ""        // 분류 미상
    let mut unknown_count = 0
    let j = 0
    while j < hog_lines.len() {
        let line = hog_lines[j].trim()
        if len(line) > 0 {
            let parts = line.split(" ")
            if parts.len() >= 3 {
                let pid = parts[0].trim()
                let cpu_s = parts[1].trim()
                let comm = parts[2].trim()
                if matches_pattern(comm, patterns) {
                    // ── 즉시 집행: taskpolicy -b 강제 적용 (CPU 우선도 최하위) ──
                    try { exec("taskpolicy -b -p " + pid) } catch e {}

                    if rec_count > 0 { recs = recs + "," }
                    recs = recs + "{\"pid\":" + pid + ",\"cpu\":" + cpu_s + ",\"comm\":\"" + comm + "\",\"action\":\"taskpolicy -b -p " + pid + " (ENFORCED)\"}"

                    // ── dispatch.log JSONL append ──
                    let log_entry = "{\"ts\":\"" + ts + "\",\"epoch\":" + epoch + ",\"type\":\"OFFLOAD_O1\",\"pid\":" + pid + ",\"cpu\":" + cpu_s + ",\"comm\":\"" + comm + "\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"gate\":\"" + gate + "\",\"action\":\"enforced_taskpolicy_bg\"}"
                    try { append_file(DISPATCH_LOG, log_entry + "\n") } catch e {}

                    rec_count = rec_count + 1
                } else {
                    let entry = "{\"pid\":" + pid + ",\"cpu\":" + cpu_s + ",\"comm\":\"" + comm + "\"}"
                    if is_non_offloadable(comm) {
                        if non_off_count > 0 { non_off = non_off + "," }
                        non_off = non_off + entry
                        non_off_count = non_off_count + 1
                    } else {
                        if unknown_count > 0 { unknown = unknown + "," }
                        unknown = unknown + entry
                        unknown_count = unknown_count + 1
                    }
                }
            }
        }
        j = j + 1
    }

    if rec_count == 0 {
        // 더 정확한 진단: GUI/CLI 가 우세하면 "local_bound", 미상이면 "no_match"
        let status = if non_off_count >= unknown_count { "local_bound" } else { "no_match" }
        let reason = if non_off_count >= unknown_count {
            "top hogs are GUI/CLI processes — fundamentally non-offloadable (claude/iTerm/Cursor/etc). Reduce instances or close idle sessions."
        } else {
            "no hogs matched offload_patterns — consider adding to offload_patterns config"
        }
        return "{\"ts\":\"" + ts + "\",\"status\":\"" + status + "\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"hogs\":" + to_string(hog_lines.len()) + ",\"non_offloadable\":[" + non_off + "],\"unknown\":[" + unknown + "],\"reason\":\"" + reason + "\"}"
    }

    // ── growth_bus 이벤트 (돌파/발견 기록) ──
    let gb_ev = "{\"ts\":\"" + ts + "\",\"source\":\"airgenome/auto_dispatch\",\"event\":\"offload_o1_recommend\",\"domain\":\"airgenome\",\"type\":\"offload\",\"phase\":\"ag3\",\"id\":\"o1_" + epoch + "\",\"value\":" + to_string(rec_count) + ",\"grade\":\"INFO\",\"resource_domain\":\"resource\",\"timestamp\":\"" + ts + "\"}"
    try { append_file(GROWTH_BUS, gb_ev + "\n") } catch e {}

    return "{\"ts\":\"" + ts + "\",\"status\":\"recommend\",\"mac_cpu\":" + to_string(mac_cpu) + ",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"gate\":\"" + gate + "\",\"count\":" + to_string(rec_count) + ",\"recommendations\":[" + recs + "]}"
}

// ═══════════════════════════════════════════════════════════════════════
//  Commands: check / watch
// ═══════════════════════════════════════════════════════════════════════

fn resolve_state_path() -> str {
    let a = args()
    // 커스텀 state_path 지정 가능 (3번째 인수)
    if a.len() >= 4 { return a[3] }
    // 기본: $TMPDIR/airgenome-state.json (sampler 기록 경로)
    let tmpdir = exec("echo ${TMPDIR:-/tmp}").trim()
    return tmpdir + "/airgenome-state.json"
}

fn main() {
    let a = args()
    if a.len() < 3 {
        println("Usage: hexa modules/auto_dispatch.hexa <check|watch> [state_path]")
        println("  check  — one-shot analysis, print JSON")
        println("  watch  — poll every scan_interval, log recommendations")
        exit(1)
    }

    let cmd = a[2]
    let state_path = resolve_state_path()

    // 사이클당 1회 log_rotate (gate_config.log_rotate_path 대상)
    try { exec("hexa '" + DIR + "/modules/log_rotate.hexa' >/dev/null 2>&1") } catch e {}

    if cmd == "check" {
        let result = check_once(state_path)
        println(result)
    } else if cmd == "watch" {
        // 골화 2026-04-10: watch 모드는 영구 실행 → 9~10h 후 81% CPU 폭주.
        // 권장 사용: launchd StartInterval + `check` 명령 (이미 1회 모드).
        // 본 watch 분기는 수동 디버깅 전용으로 유지.
        let interval = load_cfg_int("offload_scan_interval", 10)
        println("[OFFLOAD_O1 v" + VERSION + "] watch mode (manual debug only). interval=" + to_string(interval) + "s state=" + state_path)
        while true {
            let result = check_once(state_path)
            // 추천이 있을 때만 stdout 출력 (노이즈 감소)
            if result.contains("\"recommend\"") {
                println(result)
            }
            sleep(interval)
        }
    } else {
        println("Unknown command: " + cmd + ". Use 'check' or 'watch'.")
        exit(1)
    }
}

main()
