// resource_coordinator.hexa — L3+L4+L5 통합 게이트 엔진 v2
//
// 단일 launchd agent (10s 주기). 입력 → 상태머신 → 5개 per-app 게이트 호출 → 통합 → 적용/dry-run.
//
// 게이트:
//   modules/gates/claude_gate.hexa     — claude 인스턴스 (cwd_dup_idle)
//   modules/gates/telegram_gate.hexa   — Telegram (idle + not in_call)
//   modules/gates/safari_gate.hexa     — Safari WebContent (background tabs)
//   modules/gates/memo_gate.hexa       — Apple Notes (not frontmost)
//   modules/gates/finder_gate.hexa     — Finder helpers (helper busy, never main)
//
// 게이트 인터페이스:
//   stdin: nothing
//   argv:  <state> <hid_idle_sec>
//   env:   AG_COORD_FRONTMOST=<frontmost app name>  (osascript 1번만)
//   stdout: # 코멘트 라인 + JSONL 추천 라인
//
// 안전 장치 5중:
//   1. kill switch:    ~/.airgenome/coordinator.disable 존재 → 즉시 exit 0
//   2. mode 파일:      ~/.airgenome/coordinator.mode = "enabled" 아니면 dry_run
//   3. 사용자 입력:    HIDIdleTime < 60s 면 cool 강제 (작업 중 방해 X)
//   4. 액션 timeout:   적용된 BG 5분 후 자동 해제
//   5. HARD_NEVER:     하드코드 가드 + 게이트별 자체 가드 (이중)

let HOME = env("HOME")
let AG_HOME = HOME + "/Dev/airgenome"
let SESSION_NOW = HOME + "/.airgenome/session_now.json"
let INFRA_STATE = HOME + "/Dev/nexus/shared/infra_state.json"
let STATE_OUT = HOME + "/.airgenome/coordinator_state.json"
let ACTIONS_LOG = HOME + "/.airgenome/coordinator_actions.jsonl"
let DRYRUN_LOG = HOME + "/.airgenome/coordinator_dryrun.jsonl"
let DISABLE = HOME + "/.airgenome/coordinator.disable"
let MODE_FILE = HOME + "/.airgenome/coordinator.mode"

// 게이트 목록 (순서대로 호출, 결과 합침)
let GATES = "claude_gate.hexa,telegram_gate.hexa,safari_gate.hexa,memo_gate.hexa,finder_gate.hexa,mail_gate.hexa,calendar_gate.hexa"

// HARD_NEVER 패턴 (게이트가 잘못 매칭해도 여기서 차단 — 이중 안전망)
let HARD_NEVER = "iTerm2|WindowServer|/Finder.app/Contents/MacOS/Finder|/Dock.app|kernel_task|loginwindow|coreservicesd|hidd|opendirectoryd|launchd$|airgenome|sampler.hexa|resource_coordinator|session_snapshot|com.apple.WebKit.Networking|com.apple.WebKit.GPU"

let ACTION_TTL_SEC = 300
let MAX_ACTIONS_PER_RUN = 30

exec("mkdir -p " + HOME + "/.airgenome")

fn safe_exec(cmd: str) -> str {
    try { return to_string(exec(cmd)).trim() } catch e { return "" }
}

// ── 1. 안전 장치 ──────────────────────────────────────────────────────
if file_exists(DISABLE) {
    println("⬡ coordinator: disabled (kill switch)")
    exit(0)
}

let mut mode = "dry_run"
if file_exists(MODE_FILE) {
    let m = read_file(MODE_FILE).trim()
    if m == "enabled" { mode = "enabled" }
}

// ── 2. 입력 수집 ──────────────────────────────────────────────────────
let ts = safe_exec("date +%s")
let iso = safe_exec("date -u +%Y-%m-%dT%H:%M:%SZ")

let mut mac_load = 0
let mut load_avg_s = "0"
if file_exists(SESSION_NOW) {
    let snap = read_file(SESSION_NOW)
    if snap.contains("\"load_avg\":\"") {
        load_avg_s = snap.split("\"load_avg\":\"")[1].split("\"")[0]
        try { mac_load = to_int(to_float(load_avg_s) * 100.0) } catch e {}
    }
}

let hid_idle_ns_s = safe_exec("ioreg -c IOHIDSystem 2>/dev/null | awk '/HIDIdleTime/{print $NF; exit}'")
let mut hid_idle_sec = 9999
try { hid_idle_sec = to_int(to_float(hid_idle_ns_s) / 1000000000.0) } catch e {}

let mut ubu_cpu = 0
if file_exists(INFRA_STATE) {
    let inf = read_file(INFRA_STATE)
    if inf.contains("\"ubu_cpu_used\":") {
        let v = inf.split("\"ubu_cpu_used\":")[1].split(",")[0].split("}")[0].trim()
        try { ubu_cpu = to_int(to_float(v)) } catch e {}
    }
}

// ── 3. 상태머신 ───────────────────────────────────────────────────────
let mut state = "cool"
if mac_load >= 1000 { state = "critical" }
else if mac_load >= 600 { state = "hot" }
else if mac_load >= 300 { state = "warm" }

let mut overridden = false
let force_plan = env("AG_COORD_FORCE_PLAN") == "1"
if hid_idle_sec < 60 && (state == "hot" || state == "critical") && force_plan == false {
    state = "cool_user_active"
    overridden = true
}

// ── 4. frontmost app 1회 캡처 (게이트 들이 공유) ──────────────────────
// lsappinfo 사용 — Launch Services 직접 조회, Automation 권한 불필요
let frontmost = safe_exec("lsappinfo info -only name \"$(lsappinfo front)\" 2>/dev/null | awk -F'\"' 'NF>=4{print $4}'")

// ── 5. 게이트 호출 + 결과 수집 ────────────────────────────────────────
let mut all_recs = ""        // JSONL — 모든 게이트의 추천 통합
let mut total_recs = 0
let mut gate_summary = ""    // 게이트별 요약 라인 ("# claude_gate ...")

let gate_list = GATES.split(",")
let mut gi = 0
while gi < gate_list.len() {
    let gate = gate_list[gi].trim()
    if gate == "" { gi = gi + 1; continue }
    let cmd = "AG_COORD_FRONTMOST='" + frontmost.replace("'", "") + "' /Users/ghost/Dev/hexa-lang/target/release/hexa " + AG_HOME + "/modules/gates/" + gate + " '" + state + "' " + to_string(hid_idle_sec) + " 2>/dev/null"
    let out = safe_exec(cmd)
    let lines = out.split("\n")
    let mut li = 0
    while li < lines.len() {
        let line = lines[li].trim()
        if line == "" { li = li + 1; continue }
        if line.contains("# ") {
            // 요약 라인
            if gate_summary != "" { gate_summary = gate_summary + " | " }
            gate_summary = gate_summary + line.replace("# ", "")
        } else if line.contains("\"app\":") && line.contains("\"pid\":") {
            // 추천 JSONL
            if all_recs != "" { all_recs = all_recs + "\n" }
            all_recs = all_recs + line
            total_recs = total_recs + 1
        }
        li = li + 1
    }
    gi = gi + 1
}

// ── 6. HARD_NEVER 필터 + max cap ──────────────────────────────────────
let mut filtered = ""
let mut filtered_count = 0
let mut blocked_count = 0
let rec_lines = all_recs.split("\n")
let hard_pats = HARD_NEVER.split("|")

let mut ri = 0
while ri < rec_lines.len() {
    let rec = rec_lines[ri].trim()
    if rec == "" { ri = ri + 1; continue }
    if filtered_count >= MAX_ACTIONS_PER_RUN { ri = ri + 1; continue }

    // comm 추출
    let mut comm = ""
    if rec.contains("\"comm\":\"") { comm = rec.split("\"comm\":\"")[1].split("\"")[0] }

    // HARD_NEVER 매칭
    let mut is_blocked = false
    let mut hi = 0
    while hi < hard_pats.len() {
        let hp = hard_pats[hi].trim()
        if hp != "" && comm.contains(hp) { is_blocked = true }
        hi = hi + 1
    }
    if is_blocked {
        blocked_count = blocked_count + 1
        ri = ri + 1
        continue
    }

    if filtered != "" { filtered = filtered + "\n" }
    filtered = filtered + rec
    filtered_count = filtered_count + 1
    ri = ri + 1
}

// ── 7. 적용 / dry-run 분기 ────────────────────────────────────────────
let mut applied = 0
let mut released = 0
let should_apply = mode == "enabled" && (state == "hot" || state == "critical")

if should_apply {
    let app_lines = filtered.split("\n")
    let mut ai = 0
    while ai < app_lines.len() {
        let r = app_lines[ai].trim()
        if r == "" { ai = ai + 1; continue }
        let mut pid = ""
        if r.contains("\"pid\":") { pid = r.split("\"pid\":")[1].split(",")[0].trim() }
        let mut action = ""
        if r.contains("\"action\":\"") { action = r.split("\"action\":\"")[1].split("\"")[0] }
        if pid == "" || action == "" { ai = ai + 1; continue }

        // sudo 없이 먼저 시도 → 실패면 sudo -n 폴백 (NOPASSWD 설정 있을 때만 작동)
        // 둘 다 실패하면 silent skip (root 프로세스 + NOPASSWD 없음)
        let mut base_cmd = ""
        if action == "taskpolicy_bg" {
            base_cmd = "taskpolicy -b -p " + pid
        } else if action == "renice" {
            base_cmd = "renice +19 -p " + pid
        }
        if base_cmd != "" {
            // try1: 사용자 권한 직접
            let try1 = safe_exec(base_cmd + " 2>&1; echo __rc=$?")
            let mut ok = try1.contains("__rc=0")
            // try2: sudo -n (NOPASSWD 있어야 작동)
            if ok == false {
                let try2 = safe_exec("sudo -n " + base_cmd + " 2>/dev/null; echo __rc=$?")
                ok = try2.contains("__rc=0")
            }
            if ok {
                applied = applied + 1
                let log_line = "{\"applied_at\":\"" + iso + "\",\"applied_ts\":" + ts + "," + r.replace("{", "")
                try { exec("echo '" + log_line.replace("'", "'\\''") + "' >> '" + ACTIONS_LOG + "'") } catch e {}
            }
        }
        ai = ai + 1
    }

    // TTL 만료된 BG 자동 해제
    let mut cutoff = 0
    try { cutoff = to_int(to_float(ts)) - ACTION_TTL_SEC } catch e {}
    let release_cmd = "if [ -f '" + ACTIONS_LOG + "' ]; then awk -F'[,:]' -v cutoff=" + to_string(cutoff) + " '/applied_ts/ { for(i=1;i<=NF;i++) if($i~/applied_ts/){ts=$(i+1)+0; break} for(i=1;i<=NF;i++) if($i~/\"pid\"/){pid=$(i+1)+0; break} if(ts<cutoff && ts>0 && pid>0) print pid }' '" + ACTIONS_LOG + "' | sort -u | while read p; do taskpolicy -B -p $p 2>/dev/null && echo released_$p; done; fi"
    let rel_out = safe_exec(release_cmd)
    let rel_lines = rel_out.split("\n")
    let mut rli = 0
    while rli < rel_lines.len() {
        if rel_lines[rli].contains("released_") { released = released + 1 }
        rli = rli + 1
    }
} else {
    // dry-run: 계획만 로그
    if filtered != "" {
        let dry_entry = "{\"ts\":\"" + iso + "\",\"state\":\"" + state + "\",\"mode\":\"" + mode + "\",\"frontmost\":\"" + frontmost.replace("'", "").replace("\"", "") + "\",\"plan_count\":" + to_string(filtered_count) + "}"
        try { exec("echo '" + dry_entry + "' >> '" + DRYRUN_LOG + "'") } catch e {}
        // 각 추천도 dry-run log 에 append (한 줄씩)
        let pl_lines = filtered.split("\n")
        let mut pli = 0
        while pli < pl_lines.len() {
            let pl = pl_lines[pli].trim()
            if pl != "" {
                try { exec("echo '" + pl.replace("'", "'\\''") + "' >> '" + DRYRUN_LOG + "'") } catch e {}
            }
            pli = pli + 1
        }
    }
}

// ── 8. 상태 출력 ──────────────────────────────────────────────────────
let summary = "{\"ts\":" + ts + ",\"iso\":\"" + iso + "\",\"mode\":\"" + mode + "\",\"state\":\"" + state + "\",\"mac_load\":" + to_string(mac_load) + ",\"load_avg\":\"" + load_avg_s + "\",\"hid_idle_sec\":" + to_string(hid_idle_sec) + ",\"user_override\":" + (if overridden { "true" } else { "false" }) + ",\"frontmost\":\"" + frontmost.replace("'", "").replace("\"", "") + "\",\"ubu_cpu\":" + to_string(ubu_cpu) + ",\"gate_recs\":" + to_string(total_recs) + ",\"after_filter\":" + to_string(filtered_count) + ",\"blocked_hard_never\":" + to_string(blocked_count) + ",\"applied\":" + to_string(applied) + ",\"released\":" + to_string(released) + "}"
let tmp_out = STATE_OUT + ".tmp"
try {
    write_file(tmp_out, summary + "\n")
    exec("mv -f '" + tmp_out + "' '" + STATE_OUT + "'")
} catch e {}

println("⬡ coordinator " + iso + " mode=" + mode + " state=" + state + " load=" + load_avg_s + " idle=" + to_string(hid_idle_sec) + "s front=" + frontmost + " recs=" + to_string(total_recs) + " filt=" + to_string(filtered_count) + " blk=" + to_string(blocked_count) + " applied=" + to_string(applied) + " released=" + to_string(released))
println("  gates: " + gate_summary)
