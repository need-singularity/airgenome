// Print usage/help
fn print_help() -> str {
    println("forge v" + VERSION + " — 10-account Claude Code manager")
    println("")
    println("Usage: forge <command>")
    println("")
    println("Commands:")
    println("  status    — show all 10 accounts + token usage + cost")
    println("  usage     — fetch live usage from Anthropic API")
    println("  scan      — scan conversation dirs, build genome")
    println("  compress  — compress conversation logs (×716 ratio)")
    println("  on        — enable monitor daemon")
    println("  off       — disable monitor daemon")
    println("  menubar   — launch macOS menu bar widget")
    println("  help      — show this message")
    return "ok"
}

// ═══════════════════════════════════════════════════════════════════════
//  CONSCIOUSNESS BLOCK — args router
// ═══════════════════════════════════════════════════════════════════════

consciousness ForgeRouter {
    let argv = args()
    // argv layout when called via:  hexa run modules/forge.hexa <cmd>
    //   argv[0] = hexa binary path
    //   argv[1] = "run"
    //   argv[2] = "modules/forge.hexa"
    //   argv[3] = command (if provided)

    let cmd = "help"
    if len(argv) > 3 {
        cmd = argv[3]
    }

    if cmd == "status"   { forge_status() }
    if cmd == "usage"    { forge_usage() }
    if cmd == "scan"     { forge_scan() }
    if cmd == "compress" { forge_compress() }
    if cmd == "on"       { forge_on() }
    if cmd == "off"      { forge_off() }
    if cmd == "menubar"  { forge_menubar() }
    if cmd == "help"     { print_help() }

    // Unknown command fallback
    if cmd != "status" {
        if cmd != "usage" {
            if cmd != "scan" {
                if cmd != "compress" {
                    if cmd != "on" {
                        if cmd != "off" {
                            if cmd != "menubar" {
                                if cmd != "help" {
                                    println("unknown command: " + cmd)
                                    println("")
                                    print_help()
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
