let PRICE_INPUT_PER_M  = comptime { 3.0 }   // Claude Sonnet input
let PRICE_OUTPUT_PER_M = comptime { 15.0 }  // Claude Sonnet output
let PRICE_CACHE_READ   = comptime { 0.3 }   // cache read
let PRICE_CACHE_WRITE  = comptime { 3.75 }  // cache write

// Genome constants (from gates.hexa spec)
let GENOME_BYTES = comptime { 60 }
let PAIR_COUNT   = comptime { 15 }
