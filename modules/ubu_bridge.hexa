// airgenome/modules/ubu_bridge.hexa — Ubuntu-First 자원 브릿지 (AG3)
//
// ═══════════════════════════════════════════════════════════════════════
//  AG3 선언 — Ubuntu-First heavy compute
//  "모든 heavy compute(6축 투영 / 게놈 유사도 / forge / LLM)는
//   Ubuntu(ssh:ubu) 우선 실행. Mac은 오케스트레이션/UI/디스패치 전용.
//   Ubuntu 미접속 시에만 local fallback + 경고."
//
//  - Prime Directive 준수 (양쪽 프로세스 kill 없음)
//  - 하드코딩 금지: ssh_alias / 경로는 gate_config.jsonl 에서 동적 로드
//  - 기존 ~/airgenome/gpu_*.py + systemd(airgenome-fill/gate)를 브릿지로 감쌈
//  - CuPy/nvcc/cmake 없음 → PyTorch 2.11+cu130 전용 경로
//
//  스펙: docs/superpowers/specs/2026-04-09-ubuntu-first-breakthrough-design.md
//
//  인터페이스 (Wave 0 스캐폴딩 — body=TODO)
//    fn health() -> bool
//    fn remote_exec(cmd: str) -> str   // (스펙상 exec — 빌트인 exec 와 충돌 회피)
//    fn exec_python(script: str) -> str
//    fn tmpfs_write(name: str, data: str) -> str
//    fn tmpfs_read(name: str) -> str
//    fn gpu_submit(worker: str, args: str) -> str
//    fn get_gpu_status() -> str
//    fn fallback_local() -> void
//
//  Usage: import ubu_bridge; let ok = ubu_bridge::health()
// ═══════════════════════════════════════════════════════════════════════

let VERSION = "0.1.0"
let CONFIG_PATH = env("HOME") + "/Dev/airgenome/nexus/shared/gate_config.jsonl"
let LOG_FILE = "dispatch.log"
let GROWTH_BUS = env("HOME") + "/Dev/nexus/shared/growth_bus.jsonl"

// ═══════════════════════════════════════════════════════════════════════
//  Config loader (offload.hexa 와 동일 패턴)
// ═══════════════════════════════════════════════════════════════════════

fn load_cfg(key: str, fallback: str) -> str {
    if file_exists(CONFIG_PATH) == false { return fallback }
    let content = read_file(CONFIG_PATH)
    let lines = content.split("\n")
    let i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if len(line) > 2 {
            let parsed = json_parse(line)
            if parsed["key"] == key { return parsed["value"] }
        }
        i = i + 1
    }
    return fallback
}

let REMOTE       = load_cfg("ssh_alias",          "ubu")
let REMOTE_DIR   = load_cfg("remote_dir",         "/home/aiden/airgenome")
let UBU_TMPFS    = load_cfg("ubu_tmpfs",          "/mnt/ramdisk/airgenome")
let UBU_PYTHON   = load_cfg("ubu_python",         "python3")
let UBU_WORKER   = load_cfg("ubu_gpu_worker_dir", "/home/aiden/airgenome")

// ═══════════════════════════════════════════════════════════════════════
//  health() — ssh 접속 + torch.cuda 확인
// ═══════════════════════════════════════════════════════════════════════

fn health() -> bool {
    // 1) SSH 접속 3초 타임아웃
    let ping = exec("ssh -o ConnectTimeout=3 -o BatchMode=yes " + REMOTE + " echo ok 2>&1").trim()
    if ping.contains("ok") == false {
        fallback_local()
        return false
    }
    // 2) torch.cuda 확인
    let cuda = exec("ssh -o ConnectTimeout=5 " + REMOTE + " " + UBU_PYTHON + " -c 'import torch; print(torch.cuda.is_available())' 2>&1").trim()
    if cuda.contains("True") == false {
        fallback_local()
        return false
    }
    return true
}

// ═══════════════════════════════════════════════════════════════════════
//  exec(cmd) — 원격 bash 실행, 결과 반환
// ═══════════════════════════════════════════════════════════════════════

fn remote_exec(cmd: str) -> str {
    // offload.hexa::ssh_cmd 패턴: 로컬 임시 스크립트를 stdin 으로 흘려보냄
    write_file("/tmp/_ubu_bridge.sh", cmd)
    try {
        let result = exec("ssh -o ConnectTimeout=5 -o BatchMode=yes " + REMOTE + " bash /dev/stdin < /tmp/_ubu_bridge.sh 2>&1")
        let s = to_string(result)
        if s.contains("exec error") {
            fallback_local()
            return ""
        }
        return s.trim()
    } catch e {
        fallback_local()
        return ""
    }
}

// ═══════════════════════════════════════════════════════════════════════
//  exec_python(script) — 원격 python3 -c 실행
// ═══════════════════════════════════════════════════════════════════════

fn exec_python(script: str) -> str {
    // 로컬 임시 py 파일 → stdin 으로 원격 python3 에 주입
    write_file("/tmp/_ubu_bridge.py", script)
    let result = exec("ssh " + REMOTE + " " + UBU_PYTHON + " - < /tmp/_ubu_bridge.py 2>&1")
    let s = to_string(result)
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s.trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  tmpfs_write(name, data) — /mnt/ramdisk/airgenome/<name> 쓰기
// ═══════════════════════════════════════════════════════════════════════

fn tmpfs_write(name: str, data: str) -> str {
    // 1) 원격 tmpfs 디렉토리 보장
    let mk = exec("ssh " + REMOTE + " mkdir -p " + UBU_TMPFS + " 2>&1")
    if to_string(mk).contains("exec error") {
        fallback_local()
        return ""
    }
    // 2) 로컬 임시 파일 → scp 업로드
    let local_tmp = "/tmp/_ubu_bridge_upload_" + name
    write_file(local_tmp, data)
    let remote_path = UBU_TMPFS + "/" + name
    let r = exec("scp " + local_tmp + " " + REMOTE + ":" + remote_path + " 2>&1")
    if to_string(r).contains("exec error") {
        fallback_local()
        return ""
    }
    return remote_path
}

// ═══════════════════════════════════════════════════════════════════════
//  tmpfs_read(name) — /mnt/ramdisk/airgenome/<name> 읽기
// ═══════════════════════════════════════════════════════════════════════

fn tmpfs_read(name: str) -> str {
    // 원격 tmpfs 파일 cat
    let result = exec("ssh " + REMOTE + " cat " + UBU_TMPFS + "/" + name + " 2>&1")
    let s = to_string(result)
    if s.contains("No such file") { return "" }
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s
}

// ═══════════════════════════════════════════════════════════════════════
//  gpu_submit(worker, args) — ~/airgenome/gpu_*.py 호출
//    worker ∈ {"gpu_sweep", "gpu_batch", "gpu_cross_sweep",
//              "six_axis_gate", "cosine_nxn", "llm_query",
//              "forge", "forge_idle"}
// ═══════════════════════════════════════════════════════════════════════

fn gpu_submit(worker: str, args: str) -> str {
    // worker 는 파일명만 (예: "gpu_sweep.py") → 원격 워커 디렉토리에서 python3 실행
    let cmd = "cd " + UBU_WORKER + " && " + UBU_PYTHON + " " + worker + " " + args
    let result = exec("ssh " + REMOTE + " \"" + cmd + "\" 2>&1")
    let s = to_string(result)
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s.trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  get_gpu_status() — nvidia-smi 요약 (W/MHz/VRAM/util)
// ═══════════════════════════════════════════════════════════════════════

fn get_gpu_status() -> str {
    // util / mem.used / mem.total / power / temp
    let q = "nvidia-smi --query-gpu=utilization.gpu,memory.used,memory.total,power.draw,temperature.gpu --format=csv,noheader"
    let result = exec("ssh " + REMOTE + " \"" + q + "\" 2>&1")
    let s = to_string(result)
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s.trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  fallback_local() — 경고 로그 + growth_bus 이벤트
// ═══════════════════════════════════════════════════════════════════════

fn fallback_local() -> void {
    // 1) stderr 경고
    eprintln("[AG3] Ubuntu unreachable — degrading to local mode")
    // 2) dispatch.log append
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    append_file(LOG_FILE, ts + "\tfallback\tubu_offline\tlocal_degrade\n")
    // 3) growth_bus 이벤트 (gb_append schema: ts iso8601Z + source + event + domain="airgenome")
    let ev = "{\"ts\":\"" + ts + "\",\"source\":\"airgenome/ubu_bridge\",\"event\":\"fallback_ubu_offline\",\"domain\":\"airgenome\",\"type\":\"fallback\",\"phase\":\"ag3\",\"id\":\"ubu_offline\",\"value\":1,\"grade\":\"WARN\",\"resource_domain\":\"resource\",\"timestamp\":\"" + ts + "\"}"
    append_file(GROWTH_BUS, ev + "\n")
    return
}

// ═══════════════════════════════════════════════════════════════════════
//  END — modules/ubu_bridge.hexa
// ═══════════════════════════════════════════════════════════════════════
