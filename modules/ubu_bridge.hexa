// airgenome/modules/ubu_bridge.hexa — Ubuntu-First 자원 브릿지 (AG3)
//
// ═══════════════════════════════════════════════════════════════════════
//  AG3 선언 — Ubuntu-First heavy compute
//  "모든 heavy compute(6축 투영 / 게놈 유사도 / forge / LLM)는
//   Ubuntu(ssh:ubu) 우선 실행. Mac은 오케스트레이션/UI/디스패치 전용.
//   Ubuntu 미접속 시에만 local fallback + 경고."
//
//  - Prime Directive 준수 (양쪽 프로세스 kill 없음)
//  - 하드코딩 금지: ssh_alias / 경로는 gate_config.jsonl 에서 동적 로드
//  - 기존 ~/airgenome/gpu_*.py + systemd(airgenome-fill/gate)를 브릿지로 감쌈
//  - CuPy/nvcc/cmake 없음 → PyTorch 2.11+cu130 전용 경로
//
//  스펙: docs/superpowers/specs/2026-04-09-ubuntu-first-breakthrough-design.md
//
//  인터페이스 (Wave 0 완료 — 전 함수 구현됨)
//    fn health() -> bool
//    fn remote_exec(cmd: str) -> str   // (스펙상 exec — 빌트인 exec 와 충돌 회피)
//    fn exec_python(script: str) -> str
//    fn tmpfs_write(name: str, data: str) -> str
//    fn tmpfs_read(name: str) -> str
//    fn gpu_submit(worker: str, args: str) -> str
//    fn get_gpu_status() -> str
//    fn fallback_local() -> void
//
//  인터페이스 Wave 1 (AG7 multi-host — 2026-04-12 추가):
//    fn best_host_for(task_type: str) -> str          // "ubu"|"htz"|"none"
//    fn host_ssh_alias(host_key: str) -> str          // → ssh config alias
//    fn host_python(host_key: str) -> str             // → python3 binary
//    fn host_worker_dir(host_key: str) -> str         // → remote workdir
//    fn remote_exec_for(task_type: str, cmd: str) -> str
//    fn exec_python_for(task_type: str, script: str) -> str
//    fn gpu_submit_for(worker: str, args: str) -> str  // task_type="gpu_heavy" 고정
//
//  AG7 Consumer 의무: 기존 Wave 0 API 는 ubu 고정. 신규 코드는 Wave 1 API
//  (dispatch_state.json 기반 자동 best-fit) 를 사용할 것.
//
//  Usage: import ubu_bridge; let ok = ubu_bridge::health()
// ═══════════════════════════════════════════════════════════════════════

let VERSION = "0.2.0"  // Wave 1 — AG7 multi-host API 추가 (2026-04-12)
let CONFIG_PATH = env("HOME") + "/Dev/airgenome/nexus/shared/gate_config.jsonl"
let LOG_FILE = env("HOME") + "/Dev/airgenome/forge/dispatch.log"
let GROWTH_BUS = env("HOME") + "/Dev/nexus/shared/growth_bus.jsonl"
let DISPATCH_STATE = env("HOME") + "/Dev/nexus/shared/dispatch_state.json"  // AG7 input

// ═══════════════════════════════════════════════════════════════════════
//  Config loader (offload.hexa 와 동일 패턴)
// ═══════════════════════════════════════════════════════════════════════

fn load_cfg(key: str, fallback: str) -> str {
    if file_exists(CONFIG_PATH) == false { return fallback }
    let content = read_file(CONFIG_PATH)
    let lines = content.split("\n")
    let i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if len(line) > 2 {
            let parsed = json_parse(line)
            if parsed["key"] == key { return parsed["value"] }
        }
        i = i + 1
    }
    return fallback
}

let REMOTE       = load_cfg("ssh_alias",          "ubu")
let REMOTE_DIR   = load_cfg("remote_dir",         env("HOME") + "/airgenome")
let UBU_TMPFS    = load_cfg("ubu_tmpfs",          "/mnt/ramdisk/airgenome")
let UBU_PYTHON   = load_cfg("ubu_python",         "python3")
let UBU_WORKER   = load_cfg("ubu_gpu_worker_dir", env("HOME") + "/airgenome")

// ═══════════════════════════════════════════════════════════════════════
//  health() — ssh 접속 + torch.cuda 확인
// ═══════════════════════════════════════════════════════════════════════

fn health() -> bool {
    // 1) SSH 접속 3초 타임아웃
    let ping = exec("ssh -o ConnectTimeout=3 -o ServerAliveInterval=10 -o ServerAliveCountMax=1 -o BatchMode=yes " + REMOTE + " echo ok 2>&1").trim()
    if ping.contains("ok") == false {
        fallback_local()
        return false
    }
    // 2) torch.cuda 확인
    let cuda = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=15 -o ServerAliveCountMax=1 " + REMOTE + " " + UBU_PYTHON + " -c 'import torch; print(torch.cuda.is_available())' 2>&1").trim()
    if cuda.contains("True") == false {
        fallback_local()
        return false
    }
    return true
}

// ═══════════════════════════════════════════════════════════════════════
//  exec(cmd) — 원격 bash 실행, 결과 반환
// ═══════════════════════════════════════════════════════════════════════

fn remote_exec(cmd: str) -> str {
    // offload.hexa::ssh_cmd 패턴: 로컬 임시 스크립트를 stdin 으로 흘려보냄
    write_file("/tmp/_ubu_bridge.sh", cmd)
    try {
        let result = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=30 -o ServerAliveCountMax=1 -o BatchMode=yes " + REMOTE + " bash /dev/stdin < /tmp/_ubu_bridge.sh 2>&1")
        let s = to_string(result)
        if s.contains("exec error") {
            fallback_local()
            return ""
        }
        return s.trim()
    } catch e {
        fallback_local()
        return ""
    }
}

// ═══════════════════════════════════════════════════════════════════════
//  exec_python(script) — 원격 python3 -c 실행
// ═══════════════════════════════════════════════════════════════════════

fn exec_python(script: str) -> str {
    // 로컬 임시 py 파일 → stdin 으로 원격 python3 에 주입
    write_file("/tmp/_ubu_bridge.py", script)
    let result = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=30 -o ServerAliveCountMax=1 " + REMOTE + " " + UBU_PYTHON + " - < /tmp/_ubu_bridge.py 2>&1")
    let s = to_string(result)
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s.trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  tmpfs_write(name, data) — /mnt/ramdisk/airgenome/<name> 쓰기
// ═══════════════════════════════════════════════════════════════════════

fn tmpfs_write(name: str, data: str) -> str {
    // 1) 원격 tmpfs 디렉토리 보장
    let mk = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=15 -o ServerAliveCountMax=1 " + REMOTE + " mkdir -p " + UBU_TMPFS + " 2>&1")
    if to_string(mk).contains("exec error") {
        fallback_local()
        return ""
    }
    // 2) 로컬 임시 파일 → scp 업로드
    let local_tmp = "/tmp/_ubu_bridge_upload_" + name
    write_file(local_tmp, data)
    let remote_path = UBU_TMPFS + "/" + name
    let r = exec("scp -o ConnectTimeout=3 -o ServerAliveInterval=30 -o ServerAliveCountMax=1 " + local_tmp + " " + REMOTE + ":" + remote_path + " 2>&1")
    if to_string(r).contains("exec error") {
        fallback_local()
        return ""
    }
    return remote_path
}

// ═══════════════════════════════════════════════════════════════════════
//  tmpfs_read(name) — /mnt/ramdisk/airgenome/<name> 읽기
// ═══════════════════════════════════════════════════════════════════════

fn tmpfs_read(name: str) -> str {
    // 원격 tmpfs 파일 cat
    let result = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=15 -o ServerAliveCountMax=1 " + REMOTE + " cat " + UBU_TMPFS + "/" + name + " 2>&1")
    let s = to_string(result)
    if s.contains("No such file") { return "" }
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s
}

// ═══════════════════════════════════════════════════════════════════════
//  gpu_submit(worker, args) — ~/airgenome/gpu_*.py 호출
//    worker ∈ {"gpu_sweep", "gpu_batch", "gpu_cross_sweep",
//              "six_axis_gate", "cosine_nxn", "llm_query",
//              "forge", "forge_idle"}
// ═══════════════════════════════════════════════════════════════════════

fn gpu_submit(worker: str, args: str) -> str {
    // worker 는 파일명만 (예: "gpu_sweep.py") → 원격 워커 디렉토리에서 python3 실행
    let cmd = "cd " + UBU_WORKER + " && " + UBU_PYTHON + " " + worker + " " + args
    let result = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=30 -o ServerAliveCountMax=1 " + REMOTE + " \"" + cmd + "\" 2>&1")
    let s = to_string(result)
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s.trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  get_gpu_status() — nvidia-smi 요약 (W/MHz/VRAM/util)
// ═══════════════════════════════════════════════════════════════════════

fn get_gpu_status() -> str {
    // util / mem.used / mem.total / power / temp
    let q = "nvidia-smi --query-gpu=utilization.gpu,memory.used,memory.total,power.draw,temperature.gpu --format=csv,noheader"
    let result = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=15 -o ServerAliveCountMax=1 " + REMOTE + " \"" + q + "\" 2>&1")
    let s = to_string(result)
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s.trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  fallback_local() — 경고 로그 + growth_bus 이벤트
// ═══════════════════════════════════════════════════════════════════════

fn fallback_local() -> void {
    // 1) stderr 경고
    eprintln("[AG3] Ubuntu unreachable — degrading to local mode")
    // 2) dispatch.log append
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    append_file(LOG_FILE, ts + "\tfallback\tubu_offline\tlocal_degrade\n")
    // 3) growth_bus 이벤트 (gb_append schema: ts iso8601Z + source + event + domain="airgenome")
    let ev = "{\"ts\":\"" + ts + "\",\"source\":\"airgenome/ubu_bridge\",\"event\":\"fallback_ubu_offline\",\"domain\":\"airgenome\",\"type\":\"fallback\",\"phase\":\"ag3\",\"id\":\"ubu_offline\",\"value\":1,\"grade\":\"WARN\",\"resource_domain\":\"resource\",\"timestamp\":\"" + ts + "\"}"
    append_file(GROWTH_BUS, ev + "\n")
    return
}

// ═══════════════════════════════════════════════════════════════════════
//  Wave 1 (AG7 multi-host) — dispatch_state.json 기반 best-fit 라우팅
//  2026-04-12 골화. Consumer 는 기존 Wave 0 (ubu 고정) 대신 이 API 사용.
// ═══════════════════════════════════════════════════════════════════════

// best_host_for — dispatch_state.json 에서 task_type 에 맞는 best host key 반환
// 반환값: "ubu" | "htz" | "none"  (파일/키 없으면 "ubu" fallback)
fn best_host_for(task_type: str) -> str {
    if file_exists(DISPATCH_STATE) == false { return "ubu" }
    let raw = read_file(DISPATCH_STATE)
    let tag = "\"" + task_type + "\":{\"host\":\""
    if raw.contains(tag) == false { return "ubu" }
    let after = raw.split(tag)[1]
    let h = after.split("\"")[0]
    if len(h) == 0 { return "ubu" }
    return h
}

// host_key ("ubu"/"htz") → 실제 SSH config alias
fn host_ssh_alias(host_key: str) -> str {
    if host_key == "ubu" { return load_cfg("ssh_alias", "ubu") }
    if host_key == "htz" { return load_cfg("htz_ssh_alias", "hetzner") }
    if host_key == "hetzner" { return load_cfg("htz_ssh_alias", "hetzner") }
    return REMOTE
}

// host_key → python3 binary 경로
fn host_python(host_key: str) -> str {
    if host_key == "ubu" { return UBU_PYTHON }
    if host_key == "htz" { return load_cfg("htz_python", "python3") }
    return UBU_PYTHON
}

// host_key → remote worker directory
fn host_worker_dir(host_key: str) -> str {
    if host_key == "ubu" { return UBU_WORKER }
    if host_key == "htz" {
        return load_cfg("htz_worker_dir", load_cfg("htz_nexus_dir", env("HOME") + "/Dev/nexus") + "/airgenome")
    }
    return UBU_WORKER
}

// remote_exec_for — task type 에 맞는 best host 에서 bash 실행
fn remote_exec_for(task_type: str, cmd: str) -> str {
    let host_key = best_host_for(task_type)
    if host_key == "none" {
        fallback_local()
        return ""
    }
    let alias = host_ssh_alias(host_key)
    write_file("/tmp/_ubu_bridge_for.sh", cmd)
    try {
        let result = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=30 -o ServerAliveCountMax=1 -o BatchMode=yes " + alias + " bash /dev/stdin < /tmp/_ubu_bridge_for.sh 2>&1")
        let s = to_string(result)
        if s.contains("exec error") {
            fallback_local()
            return ""
        }
        return s.trim()
    } catch e {
        fallback_local()
        return ""
    }
}

// exec_python_for — task type 에 맞는 best host 에서 python3 실행
fn exec_python_for(task_type: str, script: str) -> str {
    let host_key = best_host_for(task_type)
    if host_key == "none" {
        fallback_local()
        return ""
    }
    let alias = host_ssh_alias(host_key)
    let py = host_python(host_key)
    write_file("/tmp/_ubu_bridge_for.py", script)
    let result = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=30 -o ServerAliveCountMax=1 " + alias + " " + py + " - < /tmp/_ubu_bridge_for.py 2>&1")
    let s = to_string(result)
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s.trim()
}

// gpu_submit_for — gpu_heavy task 전용. GPU 있는 호스트만 선택됨 (load_balancer score)
fn gpu_submit_for(worker: str, args: str) -> str {
    let host_key = best_host_for("gpu_heavy")
    if host_key == "none" {
        fallback_local()
        return ""
    }
    let alias = host_ssh_alias(host_key)
    let py = host_python(host_key)
    let wdir = host_worker_dir(host_key)
    let cmd = "cd " + wdir + " && " + py + " " + worker + " " + args
    let result = exec("ssh -o ConnectTimeout=5 -o ServerAliveInterval=30 -o ServerAliveCountMax=1 " + alias + " \"" + cmd + "\" 2>&1")
    let s = to_string(result)
    if s.contains("exec error") {
        fallback_local()
        return ""
    }
    return s.trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  END — modules/ubu_bridge.hexa
// ═══════════════════════════════════════════════════════════════════════
