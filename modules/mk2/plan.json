{
  "$schema": "nexus.airgenome.mk2-plan.v1",
  "id": "airgenome-mk2-minimal-monitor-gate",
  "version": "0.2.0",
  "created": "2026-04-13",
  "owner": "dancinlife",
  "status": "draft",

  "harness_alignment": {
    "upstream": "/Users/ghost/Dev/nexus/shared/harness",
    "thesis": "모델이 똑똑해질수록 하네스는 더 단순해져야 한다 (Sutton — Bitter Lesson)",
    "principles_applied": [
      "silent_success_loud_failure — probe/gate 는 성공 시 stdout 침묵, 실패 시 stderr JSON 1줄",
      "no_autofix — 규칙 위반 감지 시 차단·기록만, 자동 수정 금지",
      "deprecate_first — Mk1 아카이브 전에 bitter-gate audit 으로 dormant 로직 식별 (S0)",
      "ai_native — 모든 결과물 append-only JSONL (gate_log/mistakes), 산문 문서는 mk1/README.md 1개만",
      "L0_respect — 영구 골화 모듈은 제자리 유지, 내용만 단일샷 verb 로 재작성"
    ],
    "refs": {
      "pillars": "nexus/shared/harness/pillars.jsonl",
      "principles": "nexus/shared/harness/principles.jsonl",
      "bitter_gate": "nexus/shared/harness/bitter-gate.hexa",
      "lint_rules": "nexus/shared/harness/lint.hexa",
      "rule_ids_to_comply": ["R1", "R14", "L0", "P-PY-HEAVY"]
    }
  },

  "context": {
    "project": "airgenome",
    "problem": "8개 launchd 워커가 5-60s 폴링, hexa_stage0 인터프리터 콜드스타트 × 2280회/시간, 상시 CPU 370%",
    "trigger": "2026-04-13 11:45 Path C (hexa_full.hexa) 재빌드 완료 → 새 인터프리터 전환 적기",
    "constraint": [
      "미니멀 — 폴링 최소화",
      "모니터링+게이트는 메인 기능",
      "AG3/AG4/AG6/AG7/R-MAC-01 방어 유지",
      "L0 락 파일 3종 (mac_compute_zero, load_balancer, ag3_menubar_feed + plist) 제자리 유지",
      "롤백 가능 (mk1 아카이브 보존, L0 파일은 git revert)"
    ],
    "target": {
      "wakeups_per_hour": { "before": 2280, "after_max": 70 },
      "steady_cpu_pct": { "before": 370, "after_max": 30 },
      "workers": { "before": 8, "after_max": 2 }
    }
  },

  "l0_status": {
    "lockdown_source": "/Users/ghost/Dev/nexus/shared/lockdown/lockdown.json",
    "protected_paths": [
      "modules/mac_compute_zero.hexa",
      "scripts/com.airgenome.mac-compute-zero.plist",
      "modules/load_balancer.hexa",
      "scripts/com.airgenome.load-balancer.plist",
      "modules/ag3_menubar_feed.hexa"
    ],
    "handling": "inplace_rewrite — 영구 골화 규칙 (2026-04-12 사용자 직접) 존중. mv 금지. 내용은 단일샷 verb 추가 편집으로만 갱신 (PR + CODEOWNERS 경유). plist 은 Disabled=true + StartInterval 제거 편집.",
    "demote_forbidden": true
  },

  "archive": {
    "destination": "/Users/ghost/Dev/airgenome/mk1",
    "modules_movable": [
      { "from": "modules/resource_coordinator.hexa", "poll_sec": 10, "role": "L3+L4+L5 통합 gate" },
      { "from": "modules/resource_ceiling.hexa", "poll_sec": 30, "role": "천장 모니터 + auto_fill" },
      { "from": "modules/launcher_cap.hexa", "poll_sec": 20, "role": "AG4 launcher ≤8" },
      { "from": "modules/auto_dispatch.hexa", "poll_sec": 5, "role": "OFFLOAD_O1 throttle" },
      { "from": "modules/ag3_loop.hexa", "poll_sec": 5, "role": "AG3 게놈 스캔" },
      { "from": "modules/infra_probe.hexa", "poll_sec": 60, "role": "원격 상태 수집" }
    ],
    "modules_inplace_l0": [
      { "path": "modules/mac_compute_zero.hexa", "new_shape": "단일샷 verb: check / heartbeat / enforce", "invoked_by": "mk2 probe subprocess" },
      { "path": "modules/load_balancer.hexa", "new_shape": "단일샷 verb: score / best-host", "invoked_by": "mk2 probe subprocess" },
      { "path": "modules/ag3_menubar_feed.hexa", "new_shape": "단일샷 verb: refresh", "invoked_by": "mk2 probe subprocess (선택)" }
    ],
    "plists_movable": [
      "com.airgenome.resource-coordinator.plist",
      "com.airgenome.resource-ceiling.plist",
      "com.airgenome.launcher-cap.plist",
      "com.airgenome.auto-dispatch.plist",
      "com.airgenome.ag3-loop.plist",
      "com.airgenome.ag3-loop-once.plist",
      "com.airgenome.infra-probe.plist"
    ],
    "plists_inplace_l0_edit": [
      { "path": "scripts/com.airgenome.mac-compute-zero.plist", "edit": "Disabled=true, StartInterval 제거" },
      { "path": "scripts/com.airgenome.load-balancer.plist", "edit": "Disabled=true, StartInterval 제거" }
    ]
  },

  "mk2": {
    "base_dir": "/Users/ghost/Dev/airgenome/modules/mk2",
    "state_file": "~/.airgenome/mk2/state.json",
    "log_files": {
      "gate_log": "~/.airgenome/mk2/gate_log.jsonl",
      "mistakes": "~/.airgenome/mk2/mistakes.jsonl"
    },
    "jsonl_convention": "append-only, 1 event per line, pass/fail 모두 gate_log; fail 만 mistakes 에 중복 기록 (harness 와 동일)",
    "components": [
      {
        "id": "probe",
        "file": "modules/mk2/probe.hexa",
        "launchd": {
          "label": "com.airgenome.mk2-probe",
          "StartInterval": 60,
          "RunAtLoad": true,
          "KeepAlive": false
        },
        "responsibilities": [
          "ssh ubu + ssh hetzner (병렬, 5s timeout) → load/ram/gpu",
          "Mac sysctl vm.loadavg + top 10 pcpu",
          "L0 load_balancer.hexa 를 subprocess 로 호출해 best_host 계산 (인라인 복제 금지)",
          "L0 mac_compute_zero.hexa heartbeat verb 호출",
          "state.json 원자적 write (tmp → rename)",
          "mk2_epoch = unix_time 갱신",
          "silent_success: stdout 0바이트, 실패 시 stderr {error, code} JSON 1줄"
        ],
        "budget": {
          "runtime_ms_max": 5000,
          "memory_mb_max": 50,
          "wakeups_per_hour": 60
        }
      },
      {
        "id": "gate",
        "file": "modules/mk2/gate.hexa",
        "launchd": null,
        "invoked_by": "Claude Code hook (PreToolUse/PostToolUse) + CLI",
        "verbs": {
          "pre-bash": {
            "trigger": "PreToolUse matcher=Bash",
            "timeout_sec": 3,
            "checks": [
              "mk2_epoch 신선도 (<120s)",
              "Mac load < AG6 threshold",
              "L0 mac_compute_zero check verb 호출 (원격 idle 확인)",
              "heavy keyword 감지 시 차단"
            ],
            "on_fail": "stderr JSON {tool,reason,action:block} + mistakes.jsonl append + exit 1"
          },
          "pre-agent": {
            "trigger": "PreToolUse matcher=Agent",
            "timeout_sec": 3,
            "checks": [
              "동시 Agent ≤8 (AG4)",
              "launcher 프로세스 count 제한"
            ],
            "on_fail": "stderr JSON + mistakes.jsonl + exit 1"
          },
          "post-bash": {
            "trigger": "PostToolUse matcher=Bash",
            "timeout_sec": 3,
            "checks": [
              "state=R + elapsed>5min hexa 좀비 kill",
              "gate_log.jsonl 1줄 기록 (성공/실패 모두)"
            ]
          },
          "status": {
            "trigger": "CLI",
            "timeout_sec": 3,
            "output": "state.json 요약 (human-readable, stdout)"
          }
        },
        "budget": {
          "runtime_ms_max": 200,
          "state_write": false
        }
      },
      {
        "id": "ceiling",
        "file": "modules/mk2/ceiling.hexa",
        "optional": true,
        "launchd": {
          "label": "com.airgenome.mk2-ceiling",
          "StartInterval": 900,
          "Disabled": true,
          "RunAtLoad": false
        },
        "responsibilities": [
          "state.json 읽기",
          "ubu/hetzner 50% 미달 시 systemctl start auto_fill@* (SSH 1회)"
        ],
        "budget": {
          "runtime_ms_max": 10000,
          "wakeups_per_hour": 4
        }
      }
    ]
  },

  "hooks_config": {
    "file": "/Users/ghost/Dev/airgenome/.claude/settings.json",
    "additions": {
      "PreToolUse": [
        { "matcher": "Bash",  "command": "hexa run ~/Dev/airgenome/modules/mk2/gate.hexa pre-bash",  "timeout": 3 },
        { "matcher": "Agent", "command": "hexa run ~/Dev/airgenome/modules/mk2/gate.hexa pre-agent", "timeout": 3 }
      ],
      "PostToolUse": [
        { "matcher": "Bash",  "command": "hexa run ~/Dev/airgenome/modules/mk2/gate.hexa post-bash", "timeout": 3 }
      ]
    },
    "preserve": ["기존 nexus hook-entry.hexa 체인 유지 — 병렬 등록"],
    "patch_schema_ref": "nexus/shared/harness/hooks-config-patch.json"
  },

  "steps": [
    {
      "id": "S0-bitter-audit",
      "order": 0,
      "title": "Mk1 모듈에 대해 bitter-gate audit — dormant 로직 식별",
      "actions": [
        "hexa run nexus/shared/harness/bitter-gate.hexa --audit --window 500",
        "각 Mk1 모듈의 regex 히트 카운트 수집 (resource_coordinator, auto_dispatch 등)",
        "dormant(히트 0) 또는 near-dormant(<3) 인 규칙/로직 → S1 archive 시 'dead' 태그"
      ],
      "verify": [
        "nexus/shared/harness/rules_usage.jsonl 에 신규 audit 엔트리 1건",
        "mk1/README.md 에 dormant 식별 결과 섹션 추가"
      ]
    },
    {
      "id": "S1-archive",
      "order": 1,
      "blocked_by": ["S0-bitter-audit"],
      "title": "Non-L0 6개 모듈 + 7개 plist 를 mk1/ 로 이동",
      "actions": [
        "mkdir -p /Users/ghost/Dev/airgenome/mk1/launchd",
        "launchctl bootout gui/501/com.airgenome.<label> × 7 (non-L0)",
        "mv modules/{resource_coordinator,resource_ceiling,launcher_cap,auto_dispatch,ag3_loop,infra_probe}.hexa mk1/",
        "mv ~/Library/LaunchAgents/com.airgenome.{모두}.plist mk1/launchd/ (non-L0 7개)",
        "write mk1/README.md (복구 절차 + S0 audit 결과)",
        "L0 파일 3종 + plist 2종은 제자리 유지, PR 로 내용만 편집"
      ],
      "verify": [
        "launchctl list | grep airgenome 에서 비L0 7개 label 부재",
        "L0 5개 파일 존재 계속 PASS (l0_guard verify)",
        "ps axo command | grep airgenome/modules 에 비L0 6개 0건"
      ]
    },
    {
      "id": "S2-l0-inplace-edit",
      "order": 2,
      "blocked_by": ["S1-archive"],
      "title": "L0 모듈 3개 + plist 2개 제자리 편집 (단일샷 verb 추가)",
      "actions": [
        "edit modules/mac_compute_zero.hexa — main() 폴링 루프 제거, check/heartbeat/enforce verb 분기 추가",
        "edit modules/load_balancer.hexa — main() 폴링 루프 제거, score/best-host verb 분기 추가",
        "edit modules/ag3_menubar_feed.hexa — main() 폴링 루프 제거, refresh verb 분기 추가",
        "edit scripts/com.airgenome.mac-compute-zero.plist — Disabled=true, StartInterval 제거",
        "edit scripts/com.airgenome.load-balancer.plist — Disabled=true, StartInterval 제거",
        "commit message prefix: 'chore(lockdown): L0 inplace — single-shot verb refactor'"
      ],
      "verify": [
        "l0_guard verify 47 PASS / 0 FAIL 유지",
        "hexa run modules/mac_compute_zero.hexa check exit 0",
        "hexa run modules/load_balancer.hexa score exit 0, JSON 출력",
        "launchctl list | grep mac-compute-zero → Disabled 상태"
      ]
    },
    {
      "id": "S3-mk2-probe",
      "order": 3,
      "blocked_by": ["S2-l0-inplace-edit"],
      "title": "probe.hexa 작성 + launchd 등록",
      "actions": [
        "write modules/mk2/probe.hexa (L0 모듈 subprocess 호출 포함)",
        "write ~/Library/LaunchAgents/com.airgenome.mk2-probe.plist",
        "hexa run modules/mk2/probe.hexa (manual smoke)",
        "launchctl bootstrap gui/501 ~/Library/LaunchAgents/com.airgenome.mk2-probe.plist"
      ],
      "verify": [
        "~/.airgenome/mk2/state.json 생성",
        "jq .mk2_epoch state.json 이 60s 이내 값",
        "state.json 안에 best_host (load_balancer 결과) + mac_heavy_ok (mac_compute_zero 결과) 포함",
        "2분 대기 후 state.json mtime 갱신",
        "stdout 침묵 (silent_success)"
      ]
    },
    {
      "id": "S4-mk2-gate",
      "order": 4,
      "blocked_by": ["S3-mk2-probe"],
      "title": "gate.hexa 작성 (4 verbs, silent_success + mistakes.jsonl)",
      "actions": [
        "write modules/mk2/gate.hexa",
        "hexa run modules/mk2/gate.hexa status (smoke)",
        "hexa run modules/mk2/gate.hexa pre-bash (dry)",
        "hexa run modules/mk2/gate.hexa post-bash (dry)"
      ],
      "verify": [
        "4 verbs exit 0 on success, stdout 0바이트",
        "runtime <200ms 각각",
        "gate_log.jsonl 1줄 append (성공도 기록)",
        "강제 실패 케이스 주입 → mistakes.jsonl 1줄 append + stderr JSON"
      ]
    },
    {
      "id": "S5-hooks",
      "order": 5,
      "blocked_by": ["S4-mk2-gate"],
      "title": ".claude/settings.json 에 Mk2 hook 3개 추가",
      "actions": [
        "edit airgenome/.claude/settings.json — hooks.PreToolUse + hooks.PostToolUse 에 Mk2 추가",
        "기존 hook-entry.hexa 체인 보존"
      ],
      "verify": [
        "jq .hooks.PreToolUse settings.json 에서 gate.hexa 확인",
        "airgenome 디렉토리에서 Bash 1회 실행 → gate_log.jsonl 새 줄"
      ]
    },
    {
      "id": "S6-ceiling-optional",
      "order": 6,
      "optional": true,
      "blocked_by": ["S3-mk2-probe"],
      "title": "ceiling.hexa 작성 (비활성 상태로)",
      "actions": [
        "write modules/mk2/ceiling.hexa",
        "write ~/Library/LaunchAgents/com.airgenome.mk2-ceiling.plist (Disabled=true)"
      ],
      "verify": [
        "launchctl list | grep mk2-ceiling 부재 (Disabled)",
        "수동 hexa run ceiling.hexa 동작"
      ]
    },
    {
      "id": "S7-soak",
      "order": 7,
      "blocked_by": ["S5-hooks"],
      "title": "30분 부하 측정 + 예산 검증 + harness lint 통과",
      "actions": [
        "uptime 1분 평균 기록 × 3회 (0, 15, 30분)",
        "ps axo pcpu,command | awk $1>30 && /hexa/ 카운트",
        "launchctl list | grep airgenome 카운트",
        "hexa run nexus/shared/harness/lint.hexa --file modules/mk2/probe.hexa",
        "hexa run nexus/shared/harness/lint.hexa --file modules/mk2/gate.hexa"
      ],
      "verify": [
        "uptime 1min avg < 2.0",
        "high-CPU hexa count = 0 (hook 실행 순간 제외)",
        "airgenome launchd 활성 = 1–2 (mk2-probe [+mk2-ceiling])",
        "lint.hexa exit 0 on Mk2 파일들 (R1/R14/P-PY-HEAVY 통과)",
        "mistakes.jsonl 순증 = 0 during 정상 사용"
      ]
    }
  ],

  "rollback": {
    "trigger": "S3~S7 중 어느 단계라도 실패 시",
    "steps": [
      "launchctl bootout mk2-probe / mk2-ceiling",
      "cp mk1/launchd/*.plist ~/Library/LaunchAgents/ (non-L0)",
      "cp mk1/*.hexa modules/ (non-L0)",
      "launchctl bootstrap gui/501 <각 plist>",
      "L0 파일 3종 + plist 2종은 git revert <S2 commit>",
      "settings.json 에서 mk2 hook 3개 제거 (git revert)",
      "modules/mk2/ 디렉토리는 보존 (재시도용)",
      "l0_guard verify 47 PASS 재확인"
    ]
  },

  "safety": {
    "L0_protected": true,
    "l0_touch_requires_pr": true,
    "l0_commit_prefix": "chore(lockdown):",
    "git_branch_suggested": "feat/mk2-minimal-monitor-gate",
    "commit_per_step": true,
    "destructive_operations": [
      "launchctl bootout × 7 (non-L0, 복구 가능)",
      "파일 mv × 6 (non-L0, 복구 가능)",
      "L0 파일 편집 × 3 (PR + CODEOWNERS, git revert 가능)",
      "L0 plist 편집 × 2 (PR + CODEOWNERS, git revert 가능)",
      "settings.json 편집 (git revert 가능)"
    ],
    "requires_sudo": false,
    "requires_permission_prompt": false,
    "harness_lint_required_before_merge": true
  },

