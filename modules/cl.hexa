// airgenome/modules/cl.hexa — Claude Code multi-account launcher
//
// Features:
//   1. cl / claude → auto-pick best account, launch claude code
//   2. Rate limit → auto-switch to next account (오염 방지)
//   3. /login capture → add new account to management
//   4. cl status → show all accounts usage
//   5. cl remove <name> → remove account
//
// 폐기 가능: 이 파일 삭제 + ~/.zshrc에서 cl 제거하면 끝

// ═══════════════════════════════════════════════════════════════════════
//  CONSTANTS
// ═══════════════════════════════════════════════════════════════════════

let VERSION = "0.1.0"
let ACCOUNTS_FILE = "~/.airgenome/accounts.json"
let STATE_FILE = "~/.airgenome/cl-state.json"
let USAGE_CACHE = "~/.airgenome/usage-cache.json"

// Rate limit detection patterns
let RATE_PATTERNS = ["rate limit", "limit reached", "usage cap", "rate_limit_error", "Too many requests", "overloaded_error"]

// ═══════════════════════════════════════════════════════════════════════
//  EFFECTS
// ═══════════════════════════════════════════════════════════════════════

effect KeychainAccess {
    fn read_keychain(label: str) -> str
    fn delete_keychain(label: str) -> void
}

effect AccountManager {
    fn discover_accounts() -> str
    fn load_accounts() -> str
    fn save_accounts(json: str) -> void
    fn get_usage(name: str) -> str
}

// ═══════════════════════════════════════════════════════════════════════
//  ACCOUNT DISCOVERY
// ═══════════════════════════════════════════════════════════════════════

fn discover_accounts() -> str {
    // Scan ~/.claude-claude*/ directories
    let result = exec("ls -d ~/.claude-claude*/ 2>/dev/null | while read dir; do name=$(basename \"$dir\" | sed 's/^\\.//' | sed 's/^claude-//'); has_json='false'; [ -f \"$dir/.claude.json\" ] && has_json='true'; echo \"$name|$dir|$has_json\"; done").trim()
    return result
}

fn load_accounts_json() -> str {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    let exists = exec("[ -f '" + path + "' ] && echo 'yes' || echo 'no'").trim()
    if exists == "yes" {
        return exec("cat '" + path + "'").trim()
    }
    return ""
}

fn save_accounts_json(json: str) -> void {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    exec("mkdir -p ~/.airgenome")
    write_file(path, json)
}

fn bootstrap_accounts() -> str {
    let existing = load_accounts_json()
    if len(existing) > 10 {
        return existing
    }

    println("  ⬡ 첫 실행: Claude 계정 스캔 중...")
    let raw = discover_accounts()
    if len(raw) == 0 {
        println("  ✗ ~/.claude-claude*/ 디렉토리 없음")
        return ""
    }

    let lines = raw.split("\n")
    let json = "{\"accounts\":["
    let i = 0
    let count = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 3 {
            if parts[2] == "true" {
                if count > 0 {
                    json = json + ","
                }
                json = json + "{\"name\":\"" + parts[0] + "\",\"config_dir\":\"" + parts[1] + "\",\"active\":false,\"removed\":false}"
                count = count + 1
            }
        }
        i = i + 1
    }
    json = json + "]}"

    save_accounts_json(json)
    println("  ⬡ " + to_string(count) + "개 계정 발견")
    return json
}

// ═══════════════════════════════════════════════════════════════════════
//  USAGE API (reads ccmon cache, no API calls)
// ═══════════════════════════════════════════════════════════════════════

fn get_account_usage(name: str) -> str {
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    let exists = exec("[ -f '" + cache_path + "' ] && echo 'yes' || echo 'no'").trim()
    if exists == "no" {
        return "?|?"
    }
    let result = exec("/opt/homebrew/bin/python3.12 -c 'import json;d=json.load(open(\"" + cache_path + "\"));e=d.get(\"" + name + "\",{});print(str(e.get(\"session_pct\",\"?\"))+\"|\"+str(e.get(\"week_all_pct\",\"?\")))' 2>/dev/null || echo '?|?'").trim()
    return result
}

fn pick_best_account(accounts_json: str) -> str {
    // Returns best account name (lowest week usage, not exhausted, not removed)
    let accts_path = exec("echo " + ACCOUNTS_FILE).trim()
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    let result = exec("/opt/homebrew/bin/python3.12 -c \"import json;accounts=json.load(open('" + accts_path + "'))['accounts'];cache_path='" + cache_path + "'\ntry: usage=json.load(open(cache_path))\nexcept: usage={}\nbest=None; best_week=999\nfor a in accounts:\n  if a.get('removed'): continue\n  n=a['name'];u=usage.get(n,{});w=u.get('week_all_pct',999)\n  try: w=float(w)\n  except: w=999\n  if w>=100: continue\n  if w<best_week: best=n; best_week=w\nif best: print(f'{best}|{best_week}')\nelse: print('none|0')\" 2>/dev/null").trim()
    return result
}

// ═══════════════════════════════════════════════════════════════════════
//  오염 방지 (Contamination Guard)
// ═══════════════════════════════════════════════════════════════════════

fn backup_claude_json(config_dir: str) -> str {
    let json_path = config_dir + "/.claude.json"
    let backup = config_dir + "/.claude.json.bak"
    let exists = exec("[ -f '" + json_path + "' ] && echo 'yes' || echo 'no'").trim()
    if exists == "yes" {
        exec("cp '" + json_path + "' '" + backup + "'")
        // Extract original accountUuid
        let uuid = exec("/opt/homebrew/bin/python3.12 -c \"import json;d=json.load(open('" + json_path + "'));print(d.get('oauthAccount',{}).get('accountUuid',''))\" 2>/dev/null").trim()
        return uuid
    }
    return ""
}

fn check_contamination(config_dir: str, original_uuid: str) -> bool {
    if len(original_uuid) == 0 {
        return false
    }
    let json_path = config_dir + "/.claude.json"
    let current_uuid = exec("/opt/homebrew/bin/python3.12 -c \"import json;d=json.load(open('" + json_path + "'));print(d.get('oauthAccount',{}).get('accountUuid',''))\" 2>/dev/null").trim()
    if current_uuid != original_uuid {
        println("  ⚠ 오염 감지! UUID 변경: " + original_uuid + " → " + current_uuid)
        let backup = config_dir + "/.claude.json.bak"
        exec("cp '" + backup + "' '" + json_path + "'")
        println("  ✓ 백업에서 복원 완료")
        return true
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════════
//  RATE LIMIT DETECTION
// ═══════════════════════════════════════════════════════════════════════

fn check_rate_limit(logfile: str) -> bool {
    let i = 0
    while i < len(RATE_PATTERNS) {
        let found = exec("grep -qi '" + RATE_PATTERNS[i] + "' '" + logfile + "' 2>/dev/null && echo 'yes' || echo 'no'").trim()
        if found == "yes" {
            return true
        }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════════
//  LAUNCH
// ═══════════════════════════════════════════════════════════════════════

fn resolve_launch(account_name: str) -> str {
    // Returns "CONFIG_DIR|ACCOUNT_NAME" for shell wrapper to exec claude
    let config_dir = exec("/opt/homebrew/bin/python3.12 -c \"import json;d=json.load(open('" + exec("echo " + ACCOUNTS_FILE).trim() + "'));[print(a['config_dir']) for a in d['accounts'] if a['name']=='" + account_name + "']\" 2>/dev/null").trim()

    if len(config_dir) == 0 {
        println("  ✗ 계정 없음: " + account_name)
        return ""
    }

    // Usage info
    let usage = get_account_usage(account_name)
    let usage_parts = usage.split("|")
    let session_pct = usage_parts[0]
    let week_pct = "?"
    if len(usage_parts) > 1 {
        week_pct = usage_parts[1]
    }

    println("  ⬡ " + account_name + "  session=" + session_pct + "%  week=" + week_pct + "%")
    println("    " + config_dir)

    // 오염 방지: 백업
    backup_claude_json(config_dir)

    // Save active state
    exec("mkdir -p ~/.airgenome && echo '{\"active\":\"" + account_name + "\"}' > " + exec("echo " + STATE_FILE).trim())

    // Output marker for shell wrapper: LAUNCH:config_dir
    println("LAUNCH:" + config_dir)
    return config_dir
}

// ═══════════════════════════════════════════════════════════════════════
//  ACCOUNT MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════

fn add_account(name: str, config_dir: str) -> void {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    exec("/opt/homebrew/bin/python3.12 -c \"import json;d=json.load(open('" + path + "'));names=[a['name'] for a in d['accounts']]\nif '" + name + "' not in names:\n  d['accounts'].append({'name':'" + name + "','config_dir':'" + config_dir + "','active':False,'removed':False});json.dump(d,open('" + path + "','w'),indent=2);print('added')\nelse: print('exists')\"")
    println("  ⬡ 계정 추가: " + name)
}

fn remove_account(name: str) -> void {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    exec("/opt/homebrew/bin/python3.12 -c \"import json;d=json.load(open('" + path + "'))\nfor a in d['accounts']:\n  if a['name']=='" + name + "': a['removed']=True\njson.dump(d,open('" + path + "','w'),indent=2)\"")
    println("  ⬡ 계정 제거: " + name + " (폐기 표시)")
}

fn show_status() -> void {
    let accounts_json = bootstrap_accounts()
    if len(accounts_json) == 0 {
        return
    }

    println("")
    println("  ⬡ Claude Code 계정 현황")
    println("  ─────────────────────────────────────────")
    println("  이름         세션    주간    상태")
    println("  ─────────────────────────────────────────")

    let active = exec("[ -f " + exec("echo " + STATE_FILE).trim() + " ] && /opt/homebrew/bin/python3.12 -c \"import json;print(json.load(open('" + exec("echo " + STATE_FILE).trim() + "'))['active'])\" 2>/dev/null || echo ''").trim()

    let names = exec("/opt/homebrew/bin/python3.12 -c \"import json;d=json.load(open('" + exec("echo " + ACCOUNTS_FILE).trim() + "'));[print(a['name']+'|'+str(a.get('removed',False))) for a in d['accounts']]\" 2>/dev/null").trim()
    let lines = names.split("\n")
    let i = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 2 {
            let name = parts[0]
            let removed = parts[1]
            if removed == "True" {
                i = i + 1
                // skip removed, but show with strikethrough
                println("  " + name + "       -       -       [폐기됨]")
                i = i  // continue
            }
            if removed != "True" {
                let usage = get_account_usage(name)
                let u_parts = usage.split("|")
                let session = u_parts[0]
                let week = "?"
                if len(u_parts) > 1 { week = u_parts[1] }

                let status = ""
                if name == active { status = "● ACTIVE" }
                // Check if exhausted
                let w_check = exec("echo '" + week + "' | awk '{if($1+0>=100)print \"exhausted\";else if($1+0>=80)print \"warn\";else print \"ok\"}'").trim()
                if w_check == "exhausted" { status = status + " ✗ EXHAUSTED" }
                if w_check == "warn" { status = status + " ⚠" }

                println("  " + name + "    " + session + "%    " + week + "%    " + status)
            }
        }
        i = i + 1
    }
    println("  ─────────────────────────────────────────")
    println("")
}

// ═══════════════════════════════════════════════════════════════════════
//  cl u — 상세 사용량 대시보드 (세션/주간 limit + 리셋 시간)
// ═══════════════════════════════════════════════════════════════════════

fn get_full_usage(name: str) -> str {
    // Returns: session_pct|session_resets|week_pct|week_resets
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    let exists = exec("[ -f '" + cache_path + "' ] && echo 'yes' || echo 'no'").trim()
    if exists == "no" { return "?|?|?|?" }
    let result = exec("/opt/homebrew/bin/python3.12 -c \"import json;d=json.load(open('" + cache_path + "'));e=d.get('" + name + "',{});print(str(e.get('session_pct','?'))+'|'+str(e.get('session_resets','?'))+'|'+str(e.get('week_all_pct','?'))+'|'+str(e.get('week_resets','?')))\" 2>/dev/null || echo '?|?|?|?'").trim()
    return result
}

fn format_reset_time(iso_str: str) -> str {
    if iso_str == "?" { return "?" }
    if iso_str == "None" { return "-" }
    if len(iso_str) < 5 { return iso_str }
    let result = exec("/opt/homebrew/bin/python3.12 -c \"from datetime import datetime,timezone;import sys\ntry:\n  s='" + iso_str + "'\n  if 'T' in s:\n    dt=datetime.fromisoformat(s.replace('Z','+00:00'))\n    now=datetime.now(timezone.utc)\n    diff=dt-now\n    ts=int(diff.total_seconds())\n    if ts<0: print('now')\n    elif ts<3600: print(str(ts//60)+'m')\n    elif ts<86400: print(str(ts//3600)+'h '+str((ts%3600)//60)+'m')\n    else: print(str(ts//86400)+'d '+str((ts%86400)//3600)+'h')\n  else: print(s)\nexcept: print(s)\" 2>/dev/null").trim()
    return result
}

fn pct_bar(pct_str: str, width: int) -> str {
    let bar = exec("/opt/homebrew/bin/python3.12 -c \"p=min(100,max(0,int(float('" + pct_str + "') if '" + pct_str + "' not in ('?','None','') else 0)));w=" + to_string(width) + ";f=int(p/100*w);print('▓'*f+'░'*(w-f))\" 2>/dev/null || echo '░░░░░░░░░░░░░░'").trim()
    return bar
}

fn load_cache_age() -> int {
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    let age = exec("/opt/homebrew/bin/python3.12 -c 'import json,time;d=json.load(open(\"" + cache_path + "\"));print(int(time.time()-d.get(\"_ts\",0)))' 2>/dev/null").trim()
    if len(age) == 0 { return 9999 }
    return to_int(age)
}

fn pad_right(s: str, width: int) -> str {
    let result = exec("/opt/homebrew/bin/python3.12 -c \"s='" + s + "';print(s+' '*(max(0," + to_string(width) + "-len(s))))\" 2>/dev/null").trim()
    return result
}

fn pad_left(s: str, width: int) -> str {
    let result = exec("/opt/homebrew/bin/python3.12 -c \"s='" + s + "';print(' '*(max(0," + to_string(width) + "-len(s)))+s)\" 2>/dev/null").trim()
    return result
}

fn limit_tag(pct_str: str) -> str {
    let w_int = to_int(exec("echo '" + pct_str + "' | awk '{printf \"%.0f\", $1+0}'").trim())
    if w_int >= 100 { return "EXHAUSTED" }
    if w_int >= 80 { return "HIGH" }
    if w_int >= 50 { return "MID" }
    return "OK"
}

fn limit_icon(pct_str: str) -> str {
    let w_int = to_int(exec("echo '" + pct_str + "' | awk '{printf \"%.0f\", $1+0}'").trim())
    if w_int >= 100 { return "✗" }
    if w_int >= 80 { return "⚠" }
    if w_int >= 50 { return "△" }
    return "✓"
}

fn show_usage_dashboard() -> void {
    let accounts_json = bootstrap_accounts()
    if len(accounts_json) == 0 { return }

    // 단일 python3 호출로 전체 테이블 생성 (즉시 출력)
    let accounts_path = exec("echo " + ACCOUNTS_FILE).trim()
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    let state_path = exec("echo " + STATE_FILE).trim()

    let table = exec("/opt/homebrew/bin/python3.12 -c \"\nimport json,time,os\nfrom datetime import datetime,timezone\n\ndef load(p):\n    try: return json.load(open(os.path.expanduser(p)))\n    except: return {}\n\naccounts=load('" + accounts_path + "').get('accounts',[])\ncache=load('" + cache_path + "')\nstate=load('" + state_path + "')\nactive=state.get('active','')\nts=cache.get('_ts',0)\nage=int(time.time()-ts) if ts else 9999\nage_s=f'{age//60}m {age%60}s ago' if age<3600 else f'{age//3600}h ago'\n\ndef bar(p,w=14):\n    p=min(100,max(0,int(float(p)))) if p not in ('?','None','','-') else 0\n    f=int(p/100*w)\n    return chr(9619)*f+chr(9617)*(w-f)\n\ndef fmt_reset(s):\n    if not s or s in ('?','None'): return '-'\n    try:\n        dt=datetime.fromisoformat(s.replace('Z','+00:00'))\n        d=int((dt-datetime.now(timezone.utc)).total_seconds())\n        if d<0: return 'now'\n        if d<3600: return f'{d//60}m'\n        if d<86400: return f'{d//3600}h {(d%3600)//60}m'\n        return f'{d//86400}d {(d%86400)//3600}h'\n    except: return s\n\ndef lim(w):\n    try: v=float(w)\n    except: v=0\n    if v>=100: return chr(10007)+' EXHAUSTED'\n    if v>=80: return chr(9888)+' HIGH    '\n    if v>=50: return chr(9651)+' MID     '\n    return chr(10003)+' OK      '\n\nprint()\nprint(f'  \\u2b22 Claude Code Usage Dashboard          (cached {age_s})')\nprint()\nprint('  \\u250c\\u2500\\u2500\\u2500\\u2500\\u2500\\u252c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u252c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u252c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u252c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u252c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u252c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u252c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u252c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2510')\nprint('  \\u2502  #  \\u2502  Account    \\u2502 Session \\u2502                \\u2502  Reset \\u2502  Week   \\u2502                \\u2502  Reset \\u2502  Limit   \\u2502')\nprint('  \\u251c\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2524')\nfor i,a in enumerate(accounts):\n    n=a['name']; rm=a.get('removed',False)\n    idx=f'{i+1:>2}'\n    if rm:\n        print(f'  \\u2502 {idx}  \\u2502 {n:<10s}  \\u2502     -   \\u2502 {bar(0)}  \\u2502      - \\u2502     -   \\u2502 {bar(0)}  \\u2502      - \\u2502 \\u2717 \\ud3d0\\uae30\\ub428  \\u2502')\n    else:\n        e=cache.get(n,{})\n        sp=e.get('session_pct','?'); sr=e.get('session_resets','?')\n        wp=e.get('week_all_pct','?'); wr=e.get('week_resets','?')\n        sp_d='-' if sp in (None,'None','?') else f'{sp}%'\n        wp_d='-' if wp in (None,'None','?') else f'{wp}%'\n        star='\\u2605' if n==active else ' '\n        print(f'  \\u2502 {idx}{star} \\u2502 {n:<10s}  \\u2502  {sp_d:>5s}  \\u2502 {bar(sp)} \\u2502 {fmt_reset(sr):>6s} \\u2502  {wp_d:>5s}  \\u2502 {bar(wp)} \\u2502 {fmt_reset(wr):>6s} \\u2502 {lim(wp)}\\u2502')\n    if i<len(accounts)-1:\n        print('  \\u251c\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u253c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2524')\nprint('  \\u2514\\u2500\\u2500\\u2500\\u2500\\u2500\\u2534\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2534\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2534\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2534\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2534\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2534\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2534\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2534\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2518')\nprint()\n\" 2>/dev/null").trim()

    println(table)
}

// ═══════════════════════════════════════════════════════════════════════
//  CLI ROUTER
// ═══════════════════════════════════════════════════════════════════════

fn print_help() -> void {
    println("cl v" + VERSION + " — Claude Code multi-account launcher (airgenome)")
    println("")
    println("Commands:")
    println("  cl              → 최적 계정으로 claude 실행")
    println("  cl status       → 계정 현황 (간단)")
    println("  cl u            → 사용량 대시보드 (세션/주간 limit + 리셋 시간)")
    println("  cl pick <name>  → 지정 계정으로 실행")
    println("  cl add <name> <dir> → 계정 추가")
    println("  cl remove <name>    → 계정 폐기")
    println("  cl help         → 도움말")
    println("")
    println("Rate limit 시 자동 전환. 오염 방지 내장.")
    println("폐기: 이 파일 삭제 + ~/.zshrc에서 cl 제거")
}

fn main() {
    let argv = args()
    let cmd = ""
    if len(argv) > 3 {
        cmd = argv[3]
    }

    if cmd == "" {
        // Usage 캐시 자동 갱신 (5분 이상 경과 시)
        exec("cd ~/Dev/airgenome && ~/Dev/hexa-lang/hexa run modules/usage.hexa auto >/dev/null 2>&1 &")
        // Default: auto-pick best → launch
        let accounts = bootstrap_accounts()
        if len(accounts) > 0 {
            let best = pick_best_account(accounts)
            let bp = best.split("|")
            if bp[0] != "none" {
                resolve_launch(bp[0])
            }
            if bp[0] == "none" {
                println("  ✗ 사용 가능한 계정 없음")
                show_status()
            }
        }
    }
    if cmd == "status" {
        exec("cd ~/Dev/airgenome && ~/Dev/hexa-lang/hexa run modules/usage.hexa auto >/dev/null 2>&1 &")
        show_status()
    }
    if cmd == "u" {
        show_usage_dashboard()
    }
    if cmd == "pick" {
        if len(argv) > 4 {
            resolve_launch(argv[4])
        }
        if len(argv) <= 4 {
            println("usage: cl pick <name>")
        }
    }
    if cmd == "add" {
        if len(argv) > 5 {
            add_account(argv[4], argv[5])
        }
        if len(argv) <= 5 {
            println("usage: cl add <name> <config_dir>")
        }
    }
    if cmd == "remove" {
        if len(argv) > 4 {
            remove_account(argv[4])
        }
        if len(argv) <= 4 {
            println("usage: cl remove <name>")
        }
    }
    if cmd == "help" { print_help() }
}

main()
