// airgenome/modules/cl.hexa — Claude Code multi-account launcher
// python3-free: 순수 hexa + awk/grep/sed

let VERSION = "0.2.0"
let ACCOUNTS_FILE = "~/.airgenome/accounts.json"
let STATE_FILE = "~/.airgenome/cl-state.json"
let USAGE_CACHE = "~/.airgenome/usage-cache.json"

let RATE_PATTERNS = ["rate limit", "limit reached", "usage cap", "rate_limit_error", "Too many requests", "overloaded_error"]

// ═══════════════════════════════════════════════════════════════════════
//  EFFECTS
// ═══════════════════════════════════════════════════════════════════════

effect KeychainAccess {
    fn read_keychain(label: str) -> str
    fn delete_keychain(label: str) -> void
}

effect AccountManager {
    fn discover_accounts() -> str
    fn load_accounts() -> str
    fn save_accounts(json: str) -> void
    fn get_usage(name: str) -> str
}

// ═══════════════════════════════════════════════════════════════════════
//  HELPERS — 순수 hexa (python3 제거)
// ═══════════════════════════════════════════════════════════════════════

fn pad_right(s: str, width: int) -> str {
    let r = s
    while len(r) < width { r = r + " " }
    return r
}

fn pad_left(s: str, width: int) -> str {
    let r = s
    while len(r) < width { r = " " + r }
    return r
}

fn pct_bar(pct_str: str, width: int) -> str {
    let p = to_int(exec("echo '" + pct_str + "' | awk '{v=$1+0;if(v<0)v=0;if(v>100)v=100;printf \"%.0f\",v}'").trim())
    let filled = p * width / 100
    let bar = ""
    let i = 0
    while i < width {
        if i < filled { bar = bar + "\u2593" }
        if i >= filled { bar = bar + "\u2591" }
        i = i + 1
    }
    return bar
}

fn limit_tag(pct_str: str) -> str {
    let w_int = to_int(exec("echo '" + pct_str + "' | awk '{printf \"%.0f\", $1+0}'").trim())
    if w_int >= 100 { return "EXHAUSTED" }
    if w_int >= 80 { return "HIGH" }
    if w_int >= 50 { return "MID" }
    return "OK"
}

fn limit_icon(pct_str: str) -> str {
    let w_int = to_int(exec("echo '" + pct_str + "' | awk '{printf \"%.0f\", $1+0}'").trim())
    if w_int >= 100 { return "\u2717" }
    if w_int >= 80 { return "\u26a0" }
    if w_int >= 50 { return "\u25b3" }
    return "\u2713"
}

fn format_reset_time(iso_str: str) -> str {
    if iso_str == "?" { return "-" }
    if iso_str == "None" { return "-" }
    if iso_str == "null" { return "-" }
    if iso_str == "-" { return "-" }
    if iso_str == "" { return "-" }
    if len(iso_str) < 10 { return iso_str }
    let clean = exec("echo '" + iso_str + "' | sed 's/Z$//;s/+00:00$//;s/\\.[0-9]*//'").trim()
    let target_ts = to_int(exec("TZ=UTC date -j -f '%Y-%m-%dT%H:%M:%S' '" + clean + "' +%s 2>/dev/null || echo 0").trim())
    let now_ts = to_int(exec("date -u +%s").trim())
    let diff = target_ts - now_ts
    if diff < 0 { return "now" }
    if diff < 3600 { return to_string(diff / 60) + "m" }
    let hours = diff / 3600
    let rem = diff - hours * 3600
    let mins = rem / 60
    if diff < 86400 { return to_string(hours) + "h " + to_string(mins) + "m" }
    let days = diff / 86400
    let rem2 = diff - days * 86400
    let hrs = rem2 / 3600
    return to_string(days) + "d " + to_string(hrs) + "h"
}

// ═══════════════════════════════════════════════════════════════════════
//  JSON HELPERS — awk/grep/sed (python3 제거)
// ═══════════════════════════════════════════════════════════════════════

fn list_accounts(file: str) -> str {
    // Returns lines of "name|config_dir|removed"
    return exec("grep -oE '\"name\":\"[^\"]*\"|\"config_dir\":\"[^\"]*\"|\"removed\":[a-z]+' '" + file + "' 2>/dev/null | sed 's/\"//g;s/:/|/' | awk -F'|' '{if($1==\"name\")n=$2;if($1==\"config_dir\")d=$2;if($1==\"removed\"){if(n!=\"\")print n\"|\"d\"|\"$2;n=\"\"}}'").trim()
}

fn get_config_dir_for(name: str) -> str {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    let entries = list_accounts(path)
    if len(entries) == 0 { return "" }
    let lines = entries.split("\n")
    let i = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 2 {
            if parts[0] == name { return parts[1] }
        }
        i = i + 1
    }
    return ""
}

fn get_active_account() -> str {
    let state_path = exec("echo " + STATE_FILE).trim()
    return exec("sed 's/\"//g;s/.*active://;s/[,}].*//' '" + state_path + "' 2>/dev/null").trim()
}

fn cache_field(name: str, field: str) -> str {
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    return exec("sed 's/.*\"" + name + "\":{//;s/}.*//' '" + cache_path + "' 2>/dev/null | grep -o '\"" + field + "\":[^,}]*' | sed 's/[^:]*://;s/\"//g'").trim()
}

fn load_cache_age() -> int {
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    let ts = exec("grep -o '\"_ts\":[0-9.]*' '" + cache_path + "' 2>/dev/null | sed 's/\"_ts\"://'").trim()
    if len(ts) == 0 { return 9999 }
    let now = to_int(exec("date +%s").trim())
    let cache_ts = to_int(ts)
    return now - cache_ts
}

fn get_full_usage(name: str) -> str {
    // Returns: session_pct|session_resets|week_all_pct|week_resets
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    let result = exec("sed 's/.*\"" + name + "\":{//;s/}.*//' '" + cache_path + "' 2>/dev/null | sed 's/\"//g' | awk -F, '{sp=\"?\";sr=\"?\";wp=\"?\";wr=\"?\";for(i=1;i<=NF;i++){k=$i;sub(/:.*/,\"\",k);v=$i;sub(/[^:]*:/,\"\",v);if(k==\"session_pct\")sp=v;if(k==\"session_resets\")sr=v;if(k==\"week_all_pct\")wp=v;if(k==\"week_resets\")wr=v};print sp\"|\"sr\"|\"wp\"|\"wr}'").trim()
    if len(result) == 0 { return "?|?|?|?" }
    return result
}

fn get_account_usage(name: str) -> str {
    // Returns: session_pct|week_all_pct
    let cache_path = exec("echo " + USAGE_CACHE).trim()
    let exists = exec("[ -f '" + cache_path + "' ] && echo 'yes' || echo 'no'").trim()
    if exists == "no" { return "?|?" }
    let full = get_full_usage(name)
    let parts = full.split("|")
    let sp = parts[0]
    let wp = "?"
    if len(parts) > 2 { wp = parts[2] }
    return sp + "|" + wp
}

// ═══════════════════════════════════════════════════════════════════════
//  ACCOUNT DISCOVERY
// ═══════════════════════════════════════════════════════════════════════

fn discover_accounts() -> str {
    let result = exec("ls -d ~/.claude-claude*/ 2>/dev/null | while read dir; do name=$(basename \"$dir\" | sed 's/^\\.//' | sed 's/^claude-//'); has_json='false'; [ -f \"$dir/.claude.json\" ] && has_json='true'; echo \"$name|$dir|$has_json\"; done").trim()
    return result
}

fn load_accounts_json() -> str {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    let exists = exec("[ -f '" + path + "' ] && echo 'yes' || echo 'no'").trim()
    if exists == "yes" {
        return exec("cat '" + path + "'").trim()
    }
    return ""
}

fn save_accounts_json(json: str) -> void {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    exec("mkdir -p ~/.airgenome")
    write_file(path, json)
}

fn bootstrap_accounts() -> str {
    let existing = load_accounts_json()
    if len(existing) > 10 {
        return existing
    }

    println("  \u2b21 \ucca8 \uc2e4\ud589: Claude \uacc4\uc815 \uc2a4\uce94 \uc911...")
    let raw = discover_accounts()
    if len(raw) == 0 {
        println("  \u2717 ~/.claude-claude*/ \ub514\ub809\ud1a0\ub9ac \uc5c6\uc74c")
        return ""
    }

    let lines = raw.split("\n")
    let json = "{\"accounts\":["
    let i = 0
    let count = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 3 {
            if parts[2] == "true" {
                if count > 0 {
                    json = json + ","
                }
                json = json + "{\"name\":\"" + parts[0] + "\",\"config_dir\":\"" + parts[1] + "\",\"active\":false,\"removed\":false}"
                count = count + 1
            }
        }
        i = i + 1
    }
    json = json + "]}"

    save_accounts_json(json)
    println("  \u2b21 " + to_string(count) + "\uac1c \uacc4\uc815 \ubc1c\uacac")
    return json
}

// ═══════════════════════════════════════════════════════════════════════
//  PICK BEST ACCOUNT
// ═══════════════════════════════════════════════════════════════════════

fn pick_best_account(accounts_json: str) -> str {
    let accts_path = exec("echo " + ACCOUNTS_FILE).trim()
    let entries = list_accounts(accts_path)
    if len(entries) == 0 { return "none|0" }

    let lines = entries.split("\n")
    let best_name = "none"
    let best_week = 999
    let i = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 3 {
            let name = parts[0]
            let removed = parts[2]
            if removed != "true" {
                let w_str = cache_field(name, "week_all_pct")
                let w = 999
                if len(w_str) > 0 {
                    w = to_int(exec("echo '" + w_str + "' | awk '{printf \"%.0f\",$1}'").trim())
                }
                if w < 100 {
                    if w < best_week {
                        best_name = name
                        best_week = w
                    }
                }
            }
        }
        i = i + 1
    }
    return best_name + "|" + to_string(best_week)
}

// ═══════════════════════════════════════════════════════════════════════
//  \uc624\uc5fc \ubc29\uc9c0 (Contamination Guard)
// ═══════════════════════════════════════════════════════════════════════

fn extract_uuid(config_dir: str) -> str {
    let json_path = config_dir + "/.claude.json"
    return exec("grep -o '\"accountUuid\":\"[^\"]*\"' '" + json_path + "' 2>/dev/null | head -1 | sed 's/[^:]*://;s/\"//g'").trim()
}

fn backup_claude_json(config_dir: str) -> str {
    let json_path = config_dir + "/.claude.json"
    let backup = config_dir + "/.claude.json.bak"
    let exists = exec("[ -f '" + json_path + "' ] && echo 'yes' || echo 'no'").trim()
    if exists == "yes" {
        exec("cp '" + json_path + "' '" + backup + "'")
        return extract_uuid(config_dir)
    }
    return ""
}

fn check_contamination(config_dir: str, original_uuid: str) -> bool {
    if len(original_uuid) == 0 {
        return false
    }
    let current_uuid = extract_uuid(config_dir)
    if current_uuid != original_uuid {
        println("  \u26a0 \uc624\uc5fc \uac10\uc9c0! UUID \ubcc0\uacbd: " + original_uuid + " \u2192 " + current_uuid)
        let json_path = config_dir + "/.claude.json"
        let backup = config_dir + "/.claude.json.bak"
        exec("cp '" + backup + "' '" + json_path + "'")
        println("  \u2713 \ubc31\uc5c5\uc5d0\uc11c \ubcf5\uc6d0 \uc644\ub8cc")
        return true
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════════
//  RATE LIMIT DETECTION
// ═══════════════════════════════════════════════════════════════════════

fn check_rate_limit(logfile: str) -> bool {
    let i = 0
    while i < len(RATE_PATTERNS) {
        let found = exec("grep -qi '" + RATE_PATTERNS[i] + "' '" + logfile + "' 2>/dev/null && echo 'yes' || echo 'no'").trim()
        if found == "yes" {
            return true
        }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════════
//  LAUNCH
// ═══════════════════════════════════════════════════════════════════════

fn resolve_launch(account_name: str) -> str {
    let config_dir = get_config_dir_for(account_name)

    if len(config_dir) == 0 {
        println("  \u2717 \uacc4\uc815 \uc5c6\uc74c: " + account_name)
        return ""
    }

    let usage = get_account_usage(account_name)
    let usage_parts = usage.split("|")
    let session_pct = usage_parts[0]
    let week_pct = "?"
    if len(usage_parts) > 1 {
        week_pct = usage_parts[1]
    }

    println("  \u2b21 " + account_name + "  session=" + session_pct + "%  week=" + week_pct + "%")
    println("    " + config_dir)

    backup_claude_json(config_dir)

    exec("mkdir -p ~/.airgenome && echo '{\"active\":\"" + account_name + "\"}' > " + exec("echo " + STATE_FILE).trim())

    println("LAUNCH:" + config_dir)
    return config_dir
}

// ═══════════════════════════════════════════════════════════════════════
//  ACCOUNT MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════

fn add_account(name: str, config_dir: str) -> void {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    let entries = list_accounts(path)
    if entries.contains(name + "|") {
        println("  \u2b21 \uacc4\uc815 \uc774\ubbf8 \uc874\uc7ac: " + name)
        return
    }
    let lines = entries.split("\n")
    let json = "{\"accounts\":["
    let count = 0
    let i = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 3 {
            if count > 0 { json = json + "," }
            json = json + "{\"name\":\"" + parts[0] + "\",\"config_dir\":\"" + parts[1] + "\",\"active\":false,\"removed\":" + parts[2] + "}"
            count = count + 1
        }
        i = i + 1
    }
    if count > 0 { json = json + "," }
    json = json + "{\"name\":\"" + name + "\",\"config_dir\":\"" + config_dir + "\",\"active\":false,\"removed\":false}"
    json = json + "]}"
    write_file(path, json)
    println("  \u2b21 \uacc4\uc815 \ucd94\uac00: " + name)
}

fn remove_account(name: str) -> void {
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    let entries = list_accounts(path)
    let lines = entries.split("\n")
    let json = "{\"accounts\":["
    let count = 0
    let i = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 3 {
            if count > 0 { json = json + "," }
            let removed = parts[2]
            if parts[0] == name { removed = "true" }
            json = json + "{\"name\":\"" + parts[0] + "\",\"config_dir\":\"" + parts[1] + "\",\"active\":false,\"removed\":" + removed + "}"
            count = count + 1
        }
        i = i + 1
    }
    json = json + "]}"
    write_file(path, json)
    println("  \u2b21 \uacc4\uc815 \uc81c\uac70: " + name + " (\ud3d0\uae30 \ud45c\uc2dc)")
}

// ═══════════════════════════════════════════════════════════════════════
//  STATUS DISPLAY
// ═══════════════════════════════════════════════════════════════════════

fn show_status() -> void {
    let accounts_json = bootstrap_accounts()
    if len(accounts_json) == 0 { return }

    println("")
    println("  \u2b21 Claude Code \uacc4\uc815 \ud604\ud669")
    println("  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500")
    println("  \uc774\ub984         \uc138\uc158    \uc8fc\uac04    \uc0c1\ud0dc")
    println("  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500")

    let active = get_active_account()
    let path = exec("echo " + ACCOUNTS_FILE).trim()
    let entries = list_accounts(path)
    if len(entries) == 0 { return }
    let lines = entries.split("\n")
    let i = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 3 {
            let name = parts[0]
            let removed = parts[2]
            if removed == "true" {
                println("  " + name + "       -       -       [\ud3d0\uae30\ub428]")
            }
            if removed != "true" {
                let usage = get_account_usage(name)
                let u_parts = usage.split("|")
                let session = u_parts[0]
                let week = "?"
                if len(u_parts) > 1 { week = u_parts[1] }

                let status = ""
                if name == active { status = "\u25cf ACTIVE" }
                let w_check = exec("echo '" + week + "' | awk '{if($1+0>=100)print \"exhausted\";else if($1+0>=80)print \"warn\";else print \"ok\"}'").trim()
                if w_check == "exhausted" { status = status + " \u2717 EXHAUSTED" }
                if w_check == "warn" { status = status + " \u26a0" }

                println("  " + name + "    " + session + "%    " + week + "%    " + status)
            }
        }
        i = i + 1
    }
    println("  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500")
    println("")
}

// ═══════════════════════════════════════════════════════════════════════
//  cl u — \uc0c1\uc138 \uc0ac\uc6a9\ub7c9 \ub300\uc2dc\ubcf4\ub4dc
// ═══════════════════════════════════════════════════════════════════════

fn show_usage_dashboard() -> void {
    let accounts_json = bootstrap_accounts()
    if len(accounts_json) == 0 { return }

    let cache_age = load_cache_age()
    let age_str = ""
    if cache_age < 3600 {
        age_str = to_string(cache_age / 60) + "m " + to_string(cache_age - (cache_age / 60) * 60) + "s ago"
    }
    if cache_age >= 3600 {
        age_str = to_string(cache_age / 3600) + "h ago"
    }

    let active = get_active_account()

    println("")
    println("  \u2b22 Claude Code Usage Dashboard          (cached " + age_str + ")")
    println("")
    println("  \u250c\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510")
    println("  \u2502  #  \u2502  Account    \u2502 Session \u2502                \u2502  Reset \u2502  Week   \u2502                \u2502  Reset \u2502  Limit   \u2502")
    println("  \u251c\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524")

    let path = exec("echo " + ACCOUNTS_FILE).trim()
    let entries = list_accounts(path)
    if len(entries) == 0 { return }
    let lines = entries.split("\n")
    let i = 0
    while i < len(lines) {
        let parts = lines[i].split("|")
        if len(parts) >= 3 {
            let name = parts[0]
            let removed = parts[2]
            let idx = pad_left(to_string(i + 1), 2)

            if removed == "true" {
                println("  \u2502 " + idx + "  \u2502 " + pad_right(name, 10) + "  \u2502     -   \u2502 \u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591 \u2502      - \u2502     -   \u2502 \u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591 \u2502      - \u2502 \u2717 \ud3d0\uae30\ub428  \u2502")
            }
            if removed != "true" {
                let u = get_full_usage(name)
                let up = u.split("|")
                let s_pct = up[0]
                let s_reset = "?"
                let w_pct = "?"
                let w_reset = "?"
                if len(up) > 1 { s_reset = up[1] }
                if len(up) > 2 { w_pct = up[2] }
                if len(up) > 3 { w_reset = up[3] }

                let s_bar = pct_bar(s_pct, 14)
                let w_bar = pct_bar(w_pct, 14)
                let s_time = pad_left(format_reset_time(s_reset), 6)
                let w_time = pad_left(format_reset_time(w_reset), 6)

                let icon = " "
                if name == active { icon = "\u2605" }

                if s_pct == "None" { s_pct = "-" }
                if s_pct == "null" { s_pct = "-" }
                if w_pct == "None" { w_pct = "-" }
                if w_pct == "null" { w_pct = "-" }
                let s_display = s_pct
                if s_pct != "-" { if s_pct != "?" { s_display = s_pct + "%" } }
                let w_display = w_pct
                if w_pct != "-" { if w_pct != "?" { w_display = w_pct + "%" } }
                let s_val = pad_left(s_display, 5)
                let w_val = pad_left(w_display, 5)

                let lim = limit_icon(w_pct) + " " + pad_right(limit_tag(w_pct), 8)

                println("  \u2502 " + idx + icon + " \u2502 " + pad_right(name, 10) + "  \u2502  " + s_val + "  \u2502 " + s_bar + " \u2502 " + s_time + " \u2502  " + w_val + "  \u2502 " + w_bar + " \u2502 " + w_time + " \u2502 " + lim + "\u2502")
            }

            if i < len(lines) - 1 {
                println("  \u251c\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u253c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524")
            }
        }
        i = i + 1
    }
    println("  \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518")
    println("")
}

// ═══════════════════════════════════════════════════════════════════════
//  CLI ROUTER
// ═══════════════════════════════════════════════════════════════════════

fn print_help() -> void {
    println("cl v" + VERSION + " \u2014 Claude Code multi-account launcher (airgenome)")
    println("")
    println("Commands:")
    println("  cl              \u2192 \ucd5c\uc801 \uacc4\uc815\uc73c\ub85c claude \uc2e4\ud589")
    println("  cl status       \u2192 \uacc4\uc815 \ud604\ud669 (\uac04\ub2e8)")
    println("  cl u            \u2192 \uc0ac\uc6a9\ub7c9 \ub300\uc2dc\ubcf4\ub4dc (\uc138\uc158/\uc8fc\uac04 limit + \ub9ac\uc14b \uc2dc\uac04)")
    println("  cl pick <name>  \u2192 \uc9c0\uc815 \uacc4\uc815\uc73c\ub85c \uc2e4\ud589")
    println("  cl add <name> <dir> \u2192 \uacc4\uc815 \ucd94\uac00")
    println("  cl remove <name>    \u2192 \uacc4\uc815 \ud3d0\uae30")
    println("  cl help         \u2192 \ub3c4\uc6c0\ub9d0")
    println("")
    println("Rate limit \uc2dc \uc790\ub3d9 \uc804\ud658. \uc624\uc5fc \ubc29\uc9c0 \ub0b4\uc7a5.")
    println("\ud3d0\uae30: \uc774 \ud30c\uc77c \uc0ad\uc81c + ~/.zshrc\uc5d0\uc11c cl \uc81c\uac70")
}

fn main() {
    let argv = args()
    let cmd = ""
    if len(argv) > 3 {
        cmd = argv[3]
    }

    if cmd == "" {
        exec("cd ~/Dev/airgenome && ~/Dev/hexa-lang/hexa run modules/usage.hexa auto >/dev/null 2>&1 &")
        let accounts = bootstrap_accounts()
        if len(accounts) > 0 {
            let best = pick_best_account(accounts)
            let bp = best.split("|")
            if bp[0] != "none" {
                resolve_launch(bp[0])
            }
            if bp[0] == "none" {
                println("  \u2717 \uc0ac\uc6a9 \uac00\ub2a5\ud55c \uacc4\uc815 \uc5c6\uc74c")
                show_status()
            }
        }
    }
    if cmd == "status" {
        exec("cd ~/Dev/airgenome && ~/Dev/hexa-lang/hexa run modules/usage.hexa auto >/dev/null 2>&1 &")
        show_status()
    }
    if cmd == "u" {
        show_usage_dashboard()
    }
    if cmd == "pick" {
        if len(argv) > 4 {
            resolve_launch(argv[4])
        }
        if len(argv) <= 4 {
            println("usage: cl pick <name>")
        }
    }
    if cmd == "add" {
        if len(argv) > 5 {
            add_account(argv[4], argv[5])
        }
        if len(argv) <= 5 {
            println("usage: cl add <name> <config_dir>")
        }
    }
    if cmd == "remove" {
        if len(argv) > 4 {
            remove_account(argv[4])
        }
        if len(argv) <= 4 {
            println("usage: cl remove <name>")
        }
    }
    if cmd == "help" { print_help() }
}

main()
