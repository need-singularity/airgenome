// airgenome/modules/usage.hexa — Claude Code usage API
//
// ═══════════════════════════════════════════════════════════════════
// 절대규칙 (2026-04-07 수렴진화 트러블슈팅에서 확립)
//
// 1. 키체인 해시 이중화: slash hash + noslash hash 모두 검색
//    Claude Code v2.1.90은 trailing-slash 경로로 해시 계산
//    → LABELS_SLASH / LABELS_NOSLASH 양쪽 유지 필수
//
// 2. get_label은 토큰 유효성 기준 선택: 존재 여부가 아닌 expiresAt 체크
//    slash/noslash 양쪽 entry 공존 가능, 유효 토큰은 한쪽에만 존재
//
// 3. jq 파싱에서 // empty 사용 금지: null 필드가 join에서 탈락
//    → // "" 또는 // 0 | tostring 사용하여 필드 수 보장
//
// 4. 프록시 사용 금지: API rate limit은 계정(Bearer) 기반
//    IP 변경 무의미, Bright Data POST 차단, 오히려 rate limit 악화
//
// 5. 키체인 토큰 강제 갱신: claude -p "ok" --max-turns 1
//    Claude Code는 세션 유효 시 키체인 업데이트 생략함
//    → cl 스크립트에서 세션 종료 후 CLI 짧은 실행으로 강제 갱신
//
// 6. keychain acct 필드: 'ghost' (원본 유지, 'Claude Code' 아님)
// ═══════════════════════════════════════════════════════════════════
//
// ccmon rate-limit 회피 로직 이식:
//   1. 글로벌 쿨다운 (IP 기반) — rate limit 1회 → 5분 고정, 전 계정 스킵
//   2. 계정별 지수 백오프 — 20분 base → 실패마다 2배 → 최대 1시간
//   3. 성공 시 쿨다운 즉시 해제 (글로벌+계정 모두)
//   4. 에러 계정만 재조회 (캐시 신선하면)
//
// 외부 의존: security(macOS), curl, jq, python3.12(token parse)

let API_URL = "https://api.anthropic.com/api/oauth/usage"
let TOKEN_URL = "https://platform.claude.com/v1/oauth/token"
let CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e"

let HOME = exec("echo $HOME").trim()

// 프록시 비활성화 — Bright Data residential proxy가 rate limit을 악화시킴
// (POST 차단 + API rate limit은 계정 기반이라 IP 변경 무의미)
let PROXY_ARG = ""
let CACHE_FILE = HOME + "/.airgenome/usage-cache.json"
let COOLDOWN_FILE = HOME + "/.airgenome/refresh-cooldown.json"

// 쿨다운 상수
let GLOBAL_COOLDOWN_SECS = 300   // 5분 고정 (IP 기반)
let COOLDOWN_BASE = 1200         // 20분 base
let COOLDOWN_MAX = 3600          // 1시간 max

// keychain label map — slash hash (primary) | no-slash hash (fallback)
// Claude Code v2.1.90+ uses trailing-slash path hash for keychain
let LABELS_SLASH = ["claude1|Claude Code-credentials-1b06e1b8", "claude2|Claude Code-credentials-2e3f073a", "claude3|Claude Code-credentials-4e4b1c77", "claude4|Claude Code-credentials-72bcee46", "claude5|Claude Code-credentials-6a82022a", "claude6|Claude Code-credentials-e0d8d7e7", "claude7|Claude Code-credentials-503c23ac", "claude8|Claude Code-credentials-43ae0b6f", "claude9|Claude Code-credentials-610796e1", "claude10|Claude Code-credentials-17c57bbc"]
let LABELS_NOSLASH = ["claude1|Claude Code-credentials-2b949392", "claude2|Claude Code-credentials-26492e81", "claude3|Claude Code-credentials-200a5e32", "claude4|Claude Code-credentials-2adfc64a", "claude5|Claude Code-credentials-7f9319ca", "claude6|Claude Code-credentials-71a31b2a", "claude7|Claude Code-credentials-02580ebb", "claude8|Claude Code-credentials-156d23f8", "claude9|Claude Code-credentials-90c36814", "claude10|Claude Code-credentials-90defae3"]

let NOW_TS = to_int(exec("date +%s").trim())

fn get_label(name: str) -> str {
    // 유효 토큰을 가진 label 선택: slash → noslash → (어느 쪽이든 존재하는 것)
    let i = 0
    while i < len(LABELS_SLASH) {
        let ps = LABELS_SLASH[i].split("|")
        if ps[0] == name {
            let pn = LABELS_NOSLASH[i].split("|")
            let slash_label = ps[1]
            let noslash_label = pn[1]
            // 각각 토큰 만료 체크
            let slash_exp = exec("/opt/homebrew/bin/python3.12 -c 'import json,sys,time;d=json.loads(sys.stdin.read());ea=d.get(\"claudeAiOauth\",{}).get(\"expiresAt\",0);print(\"y\" if ea/1000>time.time()+60 else \"n\")' <<< \"$(security find-generic-password -l '" + slash_label + "' -w 2>/dev/null || echo '{}')\" 2>/dev/null || echo 'n'").trim()
            if slash_exp == "y" { return slash_label }
            let noslash_exp = exec("/opt/homebrew/bin/python3.12 -c 'import json,sys,time;d=json.loads(sys.stdin.read());ea=d.get(\"claudeAiOauth\",{}).get(\"expiresAt\",0);print(\"y\" if ea/1000>time.time()+60 else \"n\")' <<< \"$(security find-generic-password -l '" + noslash_label + "' -w 2>/dev/null || echo '{}')\" 2>/dev/null || echo 'n'").trim()
            if noslash_exp == "y" { return noslash_label }
            // 둘 다 만료 — 어느 쪽이든 존재하는 것 반환 (refresh 시도용)
            let kc_s = exec("security find-generic-password -l '" + slash_label + "' -w 2>/dev/null || echo ''").trim()
            if len(kc_s) > 0 { return slash_label }
            return noslash_label
        }
        i = i + 1
    }
    return ""
}

fn get_all_names() -> str {
    let result = ""
    let i = 0
    while i < len(LABELS_SLASH) {
        let parts = LABELS_SLASH[i].split("|")
        if i > 0 { result = result + "\n" }
        result = result + parts[0]
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════════
//  COOLDOWN (ccmon 동일)
// ═══════════════════════════════════════════════════════════════════════

fn load_cooldown(key: str) -> str {
    // Returns "timestamp|fail_count" or ""
    let exists = exec("[ -f '" + COOLDOWN_FILE + "' ] && echo y || echo n").trim()
    if exists == "n" { return "" }
    return exec("jq -r '.\"" + key + "\" // empty | \"\\(.t // 0)|\\(.n // 0)\"' '" + COOLDOWN_FILE + "' 2>/dev/null || echo ''").trim()
}

fn is_global_rate_limited() -> bool {
    let cd = load_cooldown("_global")
    if len(cd) == 0 { return false }
    let parts = cd.split("|")
    let t = to_int(parts[0])
    return (NOW_TS - t) < GLOBAL_COOLDOWN_SECS
}

fn is_account_on_cooldown(name: str) -> bool {
    if is_global_rate_limited() { return true }
    let cd = load_cooldown(name)
    if len(cd) == 0 { return false }
    let parts = cd.split("|")
    let t = to_int(parts[0])
    let n = to_int(parts[1])
    if n < 1 { n = 1 }
    // 지수 백오프: base * 2^(n-1), capped at max — pure computation
    let wait = to_int(exec("awk 'BEGIN{w=" + to_string(COOLDOWN_BASE) + ";for(i=1;i<" + to_string(n) + ";i++){w*=2;if(w>" + to_string(COOLDOWN_MAX) + ")w=" + to_string(COOLDOWN_MAX) + "};print w}'").trim())
    return (NOW_TS - t) < wait
}

fn set_cooldown(name: str, failed: bool) -> void {
    exec("mkdir -p " + HOME + "/.airgenome && [ -f '" + COOLDOWN_FILE + "' ] || echo '{}' > '" + COOLDOWN_FILE + "'")
    if failed {
        let prev_n = to_int(exec("jq -r '.\"" + name + "\".n // 0' '" + COOLDOWN_FILE + "' 2>/dev/null || echo 0").trim())
        let new_n = prev_n + 1
        exec("jq '.\"" + name + "\"={\"t\":" + to_string(NOW_TS) + ",\"n\":" + to_string(new_n) + "} | .\"_global\"={\"t\":" + to_string(NOW_TS) + "}' '" + COOLDOWN_FILE + "' > '" + COOLDOWN_FILE + ".tmp' && mv '" + COOLDOWN_FILE + ".tmp' '" + COOLDOWN_FILE + "'")
    }
    if failed == false {
        exec("jq 'del(.\"" + name + "\") | del(.\"_global\")' '" + COOLDOWN_FILE + "' > '" + COOLDOWN_FILE + ".tmp' && mv '" + COOLDOWN_FILE + ".tmp' '" + COOLDOWN_FILE + "' 2>/dev/null || true")
    }
}

// ═══════════════════════════════════════════════════════════════════════
//  TOKEN & API
// ═══════════════════════════════════════════════════════════════════════

fn read_keychain(label: str) -> str {
    return exec("security find-generic-password -l '" + label + "' -w 2>/dev/null || echo ''").trim()
}

fn extract_token_info(keychain_json: str) -> str {
    // Returns: access_token|refresh_token|expires_at
    return exec("/opt/homebrew/bin/python3.12 -c 'import json,sys;d=json.loads(sys.stdin.read());o=d.get(\"claudeAiOauth\",{});print(o.get(\"accessToken\",\"\")+\"|\"+o.get(\"refreshToken\",\"\")+\"|\"+str(o.get(\"expiresAt\",0)))' <<< '" + keychain_json + "' 2>/dev/null").trim()
}

fn is_token_expired(expires_at_str: str) -> bool {
    let ea = to_int(expires_at_str)
    // expiresAt is in milliseconds
    return (ea / 1000) < (NOW_TS + 60)
}

fn refresh_token(refresh_tok: str, account_name: str) -> str {
    let payload = "{\"grant_type\":\"refresh_token\",\"refresh_token\":\"" + refresh_tok + "\",\"client_id\":\"" + CLIENT_ID + "\"}"
    let result = exec("curl -s -k --max-time 15" + PROXY_ARG + " '" + TOKEN_URL + "' -H 'Content-Type: application/json' -d '" + payload + "' 2>/dev/null; true").trim()
    if len(result) == 0 { return "" }
    let new_access = exec("echo '" + result + "' | jq -r '.access_token // empty' 2>/dev/null").trim()
    if len(new_access) == 0 { return "" }

    // ccmon 동일: 갱신 성공 시 키체인에 새 토큰 저장
    let expires_in = exec("echo '" + result + "' | jq -r '.expires_in // 3600' 2>/dev/null").trim()
    let new_expires_ms = to_string((NOW_TS + to_int(expires_in)) * 1000)
    let label = get_label(account_name)
    if len(label) > 0 {
        save_keychain_token(label, new_access, new_expires_ms)
    }
    return new_access
}

fn save_keychain_token(label: str, access_token: str, expires_at_ms: str) -> void {
    // 키체인에서 기존 데이터 읽기 → accessToken + expiresAt만 교체 → 다시 저장
    let kc = read_keychain(label)
    if len(kc) == 0 { return }
    let updated = exec("/opt/homebrew/bin/python3.12 -c 'import json,sys;d=json.loads(sys.stdin.read());o=d.get(\"claudeAiOauth\",{});o[\"accessToken\"]=\"" + access_token + "\";o[\"expiresAt\"]=" + expires_at_ms + ";d[\"claudeAiOauth\"]=o;print(json.dumps(d))' <<< '" + kc + "' 2>/dev/null").trim()
    if len(updated) == 0 { return }
    // security delete + add (macOS keychain update) — acct must match original ('ghost')
    let acct = exec("security find-generic-password -l '" + label + "' 2>/dev/null | grep '\"acct\"' | sed 's/.*<blob>=\"//;s/\"//'").trim()
    if len(acct) == 0 { acct = "ghost" }
    exec("security delete-generic-password -l '" + label + "' 2>/dev/null; security add-generic-password -l '" + label + "' -a '" + acct + "' -s '" + label + "' -w '" + updated + "' 2>/dev/null")
}

fn call_usage_api(access_token: str, account_name: str) -> str {
    // Returns: session_pct|session_resets|week_pct|week_resets or "api_error"
    let result = exec("curl -s -k --max-time 15" + PROXY_ARG + " '" + API_URL + "' -H 'Authorization: Bearer " + access_token + "' -H 'anthropic-beta: oauth-2025-04-20' 2>/dev/null; true").trim()
    if len(result) == 0 { return "api_error" }
    // API 에러 감지
    let err = exec("echo '" + result + "' | jq -r '.error.type // empty' 2>/dev/null").trim()
    if len(err) > 0 { return "api_error" }
    // 파싱
    let parsed = exec("echo '" + result + "' | jq -r '[(.five_hour.utilization // 0 | tostring),(.five_hour.resets_at // \"\"),(.seven_day.utilization // 0 | tostring),(.seven_day.resets_at // \"\")] | join(\"|\")' 2>/dev/null").trim()
    if len(parsed) == 0 { return "api_error" }
    return parsed
}

fn fetch_one(name: str) -> str {
    // Returns: name|session_pct|session_resets|week_pct|week_resets or name + "||||api_error"

    // 쿨다운 체크
    if is_account_on_cooldown(name) {
        return name + "||||cooldown"
    }

    let label = get_label(name)
    if len(label) == 0 { return name + "||||no_label" }

    let kc = read_keychain(label)
    if len(kc) == 0 { return name + "||||no_keychain" }

    let info = extract_token_info(kc)
    let parts = info.split("|")
    if len(parts) < 3 { return name + "||||parse_error" }

    let access = parts[0]
    let refresh = parts[1]
    let expires = parts[2]

    if len(access) == 0 {
        if len(refresh) > 0 {
            access = refresh_token(refresh, name)
        }
        if len(access) == 0 {
            set_cooldown(name, true)
            return name + "||||token_error"
        }
    }
    if is_token_expired(expires) {
        if len(refresh) > 0 {
            let new_tok = refresh_token(refresh, name)
            if len(new_tok) > 0 { access = new_tok }
        }
    }

    let usage = call_usage_api(access, name)
    if usage == "api_error" {
        set_cooldown(name, true)
        return name + "||||api_error"
    }

    // 성공 → 쿨다운 해제
    set_cooldown(name, false)
    let u = usage.split("|")
    if len(u) >= 4 {
        return name + "|" + u[0] + "|" + u[1] + "|" + u[2] + "|" + u[3]
    }
    return name + "||||api_error"
}

// ═══════════════════════════════════════════════════════════════════════
//  CACHE
// ═══════════════════════════════════════════════════════════════════════

fn save_cache(results: str) -> void {
    exec("mkdir -p " + HOME + "/.airgenome")
    // Merge: 에러/쿨다운 계정은 기존 캐시 유지
    let py_script = "import json,time,sys,os\nlines=sys.stdin.read().strip().split('\\n')\nold={}\ntry:\n  old=json.load(open('" + CACHE_FILE + "'))\n  old.pop('_ts',None)\nexcept: pass\nd=dict(old)\nok=0;skip=0\nfor l in lines:\n  if 'cached' in l:\n    skip+=1;continue\n  if 'cooldown' in l:\n    skip+=1;continue\n  p=l.split('|')\n  n=p[0]\n  err=None\n  for tag in ['api_error','token_error','no_keychain','parse_error']:\n    if tag in l: err=tag\n  if err:\n    if n not in d or d[n].get('week_all_pct') is None:\n      d[n]={'session_pct':None,'session_resets':None,'week_all_pct':None,'week_resets':None,'error':err}\n    skip+=1;continue\n  if len(p)>=5:\n    d[n]={'session_pct':float(p[1]) if p[1] else None,'session_resets':p[2] if p[2] else None,'week_all_pct':float(p[3]) if p[3] else None,'week_resets':p[4] if p[4] else None,'error':None}\n    ok+=1\nd['_ts']=time.time()\njson.dump(d,open('" + CACHE_FILE + "','w'))\nprint(f'saved {ok} / skip {skip} (kept old)')"
    let out = exec("echo '" + results + "' | /opt/homebrew/bin/python3.12 -c \"" + py_script + "\" 2>/dev/null").trim()
    println("  " + out)
}

fn load_cache_age() -> int {
    let ts_str = exec("jq -r '._ts // 0' '" + CACHE_FILE + "' 2>/dev/null").trim()
    if len(ts_str) == 0 { return 9999 }
    let ts = to_int(exec("echo '" + ts_str + "' | awk '{printf \"%.0f\", $1}'").trim())
    if ts == 0 { return 9999 }
    return NOW_TS - ts
}

// ═══════════════════════════════════════════════════════════════════════
//  REFRESH
// ═══════════════════════════════════════════════════════════════════════

fn has_valid_cache(name: str) -> bool {
    // 캐시에 유효 데이터(week_all_pct != null)가 있는지 확인
    let wp = exec("jq -r '.\"" + name + "\".week_all_pct // empty' '" + CACHE_FILE + "' 2>/dev/null || echo ''").trim()
    if len(wp) > 0 { return true }
    return false
}

fn refresh_all() -> void {
    println("  ⬡ Usage 갱신 중...")

    // 글로벌 rate limit 체크 — 걸려있으면 전부 스킵
    if is_global_rate_limited() {
        let cd = load_cooldown("_global")
        let gt = to_int(cd.split("|")[0])
        let remaining = GLOBAL_COOLDOWN_SECS - (NOW_TS - gt)
        println("  ⚠ 글로벌 rate limit 쿨다운 중 (" + to_string(remaining) + "초 남음)")
        println("  skip all — 기존 캐시 유지")
        return
    }

    let names = get_all_names().split("\n")

    // Phase 0 (ccmon 동일): 에러 계정을 먼저 재조회 — rate limit 느슨할 때 복구
    let error_names = exec("jq -r 'to_entries[] | select(.value.error != null and .key != \"_ts\") | .key' '" + CACHE_FILE + "' 2>/dev/null || echo ''").trim()

    let results = ""
    let i = 0
    let hit_rate_limit = false
    let first = true

    // Phase 0: 에러 계정 우선 갱신
    if len(error_names) > 0 {
        let err_list = error_names.split("\n")
        let ei = 0
        while ei < len(err_list) {
            let ename = err_list[ei]
            if len(ename) == 0 {
                ei = ei + 1
                continue
            }
            if hit_rate_limit {
                ei = ei + 1
                continue
            }

            let r = fetch_one(ename)
            let status = "✓"
            if r.contains("api_error") {
                status = "✗ API에러"
                hit_rate_limit = true
            }
            if r.contains("cooldown") { status = "⏭ 쿨다운" }
            if r.contains("token_error") { status = "✗ 토큰에러" }
            if status == "✓" {
                let parts = r.split("|")
                if len(parts) >= 2 {
                    if len(parts[1]) > 0 { status = "✓ s=" + parts[1] }
                }
            }
            println("    " + ename + " " + status + " (복구)")
            if first == false { results = results + "\n" }
            results = results + r
            first = false
            ei = ei + 1
        }
    }

    // Phase 1: 나머지 계정 — 캐시 유효하면 스킵
    while i < len(names) {
        let name = names[i]

        // Phase 0에서 이미 처리한 에러 계정은 스킵
        if len(error_names) > 0 {
            if error_names.contains(name) {
                i = i + 1
                continue
            }
        }

        // 이번 실행에서 rate limit 맞았으면 나머지 스킵
        if hit_rate_limit {
            println("    " + name + " ⏭ 스킵 (rate limit)")
            if first == false { results = results + "\n" }
            results = results + name + "||||cooldown"
            first = false
            i = i + 1
            continue
        }

        // 캐시에 유효 데이터가 있으면 API 호출 생략
        if has_valid_cache(name) {
            println("    " + name + " ✓ 캐시")
            if first == false { results = results + "\n" }
            results = results + name + "||||cached"
            first = false
            i = i + 1
            continue
        }

        let r = fetch_one(name)

        let status = "✓"
        if r.contains("api_error") {
            status = "✗ API에러"
            hit_rate_limit = true
        }
        if r.contains("cooldown") { status = "⏭ 쿨다운" }
        if r.contains("token_error") { status = "✗ 토큰에러" }
        if r.contains("no_keychain") { status = "✗ 키체인없음" }
        if r.contains("parse_error") { status = "✗ 파싱에러" }
        if status == "✓" {
            let parts = r.split("|")
            if len(parts) >= 2 {
                if len(parts[1]) > 0 { status = "✓ s=" + parts[1] }
            }
        }
        println("    " + name + " " + status)
        if first == false { results = results + "\n" }
        results = results + r
        first = false
        i = i + 1
    }
    save_cache(results)
}

fn fetch_one_force(name: str) -> str {
    // 쿨다운 무시 + 직접 API 호출 (세션 종료 후 강제 갱신)
    let label = get_label(name)
    if len(label) == 0 { return name + "||||no_label" }
    let kc = read_keychain(label)
    if len(kc) == 0 { return name + "||||no_keychain" }
    let info = extract_token_info(kc)
    let parts = info.split("|")
    if len(parts) < 3 { return name + "||||parse_error" }
    let access = parts[0]
    let refresh = parts[1]
    let expires = parts[2]
    if len(access) == 0 {
        if len(refresh) > 0 { access = refresh_token(refresh, name) }
        if len(access) == 0 { return name + "||||token_error" }
    }
    if is_token_expired(expires) {
        if len(refresh) > 0 {
            let new_tok = refresh_token(refresh, name)
            if len(new_tok) > 0 { access = new_tok }
        }
    }
    let usage = call_usage_api(access, name)
    if usage == "api_error" { return name + "||||api_error" }
    // 성공 → 쿨다운 해제
    set_cooldown(name, false)
    let u = usage.split("|")
    if len(u) >= 4 { return name + "|" + u[0] + "|" + u[1] + "|" + u[2] + "|" + u[3] }
    return name + "||||api_error"
}

fn refresh_one(name: str) -> void {
    // 단일 계정 강제 갱신 (세션 종료 후 — ccmon 동일)
    // 1. 쿨다운 해제 (계정 + 글로벌)
    set_cooldown(name, false)
    // 2. API 호출 (쿨다운 무시)
    let r = fetch_one_force(name)
    let status = "✓"
    if r.contains("api_error") { status = "✗ API에러" }
    if r.contains("token_error") { status = "✗ 토큰에러" }
    if status == "✓" {
        let parts = r.split("|")
        if len(parts) >= 2 {
            if len(parts[1]) > 0 { status = "✓ s=" + parts[1] }
        }
    }
    println("    " + name + " " + status)
    save_cache(r)
}

fn refresh_if_stale() -> void {
    let age = load_cache_age()
    if age > 300 {
        refresh_all()
    }
}

fn refresh_next() -> void {
    // 라운드 로빈: 1계정씩 순차 갱신 (10분 간격 launchd용)
    // 상태 파일에서 다음 인덱스 읽기
    let idx_file = HOME + "/.airgenome/refresh-next-idx"
    let idx = to_int(exec("cat '" + idx_file + "' 2>/dev/null || echo '0'").trim())
    let names = get_all_names().split("\n")
    if idx >= len(names) { idx = 0 }
    let name = names[idx]

    // CLI로 키체인 토큰 강제 갱신
    let config_dir = HOME + "/.claude-" + name
    exec("CLAUDE_CONFIG_DIR='" + config_dir + "' " + HOME + "/.local/bin/claude -p 'ok' --max-turns 1 >/dev/null 2>&1 || true")

    // 쿨다운 해제 + API 호출
    set_cooldown(name, false)
    let r = fetch_one_force(name)
    let status = "✓"
    if r.contains("api_error") { status = "✗" }
    if r.contains("token_error") { status = "✗" }
    if r.contains("no_keychain") { status = "✗" }
    if status == "✓" {
        let parts = r.split("|")
        if len(parts) >= 4 { status = "✓ s=" + parts[1] + " w=" + parts[3] }
    }
    println("  [" + to_string(idx + 1) + "/10] " + name + " " + status)
    save_cache(r)

    // 다음 인덱스 저장
    let next = idx + 1
    if next >= len(names) { next = 0 }
    exec("echo '" + to_string(next) + "' > '" + idx_file + "'")
}

fn main() {
    let argv = args()
    let cmd = ""
    if len(argv) > 3 { cmd = argv[3] }
    let target = ""
    if len(argv) > 4 { target = argv[4] }

    if cmd == "refresh" { refresh_all() }
    if cmd == "one" { refresh_one(target) }
    if cmd == "auto" { refresh_if_stale() }
    if cmd == "next" { refresh_next() }
    if cmd == "" {
        println("usage: hexa usage.hexa [refresh|auto|one <name>|next]")
    }
}

main()
