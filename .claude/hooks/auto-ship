#!/bin/bash
# auto-ship: Stop hook for the airgenome project.
# After every Claude turn, if any tracked *.hexa source (root or modules/)
# or the Airgenome.app bundle has changed, run the full ship cycle:
#     git add -> commit -> push -> rsync Airgenome.app -> smoke-check applet
# Silent on success. On failure, emits a Claude `systemMessage` JSON
# blob so the user sees the error in the transcript.
#
# Extensionless filename intentional: HEXA-FIRST rule blocks new .sh/.py/.rs
# files, but tooling scripts in .claude/hooks/ are still needed.
#
# Pattern mirrored from ~/Dev/void/.claude/hooks/auto-ship.
set -uo pipefail

# Claude Code hooks run with a sparse PATH that may not include /usr/bin,
# so `git`, `rsync`, etc. fail with "command not found". Set PATH explicitly.
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"

cd ~/Dev/airgenome 2>/dev/null || exit 0

# Bail out fast if no source changes (untracked + modified + staged).
# Watch: root *.hexa, modules/*.hexa, and the Airgenome.app bundle.
if [ -z "$(git status --porcelain -- '*.hexa' 'modules/*.hexa' 'Airgenome.app' 2>/dev/null)" ]; then
    exit 0
fi

LOG=$(mktemp -t auto-ship.XXXXXX)
trap 'rm -f "$LOG"' EXIT

(
    set -e
    git add -- '*.hexa' 'modules/*.hexa' 'Airgenome.app'
    git commit -m "auto-ship: $(date +%H:%M)"
    git push
    # Sync bundle to /Applications (noop if identical, no sudo needed — ghost:admin)
    rsync -a --delete Airgenome.app/ /Applications/Airgenome.app/
    # Smoke: applet binary must exist and be executable
    test -x /Applications/Airgenome.app/Contents/MacOS/applet
) > "$LOG" 2>&1

rc=$?
if [ $rc -ne 0 ]; then
    # Emit a systemMessage so the failure surfaces in the Claude UI.
    python3 - "$LOG" <<'PY' 2>/dev/null || { echo "[auto-ship FAILED]" >&2; tail -50 "$LOG" >&2; }
import sys, json
with open(sys.argv[1]) as f:
    log = f.read()[-2000:]
print(json.dumps({"systemMessage": "[auto-ship FAILED]\n" + log}))
PY
    exit 0
fi

exit 0
