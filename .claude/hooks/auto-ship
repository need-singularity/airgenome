#!/bin/bash
# auto-ship: PostToolUse hook for the airgenome project.
# After every Write/Edit, if any tracked source changed, run the full ship cycle:
#     git add -> commit -> push -> build .app -> rsync -> restart
# Silent on success. On failure, emits a Claude systemMessage JSON blob.
#
# Extensionless filename intentional: HEXA-FIRST rule blocks new .sh/.py/.rs
set -uo pipefail

export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"

DIR="$HOME/Dev/airgenome"
cd "$DIR" || exit 0

# ── Cooldown: skip if last ship was < 30s ago ──
COOLDOWN="/tmp/.auto-ship-cooldown"
NOW=$(date +%s)
if [ -f "$COOLDOWN" ]; then
    PREV=$(cat "$COOLDOWN" || echo 0)
    [ $((NOW - PREV)) -lt 30 ] && exit 0
fi

# ── Bail if no tracked changes ──
DIRTY=$(git status --porcelain | grep -v '^??' || true)
[ -z "$DIRTY" ] && exit 0

echo "$NOW" > "$COOLDOWN"

LOG=$(mktemp -t auto-ship.XXXXXX)
trap 'rm -f "$LOG"' EXIT

(
    set -e

    # ── 1. Commit ──
    git add -A
    git commit -m "auto-ship: $(date +%H:%M)"

    # ── 2. Push ──
    git push

    # ── 3. Build .app (recompile JXA → main.scpt) ──
    if git diff HEAD~1 --name-only | grep -qE '(menubar_tpl\.js|settings\.js)'; then
        TMPJS=$(mktemp -t airgenome-menubar.XXXXXX.js)
        trap 'rm -f "$TMPJS" "$LOG"' EXIT
        STATE="/tmp/airgenome-state.json"
        CONFIG="$HOME/.airgenome/config.json"
        sed -e "s|__STATE__|${STATE}|g" \
            -e "s|__CONFIG__|${CONFIG}|g" \
            -e "s|__DIR__|${DIR}|g" \
            "$DIR/menubar_tpl.js" > "$TMPJS"
        TMPAPP=$(mktemp -d -t airgenome-build.XXXXXX)
        osacompile -l JavaScript -o "$TMPAPP/Airgenome.app" "$TMPJS"
        cp "$TMPAPP/Airgenome.app/Contents/Resources/Scripts/main.scpt" \
           "$DIR/Airgenome.app/Contents/Resources/Scripts/main.scpt"
        rm -rf "$TMPAPP" "$TMPJS"
        # Commit rebuilt bundle
        git add Airgenome.app/Contents/Resources/Scripts/main.scpt
        git commit -m "auto-ship: rebuild main.scpt $(date +%H:%M)" || true
        git push
    fi

    # ── 4. Copy to /Applications ──
    rsync -a --delete "$DIR/Airgenome.app/" /Applications/Airgenome.app/
    test -x /Applications/Airgenome.app/Contents/MacOS/applet

    # ── 5. Restart (LaunchAgent가 단일 인스턴스 보장) ──
    launchctl kickstart -k "gui/$(id -u)/com.airgenome.menubar"

) > "$LOG" 2>&1

rc=$?
if [ $rc -ne 0 ]; then
    python3 - "$LOG" <<'PY' 2>/dev/null || { echo "[auto-ship FAILED]" >&2; tail -50 "$LOG" >&2; }
import sys, json
with open(sys.argv[1]) as f:
    log = f.read()[-2000:]
print(json.dumps({"systemMessage": "[auto-ship FAILED]\n" + log}))
PY
    exit 0
fi

exit 0
