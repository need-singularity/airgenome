#!/usr/bin/env bash
# bin/cx — AI-native Claude CLI router (ubu/ubu2 우선, mac fallback)
#
# 책임:
#   1. modules/claude_route.hexa select → best host
#   2. mac 이면 local `command claude`, remote 이면 `ssh -t <alias> claude`
#   3. SSH handshake RTT 측정 (remote only)
#   4. 세션 종료 후 modules/claude_route.hexa record 로 genome 기록
#
# 사용:
#   cx                         # 기본 claude TUI
#   cx "~/Dev/foo"             # arg 전달 (forward)
#   cx --force-host mac        # 강제 라우팅
#   cx --show                  # 선택만, 실행 안 함
#
# Why 별도 이름: Mac 의 `claude` 가 shell 함수 wrapper (터미널 제목 설정) 라 shadow 하면 충돌.

set -uo pipefail

CALLER_CWD="$(pwd)"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
MODULE="modules/claude_route.hexa"
REG="shared/config/hosts.json"
GENOME="$ROOT/forge/claude_genome.jsonl"

die() { echo "cx: $*" >&2; exit 2; }

# ms precision timer — Linux date %N 비호환 macOS → perl fallback
now_ms() {
    if command -v perl >/dev/null 2>&1; then
        perl -MTime::HiRes=time -e 'printf "%d\n", time()*1000'
    else
        # 저해상도 fallback
        echo $(( $(date +%s) * 1000 ))
    fi
}

# arg parsing — --force-host / --show 는 wrapper 전용, 나머지는 claude 로 forward
force_host=""
show_only=false
fwd=()
while [ $# -gt 0 ]; do
    case "$1" in
        --force-host) force_host=$2; shift 2 ;;
        --show)       show_only=true; shift ;;
        --)           shift; fwd+=("$@"); break ;;
        *)            fwd+=("$1"); shift ;;
    esac
done

# host 선택
if [ -n "$force_host" ]; then
    host=$force_host
else
    host=$(hexa run "$MODULE" select 2>/dev/null | tail -n 1)
fi
[ -n "$host" ] || die "select failed — infra_state 읽기 실패?"

if [ "$show_only" = true ]; then
    echo "cx → $host"
    exit 0
fi

# alias 조회 (mac 제외)
alias=""
if [ "$host" != "mac" ]; then
    alias=$(jq -r --arg h "$host" '.hosts[$h].ssh_alias // ""' "$REG")
    [ -n "$alias" ] || die "host '$host' ssh_alias 없음"
fi

echo "cx → $host${alias:+ ($alias)}" >&2

# RTT 측정 (remote only)
rtt=0
if [ "$host" != "mac" ]; then
    r0=$(now_ms)
    if ssh -o ConnectTimeout=3 -o BatchMode=yes "$alias" true 2>/dev/null; then
        r1=$(now_ms)
        rtt=$(( r1 - r0 ))
    else
        echo "cx: ssh probe 실패 — mac 으로 fallback" >&2
        host=mac
        alias=""
    fi
fi

# CLAUDE_CONFIG_DIR 매핑: cl 이 Mac 절대경로(/Users/ghost/.claude-claudeN)로 export 하므로
# 원격에는 basename 만 뽑아서 $HOME/<basename> 형태로 전달 (호스트별 HOME 상이: /home/aiden vs /home/summer).
# cl 을 안 썼으면 이 변수는 비어있고, 원격 claude 는 기본 ~/.claude 사용.
remote_env_prefix=""
if [ "$host" != "mac" ] && [ -n "${CLAUDE_CONFIG_DIR:-}" ]; then
    base=$(basename "$CLAUDE_CONFIG_DIR")
    # $HOME 은 remote 셸이 전개 — ssh 로 전달되는 문자열에 리터럴 '$HOME' 로 두기
    remote_env_prefix='CLAUDE_CONFIG_DIR="$HOME/'"$base"'" '
fi

# BROWSER inject — 원격 /login 의 OAuth URL 을 Mac 브라우저로 역송출 (~/bin/open-on-mac).
# .bashrc 의 non-interactive 가드 우회: ssh 명령행에서 직접 export.
if [ "$host" != "mac" ]; then
    remote_env_prefix='BROWSER="$HOME/bin/open-on-mac" '"$remote_env_prefix"
fi

# cwd 매핑: 원격에 /Users/ghost → $HOME/mac_home symlink 가 있으므로 Mac 절대경로를 그대로 cd.
# 장점: Mac 경로 ($HOME 밖 포함) 가 원격에서도 동일하게 resolve. cd 실패 시 $HOME fallback.
remote_cwd_prefix=""
if [ "$host" != "mac" ]; then
    # CALLER_CWD 는 cx 최상단에서 저장한 Mac 호출 시점 pwd ($ROOT cd 전)
    # fallback chain: Mac 절대경로 → 원격 $HOME 내 동일 relative → $HOME
    #   1) Mac 절대경로 ($HOME/mac_home symlink 또는 sshfs 마운트 경유)
    #   2) /Users/ghost/foo → $HOME/foo (원격에 clone 있을 때)
    #   3) /Users/ghost/Dev/foo → $HOME/Dev/foo (Dev/ 하위 convention)
    #   4) $HOME (최후 안전망)
    caller_quoted=$(printf '%q' "$CALLER_CWD")
    # Mac HOME prefix 제거한 relative 경로 (예: /Users/ghost/Dev/airgenome → Dev/airgenome)
    case "$CALLER_CWD" in
        /Users/ghost/*)
            rel="${CALLER_CWD#/Users/ghost/}"
            rel_quoted=$(printf '%q' "$rel")
            remote_cwd_prefix='cd '"$caller_quoted"' 2>/dev/null || cd "$HOME"/'"$rel_quoted"' 2>/dev/null || cd "$HOME"; '
            ;;
        *)
            remote_cwd_prefix='cd '"$caller_quoted"' 2>/dev/null || cd "$HOME"; '
            ;;
    esac
fi

# 실행 + duration
# ${fwd[@]+"${fwd[@]}"} — 빈 배열에서 set -u unbound 방지 (bash 3.2 호환)
t0=$(date +%s)
if [ "$host" = "mac" ]; then
    command claude ${fwd[@]+"${fwd[@]}"}
    rc=$?
else
    # L4-A (2026-04-18): /login SSOT 경고 — 원격 /login 은 Mac keychain 반영 안 됨.
    # 하루 1회만 안내 (stderr). marker: ~/.airgenome/cx-login-warning.YYYYMMDD
    _cx_today=$(date +%Y%m%d)
    _cx_marker="$HOME/.airgenome/cx-login-warning.$_cx_today"
    if [ ! -f "$_cx_marker" ]; then
        mkdir -p "$(dirname "$_cx_marker")" 2>/dev/null
        : > "$_cx_marker"
        echo "cx: /login 은 Mac 에서 'CLAUDE_CONFIG_DIR=\$HOME/.claude-<n> claude' — 원격 /login 은 Mac keychain 미반영 (오늘 1회)" >&2
    fi
    # 원격 실행용 cmd 합성 (cd + env prefix + claude + args) — base64 로 ssh quoting 회피.
    inner_cmd="$remote_cwd_prefix$remote_env_prefix"$(printf '%q ' claude ${fwd[@]+"${fwd[@]}"})
    # 2026-04-18: cx_remote_launch 방식 — 원격에 미리 배포된 launcher 가
    # base64 디코드 → tmux new-session -A (attached ssh 의 pty 위에서) → claude 가 실제 tty 확보.
    # detached tmux 에서 claude 가 즉시 exit 하던 문제 해결.
    # launcher 는 bin/bootstrap + bin/sync_cx_launcher 로 설치. 미설치 시 raw fallback.
    session_base="$(basename "${CLAUDE_CONFIG_DIR:-default}")"
    session_base="${session_base#.claude-}"
    session="cx-${session_base}"
    cmd_b64=$(printf '%s' "$inner_cmd" | base64 | tr -d '\n')
    # ssh -t 단일 호출. launcher 가 tty/tmux 판정 후 exec.
    # if/else 로 명확히 분기 — inner_cmd 안의 `;` 이 다음 statement 로 escape 되는 것 방지.
    ssh -o ServerAliveInterval=60 -o ServerAliveCountMax=3 -t "$alias" \
        "if [ -x ~/.airgenome/cx_remote_launch ]; then bash ~/.airgenome/cx_remote_launch '$session' '$cmd_b64'; else $inner_cmd; fi"
    rc=$?
fi
t1=$(date +%s)
dur=$(( t1 - t0 ))

# genome 기록 (bash 직접 append — hexa sandbox 우회)
# 스키마: {ts, host, duration_s, exit, rtt_ms}
mkdir -p "$(dirname "$GENOME")"
ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
printf '{"ts":"%s","host":"%s","duration_s":%d,"exit":%d,"rtt_ms":%d}\n' \
    "$ts" "$host" "$dur" "$rc" "$rtt" >> "$GENOME"

exit $rc
