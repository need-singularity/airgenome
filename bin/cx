#!/usr/bin/env bash
# bin/cx — AI-native Claude CLI router (ubu/ubu2 우선, mac fallback)
#
# v3 (2026-04-18, C안): tmux 완전 제거. ssh -t 직결.
#   - 세션 관리 레이어 폐기 → 세션 이름 충돌 / fork 이슈 원천 소멸
#   - 원격 ~/.airgenome/cx_remote_launch 미사용 (파일 남아있어도 무해)
#   - 트레이드오프: ssh 끊기면 원격 claude 가 SIGHUP. 집 LAN 전제로 수용.
#
# 책임:
#   1. modules/claude_route.hexa select → best host
#   2. mac 이면 local `command claude`, remote 이면 `ssh -t <alias> <inner_cmd>`
#   3. SSH handshake RTT 측정 (remote only)
#   4. 세션 종료 후 genome 기록
#
# 사용:
#   cx                         # 기본 claude TUI
#   cx "~/Dev/foo"             # arg 전달 (forward)
#   cx --force-host mac        # 강제 라우팅
#   cx --show                  # 선택만, 실행 안 함
#
# Why 별도 이름: Mac 의 `claude` 가 shell 함수 wrapper (터미널 제목 설정) 라 shadow 하면 충돌.

set -uo pipefail

CALLER_CWD="$(pwd)"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
MODULE="modules/claude_route.hexa"
REG="shared/config/hosts.json"
GENOME="$ROOT/forge/claude_genome.jsonl"

die() { echo "cx: $*" >&2; exit 2; }

# ms precision timer — Linux date %N 비호환 macOS → perl fallback
now_ms() {
    if command -v perl >/dev/null 2>&1; then
        perl -MTime::HiRes=time -e 'printf "%d\n", time()*1000'
    else
        echo $(( $(date +%s) * 1000 ))
    fi
}

# arg parsing — --force-host / --show 는 wrapper 전용, 나머지는 claude 로 forward
force_host=""
show_only=false
fwd=()
while [ $# -gt 0 ]; do
    case "$1" in
        --force-host) force_host=$2; shift 2 ;;
        --show)       show_only=true; shift ;;
        --)           shift; fwd+=("$@"); break ;;
        *)            fwd+=("$1"); shift ;;
    esac
done

# host 선택
if [ -n "$force_host" ]; then
    host=$force_host
else
    host=$(hexa run "$MODULE" select 2>/dev/null | tail -n 1)
fi
[ -n "$host" ] || die "select failed — infra_state 읽기 실패?"

if [ "$show_only" = true ]; then
    echo "cx → $host"
    exit 0
fi

# alias 조회 (mac 제외)
alias=""
if [ "$host" != "mac" ]; then
    alias=$(jq -r --arg h "$host" '.hosts[$h].ssh_alias // ""' "$REG")
    [ -n "$alias" ] || die "host '$host' ssh_alias 없음"
fi

echo "cx → $host${alias:+ ($alias)}" >&2

# RTT 측정 (remote only).
# Mac ~/.ssh/config 의 ControlMaster 설정에 의존 — probe 가 master 세션을 웜업,
# 이후 ssh -t 는 동일 master 재사용 → 두 번째 핸드셰이크 skip (~200ms↓).
rtt=0
if [ "$host" != "mac" ]; then
    r0=$(now_ms)
    if ssh -o ConnectTimeout=3 -o BatchMode=yes "$alias" true 2>/dev/null; then
        r1=$(now_ms)
        rtt=$(( r1 - r0 ))
    else
        echo "cx: ssh probe 실패 — mac 으로 fallback" >&2
        host=mac
        alias=""
    fi
fi

# CLAUDE_CONFIG_DIR 매핑: cl 이 Mac 절대경로(/Users/ghost/.claude-claudeN)로 export 하므로
# 원격에는 basename 만 뽑아서 $HOME/<basename> 형태로 전달 (호스트별 HOME 상이: /home/aiden vs /home/summer).
remote_env_prefix=""
if [ "$host" != "mac" ] && [ -n "${CLAUDE_CONFIG_DIR:-}" ]; then
    base=$(basename "$CLAUDE_CONFIG_DIR")
    remote_env_prefix='CLAUDE_CONFIG_DIR="$HOME/'"$base"'" '
fi

# BROWSER inject — 원격 /login 의 OAuth URL 을 Mac 브라우저로 역송출.
if [ "$host" != "mac" ]; then
    remote_env_prefix='BROWSER="$HOME/bin/open-on-mac" '"$remote_env_prefix"
fi

# cwd 매핑: 원격 /Users/ghost → $HOME/mac_home symlink 로 Mac 절대경로 그대로 resolve.
# fallback: Mac HOME 밖이면 상대 경로 추출 시도 후 최후 $HOME.
remote_cwd_prefix=""
if [ "$host" != "mac" ]; then
    caller_quoted=$(printf '%q' "$CALLER_CWD")
    case "$CALLER_CWD" in
        /Users/ghost/*)
            rel="${CALLER_CWD#/Users/ghost/}"
            rel_quoted=$(printf '%q' "$rel")
            remote_cwd_prefix='cd '"$caller_quoted"' 2>/dev/null || cd "$HOME"/'"$rel_quoted"' 2>/dev/null || cd "$HOME"; '
            ;;
        *)
            remote_cwd_prefix='cd '"$caller_quoted"' 2>/dev/null || cd "$HOME"; '
            ;;
    esac
fi

# 실행 + duration
t0=$(date +%s)
if [ "$host" = "mac" ]; then
    command claude ${fwd[@]+"${fwd[@]}"}
    rc=$?
else
    # /login SSOT 경고 (하루 1회)
    _cx_today=$(date +%Y%m%d)
    _cx_marker="$HOME/.airgenome/cx-login-warning.$_cx_today"
    if [ ! -f "$_cx_marker" ]; then
        mkdir -p "$(dirname "$_cx_marker")" 2>/dev/null
        : > "$_cx_marker"
        echo "cx: /login 은 Mac 에서 'CLAUDE_CONFIG_DIR=\$HOME/.claude-<n> claude' — 원격 /login 은 Mac keychain 미반영 (오늘 1회)" >&2
    fi
    # ssh -t 직결. cd + env + claude. printf %q 로 args 안전 인코딩.
    # ServerAliveInterval=60 : 유휴 60s 마다 keep-alive, 3회 실패시 연결 종료 → 끊김 감지.
    # Mac ssh config 의 ControlMaster 로 probe 웜업 master 재사용 (추가 handshake 0ms).
    # --add-dir /var/folders: Mac $TMPDIR paste 이미지 경로 read 허용 (mac-tmp.service sshfs 경유). 빠지면 interactive TUI image paste 시 401 재인증 루프.
    inner_cmd="$remote_cwd_prefix$remote_env_prefix"$(printf '%q ' claude --add-dir /var/folders ${fwd[@]+"${fwd[@]}"})
    ssh -o ServerAliveInterval=60 -o ServerAliveCountMax=3 -t "$alias" "$inner_cmd"
    rc=$?
fi
t1=$(date +%s)
dur=$(( t1 - t0 ))

# genome 기록
mkdir -p "$(dirname "$GENOME")"
ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
printf '{"ts":"%s","host":"%s","duration_s":%d,"exit":%d,"rtt_ms":%d}\n' \
    "$ts" "$host" "$dur" "$rc" "$rtt" >> "$GENOME"

exit $rc
