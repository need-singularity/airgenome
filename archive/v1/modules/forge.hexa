// ═══════════════════════════════════════════════════════════════════════
//  KEYCHAIN — OAuth token extraction (KeychainSensor impl)
// ═══════════════════════════════════════════════════════════════════════

fn sanitize_label(label: str) -> str {
    // Strip single-quotes to prevent shell injection
    return label.replace("'", "")
}

fn read_keychain(label: str) -> str {
    let safe = sanitize_label(label)
    if len(safe) == 0 { return "" }
    let result = exec("security find-generic-password -l '" + safe + "' -w 2>/dev/null || echo ''")
    return result.trim()
}

fn extract_json_field(json: str, field: str) -> str {
    let marker = "\"" + field + "\":"
    let idx = json.index_of(marker)
    if idx < 0 {
        return ""
    }
    let start = idx + len(marker)
    let rest = json.substring(start, len(json)).trim()
    // String value
    if rest.substring(0, 1) == "\"" {
        let inner = rest.substring(1, len(rest))
        let end_q = inner.index_of("\"")
        if end_q < 0 {
            return ""
        }
        return inner.substring(0, end_q)
    }
    // Numeric value — read until , or } or space
    let i = 0
    let end_n = len(rest)
    while i < len(rest) {
        let ch = rest.substring(i, i + 1)
        if ch == "," {
            end_n = i
            i = len(rest)
        }
        if ch == "}" {
            end_n = i
            i = len(rest)
        }
        i = i + 1
    }
    return rest.substring(0, end_n)
}

fn extract_token(keychain_json: str) -> str {
    return extract_json_field(keychain_json, "accessToken")
}

// ═══════════════════════════════════════════════════════════════════════
//  USAGE API — fetch live utilization
// ═══════════════════════════════════════════════════════════════════════

fn fetch_usage_api(token: str) -> str {
    let result = exec("curl -s --max-time 10 '" + API_USAGE_URL + "' -H 'Authorization: Bearer " + token + "' -H 'anthropic-beta: oauth-2025-04-20'")
    return result.trim()
}

fn parse_usage_block(json: str, block_name: str) -> str {
    let marker = "\"" + block_name + "\""
    let idx = json.index_of(marker)
    if idx < 0 {
        return "?"
    }
    let rest = json.substring(idx, len(json))
    let util = extract_json_field(rest, "utilization")
    return util
}

fn parse_usage_resets(json: str, block_name: str) -> str {
    let marker = "\"" + block_name + "\""
    let idx = json.index_of(marker)
    if idx < 0 {
        return ""
    }
    let rest = json.substring(idx, len(json))
    return extract_json_field(rest, "resets_at")
}

// ═══════════════════════════════════════════════════════════════════════
//  COMMAND IMPLEMENTATIONS
// ═══════════════════════════════════════════════════════════════════════

fn forge_status() -> str {
    // Daemon state
    let state = exec("cat forge/state.json 2>/dev/null").trim()
    if len(state) > 0 {
        if state.index_of("true") >= 0 {
            println("  daemon: RUNNING")
        }
        if state.index_of("true") < 0 {
            println("  daemon: OFF")
        }
    }
    if len(state) == 0 {
        println("  daemon: OFF (no state file)")
    }

    // Active Claude processes
    let procs = exec("ps aux | grep '[c]laude' | wc -l").trim()
    println("  active claude processes: " + procs)

    // Keychain scan
    println("")
    println("  ── keychain ──")
    let i = 0
    while i < 10 {
        let label = KEYCHAIN_LABELS[i]
        let name = ACCOUNT_NAMES[i]
        let raw = read_keychain(label)
        if len(raw) > 0 {
            let token = extract_token(raw)
            if len(token) > 0 {
                println("  " + name + ": OK (token present)")
            }
            if len(token) == 0 {
                println("  " + name + ": no accessToken")
            }
        }
        if len(raw) == 0 {
            println("  " + name + ": not in keychain")
        }
        i = i + 1
    }

    // Genome/compressed stats
    let genome_count = exec("ls forge/genomes/*.genome 2>/dev/null | wc -l").trim()
    let compressed_count = exec("ls forge/compressed/*.tf 2>/dev/null | wc -l").trim()
    println("")
    println("  genomes: " + genome_count + "  compressed: " + compressed_count)
    return "ok"
}

fn forge_usage() -> str {
    println("  ── usage API (10 accounts) ──")
    println("")
    let i = 0
    while i < 10 {
        let label = KEYCHAIN_LABELS[i]
        let name = ACCOUNT_NAMES[i]
        let raw = read_keychain(label)
        if len(raw) > 0 {
            let token = extract_token(raw)
            if len(token) > 0 {
                let usage_json = fetch_usage_api(token)
                if usage_json.index_of("five_hour") >= 0 {
                    let session_pct = parse_usage_block(usage_json, "five_hour")
                    let week_pct = parse_usage_block(usage_json, "seven_day")
                    let session_resets = parse_usage_resets(usage_json, "five_hour")
                    println("  " + name + ": session=" + session_pct + "%  week=" + week_pct + "%  resets=" + session_resets)
                }
                if usage_json.index_of("five_hour") < 0 {
                    println("  " + name + ": API error or expired token")
                }
            }
            if len(token) == 0 {
                println("  " + name + ": no token")
            }
        }
        if len(raw) == 0 {
            println("  " + name + ": skip (no keychain)")
        }
        i = i + 1
    }
    return "ok"
}

// ═══════════════════════════════════════════════════════════════════════
//  CONVERSATION SCANNER — JSONL parse + 6-axis genome
// ═══════════════════════════════════════════════════════════════════════

fn scan_session_tokens(path: str) -> str {
    // Python one-liner: parse JSONL, aggregate usage fields
    // Returns: input_tokens\toutput_tokens\tcache_read\ttool_calls\tthinking_chars
    let cmd = "perl -e 'alarm 30; exec @ARGV' python3 -c \"import sys,json;it=ot=cr=tc=th=0\nfor l in open('" + path + "'):\n try:\n  d=json.loads(l)\n except:continue\n if d.get('type')=='assistant':\n  u=d.get('message',{}).get('usage',{})\n  if u:\n   it+=u.get('input_tokens',0);ot+=u.get('output_tokens',0);cr+=u.get('cache_read_input_tokens',0)\n  for c in d.get('message',{}).get('content',[]):\n   if isinstance(c,dict):\n    if c.get('type')=='tool_use':tc+=1\n    if c.get('type')=='thinking':th+=len(str(c.get('thinking','')))\nprint(f'{it}\t{ot}\t{cr}\t{tc}\t{th}')\" 2>/dev/null || echo '0\t0\t0\t0\t0'"
    let result = exec(cmd)
    return result.trim()
}

fn forge_scan() -> str {
    println("  ── scanning conversations ──")
    let total_sessions = 0
    let dir_i = 0
    while dir_i < 2 {
        let claude_dir = exec("echo " + CLAUDE_DIRS[dir_i]).trim()
        let projects_dir = claude_dir + "/projects"
        let files = exec("perl -e 'alarm 60; exec @ARGV' find " + projects_dir + " -name '*.jsonl' -type f 2>/dev/null").trim()
        if len(files) > 0 {
            let paths = files.split("\n")
            let p = 0
            while p < len(paths) {
                let path = paths[p]
                if len(path) > 0 {
                    let stats = scan_session_tokens(path)
                    if len(stats) > 0 {
                        let parts = stats.split("\t")
                        if len(parts) >= 5 {
                            let it = to_float(parts[0])
                            let ot = to_float(parts[1])
                            let cr = to_float(parts[2])
                            let tc = to_float(parts[3])
                            let th = to_float(parts[4])
                            if it > 0.0 {
                                // 6-axis: cpu=throughput, ram=context, gpu=tools, npu=thinking, power=cost, io=files
                                let cost = it * 15.0 / 1000000.0 + ot * 75.0 / 1000000.0
                                // Extract filename
                                let name_parts = path.split("/")
                                let fname = name_parts[len(name_parts) - 1]
                                println("  " + fname + "  in=" + to_string(to_int(it)) + " out=" + to_string(to_int(ot)) + " tools=" + to_string(to_int(tc)) + " $" + to_string(cost))
                                total_sessions = total_sessions + 1
                            }
                        }
                    }
                }
                p = p + 1
            }
        }
        dir_i = dir_i + 1
    }
    println("")
    println("  total sessions: " + to_string(total_sessions))
    return "ok"
}

// ═══════════════════════════════════════════════════════════════════════
//  CONVERSATION COMPRESSION
// ═══════════════════════════════════════════════════════════════════════

fn forge_compress() -> str {
    println("  ── compressing old sessions ──")
    let compressed_count = 0
    let total_saved = 0
    let dir_i = 0
    while dir_i < 2 {
        let claude_dir = exec("echo " + CLAUDE_DIRS[dir_i]).trim()
        let projects_dir = claude_dir + "/projects"
        let files = exec("perl -e 'alarm 60; exec @ARGV' find " + projects_dir + " -name '*.jsonl' -size +100k -type f 2>/dev/null").trim()
        if len(files) > 0 {
            let paths = files.split("\n")
            let p = 0
            while p < len(paths) {
                let path = paths[p]
                if len(path) > 0 {
                    let size_str = exec("wc -c < '" + path + "' 2>/dev/null").trim()
                    let size = to_int(size_str)
                    // Extract user + assistant text only (strip tool results, thinking, base64)
                    let extract_cmd = "perl -e 'alarm 30; exec @ARGV' python3 -c \"import sys,json;lines=[]\nfor l in open('" + path + "'):\n try:\n  d=json.loads(l)\n except:continue\n t=d.get('type','')\n if t in('user','assistant'):\n  c=d.get('message',{}).get('content','')\n  if isinstance(c,str):lines.append(c[:500])\n  elif isinstance(c,list):\n   for b in c:\n    if isinstance(b,dict) and b.get('type')=='text':lines.append(b.get('text','')[:500])\nprint('\\n---\\n'.join(lines[:100]))\" 2>/dev/null || echo ''"
                    let conversation = exec(extract_cmd).trim()
                    if len(conversation) > 0 {
                        let name_parts = path.split("/")
                        let fname = name_parts[len(name_parts) - 1]
                        let session_id = fname.split(".")[0]
                        let out_path = "forge/compressed/" + session_id + ".tf"
                        write_file(out_path, conversation)
                        let new_size = to_int(exec("wc -c < '" + out_path + "' 2>/dev/null").trim())
                        let saved = size - new_size
                        let pct = 0
                        if size > 0 {
                            pct = (saved * 100) / size
                        }
                        println("  " + session_id + ": " + to_string(size) + "B -> " + to_string(new_size) + "B (-" + to_string(pct) + "%)")
                        compressed_count = compressed_count + 1
                        total_saved = total_saved + saved
                    }
                }
                p = p + 1
            }
        }
        dir_i = dir_i + 1
    }
    println("")
    println("  compressed: " + to_string(compressed_count) + " sessions, saved: " + to_string(total_saved) + " bytes")
    return "ok"
}

// ═══════════════════════════════════════════════════════════════════════
//  MONITOR DAEMON on/off
// ═══════════════════════════════════════════════════════════════════════

fn forge_on() -> str {
    let state = exec("cat forge/state.json 2>/dev/null").trim()
    if state.contains("true") {
        println("  already running")
        return "ok"
    }
    let ts = exec("date +%s").trim()
    let pid = exec("echo $$").trim()
    write_file("forge/state.json", "{\"active\": true, \"pid\": " + pid + ", \"started\": " + ts + "}")
    println("  monitor ON (pid=" + pid + ")")
    println("  polling every 30s... (Ctrl+C to stop)")

    let running = true
    while running {
        // R17: parent-alive check — exit if parent process is gone (zombie prevention)
        let parent_alive = try { exec("kill -0 $PPID 2>/dev/null && echo y || echo n").trim() } catch e { "n" }
        if parent_alive == "n" { println("  [forge] parent dead — exiting"); break }

        let procs = exec("ps aux | grep '[c]laude' | wc -l").trim()
        let time_str = exec("date +%H:%M:%S").trim()
        println("  [" + time_str + "] procs=" + procs)

        // Quick usage check (first account with token)
        let raw = read_keychain(KEYCHAIN_LABELS[0])
        if len(raw) > 0 {
            let token = extract_token(raw)
            if len(token) > 0 {
                let usage_json = fetch_usage_api(token)
                if usage_json.contains("five_hour") {
                    let s_pct = parse_usage_block(usage_json, "five_hour")
                    let w_pct = parse_usage_block(usage_json, "seven_day")
                    println("         claude1: s=" + s_pct + "% w=" + w_pct + "%")
                }
            }
        }

        // Check if off command was issued
        let check = exec("cat forge/state.json 2>/dev/null").trim()
        if check.contains("false") {
            running = false
            println("  monitor stopped")
        }
        if running {
            exec("sleep 30")
        }
    }
    return "ok"
}

fn forge_off() -> str {
    let state = exec("cat forge/state.json 2>/dev/null").trim()
    let ts = exec("date +%s").trim()
    write_file("forge/state.json", "{\"active\": false, \"stopped\": " + ts + "}")
    println("  monitor OFF")
    return "ok"
}

fn forge_menubar() -> str {
    println("  ── launching menu bar ──")
    // Read JXA template
    let template = read_file("modules/templates/menubar.jxa")

    // Determine current state
    let state = exec("cat forge/state.json 2>/dev/null").trim()
    let title = "○ forge"
    let toggle_label = "Start monitoring"
    if state.contains("true") {
        title = "◉ forge"
        toggle_label = "Stop monitoring"
    }

    // Build account usage lines
    let account_lines = ""
    let i = 0
    while i < 10 {
        let name = ACCOUNT_NAMES[i]
        let label = KEYCHAIN_LABELS[i]
        let status_text = name + ": --"
        let raw = read_keychain(label)
        if len(raw) > 0 {
            let token = extract_token(raw)
            if len(token) > 0 {
                let usage = fetch_usage_api(token)
                if usage.contains("five_hour") {
                    let s_pct = parse_usage_block(usage, "five_hour")
                    let w_pct = parse_usage_block(usage, "seven_day")
                    status_text = name + ": S=" + s_pct + "% W=" + w_pct + "%"
                }
            }
        }
        account_lines = account_lines + "menu.addItem($.NSMenuItem.alloc.initWithTitleActionKeyEquivalent($('" + status_text + "'), null, $('')));\n"
        i = i + 1
    }

    // Fill template
    let jxa = template
    jxa = jxa.replace("TITLE_PLACEHOLDER", title)
    jxa = jxa.replace("TOGGLE_PLACEHOLDER", toggle_label)
    jxa = jxa.replace("ACCOUNTS_PLACEHOLDER", account_lines)
    let abs_state = exec("pwd").trim() + "/forge/state.json"
    jxa = jxa.replace("STATE_PATH_PLACEHOLDER", abs_state)

    // Write and execute
    let tmp = "/tmp/airgenome-menubar.jxa"
    write_file(tmp, jxa)
    println("  menu bar active — click ○/◉ in top bar")
    println("  (Ctrl+C or Quit menu to exit)")
    exec("osascript -l JavaScript " + tmp)
    return "ok"
}

// Print usage/help
fn print_help() -> str {
    println("forge v" + VERSION + " — 10-account Claude Code manager")
    println("")
    println("Usage: forge <command>")
    println("")
    println("Commands:")
    println("  status    — show all 10 accounts + token usage + cost")
    println("  usage     — fetch live usage from Anthropic API")
    println("  scan      — scan conversation dirs, build genome")
    println("  compress  — compress conversation logs (×716 ratio)")
    println("  on        — enable monitor daemon")
    println("  off       — disable monitor daemon")
    println("  menubar   — launch macOS menu bar widget")
    println("  help      — show this message")
    return "ok"
}

// ═══════════════════════════════════════════════════════════════════════
//  CONSCIOUSNESS BLOCK — args router
// ═══════════════════════════════════════════════════════════════════════

consciousness ForgeRouter {
    // ── self-test ──
    assert len(KEYCHAIN_LABELS) == 10
    assert len(ACCOUNT_NAMES) == 10
    assert AXIS_COUNT == 6
    assert PAIR_COUNT == 15
    assert GENOME_BYTES == 60
    assert len(VERSION) > 0
    assert len(CLIENT_ID) > 0

    let argv = args()
    // argv layout when called via:  hexa run modules/forge.hexa <cmd>
    //   argv[0] = hexa binary path
    //   argv[1] = "run"
    //   argv[2] = "modules/forge.hexa"
    //   argv[3] = command (if provided)

    let cmd = "help"
    if len(argv) > 3 {
        cmd = argv[3]
    }

    if cmd == "status"   { forge_status() }
    if cmd == "usage"    { forge_usage() }
    if cmd == "scan"     { forge_scan() }
    if cmd == "compress" { forge_compress() }
    if cmd == "on"       { forge_on() }
    if cmd == "off"      { forge_off() }
    if cmd == "menubar"  { forge_menubar() }
    if cmd == "help"     { print_help() }

    // Unknown command fallback
    if cmd != "status" {
        if cmd != "usage" {
            if cmd != "scan" {
                if cmd != "compress" {
                    if cmd != "on" {
                        if cmd != "off" {
                            if cmd != "menubar" {
                                if cmd != "help" {
                                    println("unknown command: " + cmd)
                                    println("")
                                    print_help()
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
