let COMPRESS_RATIO_TARGET = comptime { 716 }

// ═══════════════════════════════════════════════════════════════════════
//  EFFECTS
// ═══════════════════════════════════════════════════════════════════════

effect KeychainSensor {
    fn read_keychain(label: str) -> str
    fn list_keychain_labels(prefix: str) -> str
}

effect ConversationScanner {
    fn scan_dir(path: str) -> str
    fn read_conversation(path: str) -> str
    fn count_tokens(text: str) -> int
