#!/bin/bash
# airgenome gate — cargo wrapper (ubu → hetzner → local fallback)
# cargo 자식 프로세스(build script 등)로 재진입 방지
[ -n "$__AG_CARGO_GATE" ] && exec "$HOME/.cargo/bin/cargo" "$@"
export __AG_CARGO_GATE=1

UBU_HOST="192.168.50.119"; UBU_PORT="9900"; UBU_SSH="ubu"; UBU_DIR="/tmp/airgenome"; TS_HOST=""
HTZ_SSH="hetzner"; HTZ_DIR="~/Dev/hexa-lang"
CFG="$HOME/Dev/airgenome/nexus/shared/gate_config.jsonl"
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SELF_DIR/_cache.sh"
ag_load_config "$CFG"

# hexa-lang 프로젝트만 원격 오프로드 대상 (원격에 소스가 있는 프로젝트)
_cwd_project=$(basename "$(git rev-parse --show-toplevel 2>/dev/null || pwd)")
case "$_cwd_project" in
  hexa-lang) ;; # 원격 가능
  *) ag_gate_msg "local" "cargo $*"
     exec "$HOME/.cargo/bin/cargo" "$@" ;;
esac

ag_budget_enter
# ── FILTER PIPELINE ──
ag_filter_decide cargo "$@"
ag_resolve_host
_t0=$(date +%s)

# budget-full but no tunnel hint → force local
if [ "$FILTER_BUDGET_BYPASS" != "1" ]; then
  ag_budget_check && FILTER_TARGET="local"
fi
# ubu 선택이지만 unreachable → htz로 강등 (vast는 cargo 지원 없음)
if [ "$FILTER_TARGET" = "ubu" ] && [ -z "$GH" ]; then
  FILTER_TARGET="htz"
  _ag_reason_push "demote:ubu-unreachable"
fi

if [ "$FILTER_TARGET" = "local" ]; then
  ag_gate_msg "local" "cargo $* [filter:$FILTER_REASON]"
  "$HOME/.cargo/bin/cargo" "$@"
  _rc=$?
  ag_filter_record cargo local "$_rc" $(( $(date +%s) - _t0 ))
  exit $_rc
fi

# remote branch chosen — emit entanglement for rustc children (10min TTL)
ag_filter_entangle_emit "$FILTER_TARGET" 600

if [ "$FILTER_TARGET" = "ubu" ] && [ -n "$GH" ]; then
  ag_gate_msg "remote" "cargo $* [entangle:$FILTER_ENTANGLE_KEY]" "$GH:$UBU_PORT" "$UBU_DIR"
  rsync -aq --update "$HOME/Dev/nexus/shared/" "$UBU_SSH:$UBU_DIR/nexus/shared/" 2>/dev/null
  echo "cd $UBU_DIR && source ~/.cargo/env && cargo $*" | nc -w 600 "$GH" "$UBU_PORT" 2>/dev/null | sed '/^---END---$/d'
  _rc=$?
  ag_filter_record cargo ubu "$_rc" $(( $(date +%s) - _t0 ))
  exit $_rc
fi

if [ "$FILTER_TARGET" = "htz" ] && ssh -o ConnectTimeout=3 "$HTZ_SSH" true 2>/dev/null; then
  ag_gate_msg "remote" "cargo $* [entangle:$FILTER_ENTANGLE_KEY]" "$HTZ_SSH" "$HTZ_DIR"
  ssh "$HTZ_SSH" "cd $HTZ_DIR && source ~/.cargo/env 2>/dev/null; cargo $*" 2>&1
  _rc=$?
  ag_filter_record cargo htz "$_rc" $(( $(date +%s) - _t0 ))
  exit $_rc
fi

# all remotes unreachable → local + record collapse
ag_gate_msg "unreachable" "cargo $*"
"$HOME/.cargo/bin/cargo" "$@"
_rc=$?
ag_filter_record cargo local "$_rc" $(( $(date +%s) - _t0 ))
exit $_rc
