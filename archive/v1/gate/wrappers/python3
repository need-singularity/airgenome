#!/bin/bash
UBU_HOST="192.168.50.119"; UBU_PORT="9900"; UBU_SSH="ubu"; UBU_DIR="/tmp/airgenome"; TS_HOST=""
CFG="$HOME/Dev/airgenome/nexus/shared/gate_config.jsonl"
# budget + reachability + config cache (GATE_G1 optimization)
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SELF_DIR/_cache.sh"
ag_load_config "$CFG"
ag_budget_enter
ag_filter_decide python3 "$@"
_t0=$(date +%s)

# -c 인라인·REPL은 무조건 local (filter와 무관)
if [ "$1" = "-c" ] || [ $# -eq 0 ]; then
  ag_gate_msg "local" "python3 $*"
  exec /opt/homebrew/bin/python3 "$@"
fi

# budget check (tunneling 비활성 시)
if [ "$FILTER_BUDGET_BYPASS" != "1" ]; then
  ag_budget_check && FILTER_TARGET="local"
fi

ag_resolve_host
if [ "$FILTER_TARGET" = "ubu" ] && [ -z "$GH" ]; then FILTER_TARGET="local"; fi

if [ "$FILTER_TARGET" = "local" ]; then
  ag_gate_msg "local" "python3 $* [filter:$FILTER_REASON]"
  /opt/homebrew/bin/python3 "$@"
  _rc=$?
  ag_filter_record python3 local "$_rc" $(( $(date +%s) - _t0 ))
  exit $_rc
fi

# remote dispatch
ag_gate_msg "remote" "python3 $*" "$GH:$UBU_PORT" "$UBU_DIR"
rsync -aq --update "$HOME/Dev/nexus/shared/" "$UBU_SSH:$UBU_DIR/nexus/shared/" 2>/dev/null &

RARGS=()
for a in "$@"; do
  if [[ -f "$a" ]]; then
    ssh "$UBU_SSH" "mkdir -p $UBU_DIR/gate_files" 2>/dev/null
    scp -q "$a" "$UBU_SSH:$UBU_DIR/gate_files/" 2>/dev/null
    RARGS+=("$UBU_DIR/gate_files/$(basename "$a")")
  else
    RARGS+=("$a")
  fi
done
wait  # rsync 완료 대기
echo "cd $UBU_DIR && python3 ${RARGS[*]}" | nc -w 600 "$GH" "$UBU_PORT" 2>/dev/null | sed '/^---END---$/d'
_rc=$?
ag_filter_record python3 "${FILTER_TARGET:-ubu}" "$_rc" $(( $(date +%s) - _t0 ))
exit $_rc
