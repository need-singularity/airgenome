<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  session-resume — mac 부팅 직후 1회만 실행
  ~/.airgenome/session_now.json 읽어 /tmp/airgenome-resume.md 생성 + 데스크탑 알림
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.airgenome.session-resume</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/ghost/Dev/hexa-lang/target/release/hexa</string>
        <string>run</string>
        <string>/Users/ghost/Dev/airgenome/modules/session_resume.hexa</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/ghost/Dev/airgenome</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/ghost</string>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/ghost/.cargo/bin:/Users/ghost/.hx/bin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/airgenome-session-resume.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/airgenome-session-resume.err</string>
</dict>
</plist>
