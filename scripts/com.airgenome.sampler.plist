<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  sampler — 리소스 모니터 + vitals_ring tick (adaptive 간격 내장)
  내부 while-loop이 3~15초 간격으로 동작하므로 KeepAlive로 프로세스 유지
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.airgenome.sampler</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/Dev/hexa-lang/target/release/hexa</string>
        <string>__HOME__/Dev/airgenome/sampler.hexa</string>
        <string>__TMPDIR__/airgenome-state.json</string>
        <string>__HOME__/.airgenome/config.json</string>
        <string>__RAM_MB__</string>
        <string>__NCPU__</string>
        <string>__HOME__/Dev/airgenome</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__HOME__</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:__HOME__/.cargo/bin:__HOME__/.hx/bin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/airgenome-sampler.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/airgenome-sampler.err</string>
    <key>ThrottleInterval</key>
    <integer>3</integer>
</dict>
</plist>
