<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  session-snapshot — mac 다운 대비 in-flight 상태 캡처 (60초 주기)
  ~/Dev/* 모든 git repo + Claude 세션 + iTerm 탭 + WIP refs
  출력: ~/.airgenome/session_now.json (atomic) + nexus/shared/session_history.jsonl (append)
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.airgenome.session-snapshot</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/ghost/Dev/hexa-lang/target/release/hexa</string>
        <string>run</string>
        <string>/Users/ghost/Dev/airgenome/modules/session_snapshot.hexa</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/ghost/Dev/airgenome</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>StartInterval</key>
    <integer>60</integer>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/ghost</string>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/ghost/.cargo/bin:/Users/ghost/.hx/bin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/airgenome-session-snapshot.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/airgenome-session-snapshot.err</string>
    <key>ProcessType</key>
    <string>Background</string>
    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
