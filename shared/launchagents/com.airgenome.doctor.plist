<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 일 1회 ~/Library/LaunchAgents/com.airgenome.* plist drift 감사.
         manifest SSOT 와 불일치 시 stderr 로그 (자동 수정은 하지 않음 — 사용자 확인 후 install). -->
    <key>Label</key>
    <string>com.airgenome.doctor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd /Users/ghost/Dev/airgenome &amp;&amp; HEXA_LOCAL=1 hexa run bin/install_agents.hexa doctor</string>
    </array>

    <key>StartInterval</key>
    <integer>86400</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>ThrottleInterval</key>
    <integer>86400</integer>

    <key>Nice</key>
    <integer>19</integer>
    <key>LowPriorityIO</key>
    <true/>
    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>/Users/ghost/.airgenome/doctor.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ghost/.airgenome/doctor.stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/ghost/Dev/airgenome</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/ghost/Dev/nexus/shared/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/ghost</string>
        <key>HEXA_LOCAL</key>
        <string>1</string>
    </dict>
</dict>
</plist>
