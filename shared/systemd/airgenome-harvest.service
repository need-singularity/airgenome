[Unit]
Description=airgenome harvest — per-process 6-axis genome collection
After=network.target

[Service]
Type=oneshot
WorkingDirectory=%h/Dev/airgenome
ExecStart=%h/Dev/hexa-lang/hexa run %h/Dev/airgenome/modules/harvest.hexa
StandardOutput=append:%h/Dev/airgenome/forge/harvest.stdout.log
StandardError=append:%h/Dev/airgenome/forge/harvest.stderr.log
Nice=10
IOSchedulingClass=idle
