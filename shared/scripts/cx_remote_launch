#!/bin/bash
# shared/scripts/cx_remote_launch — 원격 호스트에 설치되어 cx 로부터 ssh 를 통해 호출.
#
# Mac 측 cx 에서 ssh -t <alias> bash ~/.airgenome/cx_remote_launch <session> <cmd_b64>
# 으로 호출. base64 인코딩으로 ssh quoting 중첩 회피.
#
# 역할: tmux 가 있고 tty 면 `tmux new-session -A` 로 감싸 claude 를 persist 시킴.
# 없으면 bash -c 로 직접 실행 (기존 동작).
#
# 핵심: tmux new-session 을 -t (attached) ssh 안에서 실행 → claude 가 실제 pty 에 붙어
# 정상 render. 기존 `-d` (detached) 방식은 claude 가 pty 없는 것처럼 인식해 즉시 exit
# 하고 bash 로 회귀하던 문제 해결.
set -eu

SESSION="${1:?usage: cx_remote_launch <session> <cmd_b64>}"
CMD_B64="${2:?usage: cx_remote_launch <session> <cmd_b64>}"
CMD=$(printf '%s' "$CMD_B64" | base64 -d)

if [ "${CX_NO_TMUX:-0}" != "1" ] && command -v tmux >/dev/null 2>&1 && [ -t 0 ] && [ -t 1 ]; then
    # tmux new -A: 세션 있으면 attach (shell-command 무시), 없으면 생성 + shell-command 실행.
    # attached 상태의 ssh -t pty 를 tmux 가 이어받음 → claude 가 정상 pty 확보.
    exec tmux new-session -A -s "$SESSION" bash -c "$CMD"
fi
exec bash -c "$CMD"
